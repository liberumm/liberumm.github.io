async function mergeSavedDatasets(ids, datasetName, storageMeta={}){
  clearChunkCache();
  const list=(Array.isArray(ids) ? ids : []).filter(Boolean);
  if (list.length < 2) throw new Error("Select at least two saved datasets to merge");
  const root=await rootDir();
  const opened=[];
  for (const id of list){
    opened.push(await loadValidatedDataset(id,{rebuildStats:true}));
  }
  const base=opened[0].manifest;
  const baseSig=schemaFullSignatureFromColumns(base.columns);
  for (const item of opened.slice(1)){
    const sig=schemaFullSignatureFromColumns(item.manifest.columns);
    if (sig !== baseSig) throw new Error(`Merge blocked: saved dataset ${item.manifest.name || item.id} has a different column name/type layout`);
  }

  const id=makeDatasetId(datasetName || `merged_${list.length}_saved`);
  const targetDir=await root.getDirectoryHandle(id,{create:true});

  try{
    const columns=base.columns;
    const chunkMetas=[];
    let chunkIndex=0;

    for (let d=0; d<opened.length; d++){
      const item=opened[d];
      for (let c=0; c<item.chunks.length; c++){
        if (state.cancelled) throw new Error("Cancelled");
        post("PROGRESS",{value:Math.floor((d/opened.length)*100), text:`Merging saved dataset ${d+1}/${opened.length}: chunk ${c+1}/${item.chunks.length}`});
        const sourceChunkDir=await item.dir.getDirectoryHandle(`chunk_${String(c).padStart(6,"0")}`);
        const targetChunkDir=await targetDir.getDirectoryHandle(`chunk_${String(chunkIndex).padStart(6,"0")}`, {create:true});
        for (const col of columns){
          await writeBuffer(targetChunkDir, colFileName(col.index,col.type), await readBuffer(sourceChunkDir, colFileName(col.index,col.type)));
          if (col.type === "string") await writeJson(targetChunkDir, dictFileName(col.index), await readJson(sourceChunkDir, dictFileName(col.index)));
        }
        const meta=await readJson(sourceChunkDir,"meta.json");
        const copiedMeta={...meta,chunkIndex};
        await writeJson(targetChunkDir,"meta.json",copiedMeta);
        chunkMetas.push(copiedMeta);
        chunkIndex++;
      }
    }

    function sumReport(key){ return opened.reduce((a,x)=>a+Number(x.manifest.cleanReport?.[key]||0),0); }
    const totalRows=opened.reduce((a,x)=>a+Number(x.manifest.totalRows||0),0);
    const sourceRows=opened.reduce((a,x)=>a+Number(x.manifest.sourceRows||0),0);
    const cleanReport={
      sourceRows,totalRows,
      skippedRows:sumReport("skippedRows"),
      malformedRows:sumReport("malformedRows"),
      changedCells:sumReport("changedCells"),
      nullCells:sumReport("nullCells"),
      invalidNumbers:sumReport("invalidNumbers")
    };
    const tableName=cleanMetaValue(storageMeta.tableName || datasetName || `merged_${list.length}_saved`, `merged_${list.length}_saved`);
    const manifest={
      id,
      name:datasetName || tableName,
      storageWorkspace:cleanMetaValue(storageMeta.storageWorkspace, manifestWorkspace(base)),
      storageCollection:cleanMetaValue(storageMeta.storageCollection, manifestCollection(base)),
      tableName,
      storagePath:`${cleanMetaValue(storageMeta.storageWorkspace, manifestWorkspace(base))} / ${cleanMetaValue(storageMeta.storageCollection, manifestCollection(base))} / ${tableName}`,
      originalFileName:opened.map(x=>x.manifest.name || x.id).join(" + "),
      sourceDatasets:opened.map(x=>({id:x.id,name:x.manifest.name,rows:x.manifest.totalRows,chunks:x.manifest.chunks,createdAt:x.manifest.createdAt})),
      createdAt:new Date().toISOString(),
      mode:"columnar-clean-merged-opfs",
      formatVersion:5, features:integrityFeatureFlags({}),
      encoding:base.encoding,
      delimiter:base.delimiter,
      fileSize:opened.reduce((a,x)=>a+Number(x.manifest.fileSize||0),0),
      chunkSize:base.chunkSize,
      totalRows,
      sourceRows,
      chunks:chunkMetas.length,
      columns,
      rules:base.rules,
      cleanReport
    };
    await writeJson(targetDir,"manifest.json",manifest);
    await writeJson(targetDir,"chunks.json",chunkMetas);
    state.dataset={id,manifest,chunks:chunkMetas};
    state.virtual=null; state.memory=null; state.manifest=manifest; state.dir=targetDir; state.searchMatches=[]; state.dataQueryMatches=null; state.dataQueryMeta=null; state.pivotTable=null; state.pivotTileIndex=null; state.timeTable=null;
    return {manifest,chunks:chunkMetas};
  }catch(err){
    await cleanupDatasetDir(root,id);
    throw err;
  }
}

