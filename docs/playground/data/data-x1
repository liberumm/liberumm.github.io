function post(type, payload={}){ self.postMessage({type,...payload}); }
function now(){ return performance.now(); }
function fmt(n){ return Number(n || 0).toLocaleString(); }
let progressLastPostAt = 0;
let progressCurrentValue = 0;
function bytesLabel(pos,total){
  const mb = 1024 * 1024;
  if (!total) return `${fmt(pos)} bytes`;
  return `${fmt(Math.round(pos / mb))}/${fmt(Math.round(total / mb))} MB`;
}
function fileKey(file){ return file ? `${file.name}|${file.size}|${file.lastModified || 0}` : ""; }

function stableRulesKey(rules){
  return JSON.stringify({
    trim:!!rules.trim,
    nfkc:!!rules.nfkc,
    controls:!!rules.controls,
    collapse:!!rules.collapse,
    emptyNull:!!rules.emptyNull,
    numericSymbols:!!rules.numericSymbols,
    dedupSpaces:!!rules.dedupSpaces,
    skipBadRows:!!rules.skipBadRows,
    nullTokens:[...(rules.nullTokens || [])].map(String).sort(),
    numericThreshold:Number(rules.numericThreshold ?? 0.9)
  });
}
function schemaCacheKey(file, encoding, delimiter, rules){
  return JSON.stringify({
    file:fileKey(file),
    encoding:String(encoding || "utf-8"),
    delimiter:String(delimiter || ","),
    rules:stableRulesKey(rules || {})
  });
}
function postProgress(value, text, payload={}){
  const t = now();
  const v = Number.isFinite(Number(value)) ? Math.max(0, Math.min(100, Number(value))) : progressCurrentValue;
  progressCurrentValue = v;
  if (t - progressLastPostAt < 140 && v < 100 && v > 0) return;
  progressLastPostAt = t;
  post("PROGRESS", { value:v, text, ...payload });
}

const chunkColumnCache = {
  map: new Map(),
  bytes: 0,
  maxBytes: 128 * 1024 * 1024,
  maxEntries: 128,
  hits: 0,
  misses: 0,
  evictions: 0
};

function clearChunkCache(){
  chunkColumnCache.map.clear();
  chunkColumnCache.bytes = 0;
  chunkColumnCache.hits = 0;
  chunkColumnCache.misses = 0;
  chunkColumnCache.evictions = 0;
}

function estimateStringBytes(s){
  return typeof s === "string" ? s.length * 2 : 0;
}

function estimateColumnDataBytes(colData){
  if (!colData) return 0;
  if (colData.type === "number") return Number(colData.data?.byteLength || 0);
  let bytes = Number(colData.ids?.byteLength || 0);
  const dict = Array.isArray(colData.dict) ? colData.dict : [];
  for (let i=0; i<dict.length; i++) bytes += estimateStringBytes(dict[i]) + 8;
  return bytes;
}

function touchChunkCacheEntry(key, entry){
  chunkColumnCache.map.delete(key);
  entry.lastUsed = now();
  chunkColumnCache.map.set(key, entry);
  return entry.value;
}

function putChunkCacheEntry(key, value, bytes){
  const safeBytes = Math.max(0, Number(bytes || 0));
  if (safeBytes > chunkColumnCache.maxBytes) return value;
  if (chunkColumnCache.map.has(key)){
    const old = chunkColumnCache.map.get(key);
    chunkColumnCache.bytes -= Number(old.bytes || 0);
    chunkColumnCache.map.delete(key);
  }
  chunkColumnCache.map.set(key, {value, bytes:safeBytes, lastUsed:now()});
  chunkColumnCache.bytes += safeBytes;

  while (
    chunkColumnCache.map.size > chunkColumnCache.maxEntries ||
    chunkColumnCache.bytes > chunkColumnCache.maxBytes
  ){
    const firstKey = chunkColumnCache.map.keys().next().value;
    if (firstKey === undefined) break;
    const old = chunkColumnCache.map.get(firstKey);
    chunkColumnCache.bytes -= Number(old?.bytes || 0);
    chunkColumnCache.map.delete(firstKey);
    chunkColumnCache.evictions++;
  }
  return value;
}

function chunkCacheKey(datasetId, physicalChunkIndex, columnIndex, type){
  return `${datasetId || "active"}\u001f${physicalChunkIndex}\u001f${columnIndex}\u001f${type || ""}`;
}

function chunkCacheSnapshot(){
  return {
    entries: chunkColumnCache.map.size,
    mb: Math.round(chunkColumnCache.bytes / 1024 / 1024),
    hits: chunkColumnCache.hits,
    misses: chunkColumnCache.misses,
    evictions: chunkColumnCache.evictions
  };
}

function parseCSVLine(line, delimiter){
  if (line.endsWith("\r")) line = line.slice(0,-1);
  const out=[]; let cur="", inQuotes=false;
  for (let i=0;i<line.length;i++){
    const ch=line[i];
    if (ch === '"'){
      if (inQuotes && line[i+1] === '"'){ cur+='"'; i++; }
      else inQuotes=!inQuotes;
    } else if (ch === delimiter && !inQuotes){ out.push(cur); cur=""; }
    else cur+=ch;
  }
  out.push(cur);
  return out;
}

function cleanHeaderName(name, i, rules){
  let s = String(name ?? "");
  if (rules.nfkc) try{s=s.normalize("NFKC")}catch{}
  if (rules.trim) s=s.trim();
  if (rules.controls) s=s.replace(/[\u0000-\u001F\u007F]/g,"");
  if (rules.collapse) s=s.replace(/[\s\u3000]+/g," ");
  s = s.replace(/[\\/:*?"<>|#%&{}$!'@+`=]/g,"_");
  return s || `Column${i+1}`;
}

function uniqueNames(names){
  const seen=new Map();
  return names.map(n=>{
    const base=n || "Column";
    const c=seen.get(base)||0;
    seen.set(base,c+1);
    return c ? `${base}_${c+1}` : base;
  });
}

function makeRules(msg){
  const tokens = String(msg.nullTokens ?? "").split(/\r?\n/).map(x=>x.trim()).filter(Boolean);
  return {
    trim:!!msg.ruleTrim,
    nfkc:!!msg.ruleNfkc,
    controls:!!msg.ruleControls,
    collapse:!!msg.ruleCollapse,
    emptyNull:!!msg.ruleEmptyNull,
    numericSymbols:!!msg.ruleNumericSymbols,
    dedupSpaces:!!msg.ruleDedupSpaces,
    skipBadRows:!!msg.ruleSkipBadRows,
    nullTokens:tokens,
    numericThreshold:Number(msg.numericThreshold ?? 0.9)
  };
}

function cleanCell(raw, rules){
  let s = raw == null ? "" : String(raw);
  let changed = false;
  const before = s;
  if (rules.nfkc) { try{ const n=s.normalize("NFKC"); changed ||= n!==s; s=n; }catch{} }
  if (rules.controls) { const n=s.replace(/[\u0000-\u0008\u000B\u000C\u000E-\u001F\u007F]/g,""); changed ||= n!==s; s=n; }
  if (rules.dedupSpaces) { const n=s.replace(/\u3000/g," "); changed ||= n!==s; s=n; }
  if (rules.trim) { const n=s.trim(); changed ||= n!==s; s=n; }
  if (rules.collapse) { const n=s.replace(/[ \t]+/g," "); changed ||= n!==s; s=n; }
  if (rules.emptyNull && s === "") return {value:null, changed: changed || before !== s, wasNull:true};
  if (rules.nullTokens.some(t => s.toLowerCase() === t.toLowerCase())) return {value:null, changed:true, wasNull:true};
  return {value:s, changed:changed || before !== s, wasNull:false};
}

function numberCandidate(value, rules){
  if (value == null) return {ok:false, value:NaN};
  let s = String(value).trim();
  if (!s) return {ok:false, value:NaN};
  if (rules.numericSymbols) {
    let pct = false;
    if (s.endsWith("%")) { pct = true; s = s.slice(0,-1); }
    s = s.replace(/[,\s]/g,"").replace(/[￥¥$€£]/g,"");
    s = s.replace(/[()]/g, m => m === "(" ? "-" : "");
    const n = Number(s);
    if (Number.isFinite(n)) return {ok:true, value:pct ? n/100 : n};
  }
  const n = Number(s);
  return Number.isFinite(n) ? {ok:true,value:n} : {ok:false,value:NaN};
}

async function* fileLines(file, encoding, start=0, progressLabel="", progressBase=0, progressSpan=100){
  const decoder = new TextDecoder(encoding);
  const chunkSize = 4 * 1024 * 1024;
  let pos=start;
  let record="";
  let inQuotes=false;
  let pendingQuote=false;

  function* consumeText(text){
    for (let i=0;i<text.length;i++){
      let ch=text[i];

      if (pendingQuote){
        if (inQuotes && ch === '"'){
          record += '""';
          pendingQuote = false;
          continue;
        }
        record += '"';
        inQuotes = !inQuotes;
        pendingQuote = false;
      }

      if (ch === '"'){
        pendingQuote = true;
        continue;
      }

      if (ch === "\n" && !inQuotes){
        yield record.replace(/\r$/,"");
        record="";
      } else {
        record += ch;
      }
    }
  }

  while(pos < file.size){
    if (state.cancelled) throw new Error("Cancelled");
    const end=Math.min(file.size,pos+chunkSize);
    const text=decoder.decode(await file.slice(pos,end).arrayBuffer(), {stream:end<file.size});
    pos=end;
    if (progressLabel){
      const pct = file.size ? Math.floor((pos / file.size) * 100) : 100;
      const value = Math.min(99, Math.floor(progressBase + (pct / 100) * progressSpan));
      postProgress(value, `${progressLabel}: ${bytesLabel(pos,file.size)} (${pct}%)`, {loadedBytes:pos,totalBytes:file.size,stage:progressLabel});
    }
    yield* consumeText(text);
  }

  const tail=decoder.decode();
  if (tail) yield* consumeText(tail);
  if (pendingQuote){
    record += '"';
    pendingQuote=false;
  }
  if (record.length) yield record.replace(/\r$/,"");
}

function opfsAvailable(){ return !!(self.navigator && navigator.storage && navigator.storage.getDirectory); }
async function rootDir(){
  if (!opfsAvailable()) throw new Error("OPFS is not available. Open this HTML via localhost if file:// is restricted.");
  const root=await navigator.storage.getDirectory();
  return await root.getDirectoryHandle("quantum_csv_grid_columnar", {create:true});
}
function safeId(text){
  return String(text || "dataset").normalize("NFKC").replace(/[\\/:*?"<>|#%&{}$!'@+`=\s]+/g,"_").replace(/_+/g,"_").slice(0,80) || "dataset";
}
function makeDatasetId(name){
  const stamp = new Date().toISOString().replace(/[-:.TZ]/g,"").slice(0,17);
  const rand = crypto.getRandomValues(new Uint32Array(1))[0].toString(36);
  return `${safeId(name)}_${stamp}_${rand}`;
}
function cleanMetaValue(text, fallback){
  const s=String(text || "").normalize("NFKC").trim();
  return s || fallback;
}
function manifestWorkspace(m){ return cleanMetaValue(m?.storageWorkspace || m?.workspace, "Default"); }
function manifestCollection(m){ return cleanMetaValue(m?.storageCollection || m?.collection, "General"); }
function manifestTableName(m){ return cleanMetaValue(m?.tableName || m?.name || m?.id, "Table"); }
function manifestPath(m){ return `${manifestWorkspace(m)} / ${manifestCollection(m)} / ${manifestTableName(m)}`; }
async function writeText(dir,name,text){ const h=await dir.getFileHandle(name,{create:true}); const w=await h.createWritable(); await w.write(text); await w.close(); }
async function readText(dir,name){ const h=await dir.getFileHandle(name); return await (await h.getFile()).text(); }
async function writeJson(dir,name,obj){ await writeText(dir,name,JSON.stringify(obj)); }
async function readJson(dir,name){ return JSON.parse(await readText(dir,name)); }
async function writeBuffer(dir,name,buffer){ const h=await dir.getFileHandle(name,{create:true}); const w=await h.createWritable(); await w.write(buffer); await w.close(); }
async function readBuffer(dir,name){ const h=await dir.getFileHandle(name); return await (await h.getFile()).arrayBuffer(); }

async function fileByteLength(dir,name){
  const h=await dir.getFileHandle(name);
  return Number((await h.getFile()).size || 0);
}

async function cleanupDatasetDir(root,id){
  try{ await root.removeEntry(id,{recursive:true}); }catch{}
}

function integrityFeatureFlags(base={}){
  return {
    ...(base || {}),
    columnStats:true,
    rowCountAddressing:true,
    quoteNewlineCSV:true,
    lruChunkCache:true,
    integrityCheck:true,
    repairLayer:true,
    queryPlan:true,
    predicatePushdown:true,
    chunkExecutionEngine:true,
    chunkWorkerPool:true,
    distributedAggregateReduce:true,
    remoteExecutionAdapter:true,
    browserExternalStorageAdapter:true
  };
}

function integritySummary(ok, issues=[], warnings=[], repairs=[]){
  return {
    ok:!!ok,
    checkedAt:new Date().toISOString(),
    issueCount:issues.length,
    warningCount:warnings.length,
    repairCount:repairs.length,
    issues:issues.slice(0,50),
    warnings:warnings.slice(0,50),
    repairs:repairs.slice(0,50)
  };
}

function issueText(e){ return e && e.message ? e.message : String(e || "Unknown error"); }
function expectedColumnBytes(rowCount,type){ return Number(rowCount || 0) * (type === "number" ? 8 : 4); }
function rowCountFromBytes(byteLength,type){
  const width = type === "number" ? 8 : 4;
  const n = Number(byteLength || 0);
  if (!Number.isFinite(n) || n < 0 || n % width !== 0) return null;
  return n / width;
}

async function readDictArray(chunkDir,col){
  const dict=await readJson(chunkDir,dictFileName(col.index));
  if (!Array.isArray(dict)) throw new Error(`Dictionary is not an array: ${dictFileName(col.index)}`);
  return dict;
}

async function rebuildColumnStatFromFiles(chunkDir,col,rowCount){
  const rc=Number(rowCount || 0);
  if (col.type === "number"){
    const buf=await readBuffer(chunkDir,colFileName(col.index,col.type));
    const arr=new Float64Array(buf);
    if (arr.length !== rc) throw new Error(`Number column row count mismatch for ${col.name || col.index}: ${arr.length} !== ${rc}`);
    let nulls=0, min=null, max=null;
    for (let i=0;i<arr.length;i++){
      const v=arr[i];
      if (!Number.isFinite(v)){ nulls++; continue; }
      min = min == null ? v : Math.min(min,v);
      max = max == null ? v : Math.max(max,v);
    }
    return makeColumnStatForMeta({type:"number", nulls, invalidNumbers:0, min, max}, rc);
  }

  const buf=await readBuffer(chunkDir,colFileName(col.index,col.type));
  const ids=new Int32Array(buf);
  if (ids.length !== rc) throw new Error(`String column row count mismatch for ${col.name || col.index}: ${ids.length} !== ${rc}`);
  const dict=await readDictArray(chunkDir,col);
  let nulls=0;
  for (let i=0;i<ids.length;i++){
    const id=ids[i];
    if (id < 0){ nulls++; continue; }
    if (id >= dict.length) throw new Error(`String dictionary id out of range in ${col.name || col.index}: ${id} >= ${dict.length}`);
  }
  return makeColumnStatForMeta({type:"string", nulls, distinct:dict.length}, rc, dict);
}

function isColumnStatUsable(stat,col,rowCount){
  if (!stat) return false;
  if ((stat.type || col.type) !== col.type) return false;
  if (Number(stat.rowCount ?? rowCount) !== Number(rowCount || 0)) return false;
  if (!Number.isFinite(Number(stat.nullCount ?? stat.nulls ?? 0))) return false;
  if (col.type === "number"){
    const nullCount=Number(stat.nullCount ?? stat.nulls ?? 0);
    if (nullCount < Number(rowCount || 0)){
      if (stat.min == null || stat.max == null) return false;
      if (!Number.isFinite(Number(stat.min)) || !Number.isFinite(Number(stat.max))) return false;
    }
  }
  return true;
}

async function validateAndRepairDatasetDir(id,dir,options={}){
  const repair = options.repair !== false;
  const rebuildStats = !!options.rebuildStats;
  const issues=[], warnings=[], repairs=[];
  let manifest, chunks;

  async function persistIntegrity(ok){
    const summary=integritySummary(ok,issues,warnings,repairs);
    if (repair){ try{ await writeJson(dir,"_integrity.json",summary); }catch{} }
    return summary;
  }

  try{ manifest=await readJson(dir,"manifest.json"); }
  catch(e){ issues.push(`manifest.json unreadable: ${issueText(e)}`); return {ok:false,issues,warnings,repairs,integrity:await persistIntegrity(false)}; }

  try{ chunks=await readJson(dir,"chunks.json"); }
  catch(e){ issues.push(`chunks.json unreadable: ${issueText(e)}`); return {ok:false,manifest,issues,warnings,repairs,integrity:await persistIntegrity(false)}; }

  if (!manifest || typeof manifest !== "object") issues.push("manifest.json is not an object");
  if (!Array.isArray(chunks)) issues.push("chunks.json is not an array");
  const columns=Array.isArray(manifest?.columns) ? manifest.columns : [];
  if (!columns.length) issues.push("manifest.columns is empty or missing");
  for (const col of columns){
    if (!Number.isFinite(Number(col.index))) issues.push(`column has invalid index: ${JSON.stringify(col)}`);
    if (col.type !== "number" && col.type !== "string") issues.push(`column has unsupported type: ${col.name || col.index}`);
  }
  if (issues.length) return {ok:false,manifest,chunks:Array.isArray(chunks)?chunks:[],issues,warnings,repairs,integrity:await persistIntegrity(false)};

  let changedManifest=false, changedChunks=false;
  if (manifest.id !== id){ manifest.id=id; changedManifest=true; repairs.push("manifest.id normalized to directory id"); }
  manifest.features=integrityFeatureFlags(manifest.features);
  if (Number(manifest.formatVersion || 0) < 5){ manifest.formatVersion=5; changedManifest=true; repairs.push("manifest.formatVersion upgraded to 5"); }

  const repairedChunks=[];
  let totalRows=0;

  for (let i=0;i<chunks.length;i++){
    let chunkDir;
    try{ chunkDir=await dir.getDirectoryHandle(`chunk_${String(i).padStart(6,"0")}`); }
    catch(e){ issues.push(`missing chunk directory chunk_${String(i).padStart(6,"0")}: ${issueText(e)}`); continue; }

    let diskMeta=null;
    try{ diskMeta=await readJson(chunkDir,"meta.json"); }
    catch(e){ warnings.push(`chunk ${i} meta.json unreadable; reconstructing from chunks.json/files: ${issueText(e)}`); }

    const originalMeta={...(chunks[i] || {}), ...(diskMeta || {})};
    const meta={...originalMeta};
    const inferred=[];
    const dictCache=new Map();

    for (const col of columns){
      try{
        const bytes=await fileByteLength(chunkDir,colFileName(col.index,col.type));
        const rc=rowCountFromBytes(bytes,col.type);
        if (rc == null){ issues.push(`chunk ${i} ${col.name || col.index} has invalid byte length ${bytes}`); continue; }
        inferred.push(rc);
        if (col.type === "string"){
          const dict=await readDictArray(chunkDir,col);
          dictCache.set(col.index,dict);
        }
      }catch(e){
        issues.push(`chunk ${i} column ${col.name || col.index} unreadable: ${issueText(e)}`);
      }
    }
    if (issues.length) continue;

    const uniqueCounts=[...new Set(inferred.map(Number))];
    if (uniqueCounts.length !== 1){
      issues.push(`chunk ${i} column row counts disagree: ${uniqueCounts.join(", ")}`);
      continue;
    }
    const rowCount=uniqueCounts[0];

    if (Number(meta.chunkIndex) !== i){ meta.chunkIndex=i; repairs.push(`chunk ${i} meta.chunkIndex repaired`); }
    if (Number(meta.rowCount || 0) !== rowCount){ meta.rowCount=rowCount; repairs.push(`chunk ${i} rowCount repaired to ${rowCount}`); }

    if (!Array.isArray(meta.stats)) meta.stats=[];
    if (!meta.columnStats || typeof meta.columnStats !== "object" || Array.isArray(meta.columnStats)) meta.columnStats={};

    for (const col of columns){
      const key=String(col.index);
      let raw=meta.columnStats[key] || meta.stats[col.index] || null;
      let stat=normalizeColumnStat(raw,rowCount);
      let mustRebuild=!isColumnStatUsable(stat,col,rowCount);
      if (col.type === "string" && rebuildStats && stat && !stat.lowerHashComplete && (dictCache.get(col.index)?.length || 0) <= 8192) mustRebuild=true;

      if (mustRebuild && rebuildStats){
        stat=await rebuildColumnStatFromFiles(chunkDir,col,rowCount);
        repairs.push(`chunk ${i} column ${col.name || col.index} statistics rebuilt`);
      }

      if (stat && isColumnStatUsable(stat,col,rowCount)){
        meta.columnStats[key]=stat;
      } else if (mustRebuild && !rebuildStats){
        warnings.push(`chunk ${i} column ${col.name || col.index} statistics need rebuild on open`);
      }
    }

    totalRows += rowCount;
    repairedChunks.push(meta);

    const metaChanged = JSON.stringify(meta) !== JSON.stringify(originalMeta);
    if (repair && metaChanged){
      await writeJson(chunkDir,"meta.json",meta);
      changedChunks=true;
    }
  }

  if (issues.length) return {ok:false,manifest,chunks:repairedChunks,issues,warnings,repairs,integrity:await persistIntegrity(false)};

  if (Number(manifest.chunks || 0) !== repairedChunks.length){ manifest.chunks=repairedChunks.length; changedManifest=true; repairs.push(`manifest.chunks repaired to ${repairedChunks.length}`); }
  if (Number(manifest.totalRows || 0) !== totalRows){ manifest.totalRows=totalRows; changedManifest=true; repairs.push(`manifest.totalRows repaired to ${totalRows}`); }
  if (!Number.isFinite(Number(manifest.sourceRows || 0)) || Number(manifest.sourceRows || 0) < totalRows){ manifest.sourceRows=Math.max(totalRows,Number(manifest.sourceRows || 0)); changedManifest=true; repairs.push("manifest.sourceRows normalized"); }

  const summary=integritySummary(true,issues,warnings,repairs);
  manifest.integrity=summary;
  changedManifest=true;

  if (repair){
    if (changedChunks || JSON.stringify(chunks) !== JSON.stringify(repairedChunks)) await writeJson(dir,"chunks.json",repairedChunks);
    if (changedManifest) await writeJson(dir,"manifest.json",manifest);
    await writeJson(dir,"_integrity.json",summary);
  }
  return {ok:true,manifest,chunks:repairedChunks,issues,warnings,repairs,integrity:summary};
}

async function loadValidatedDataset(id,options={}){
  const root=await rootDir();
  const dir=await root.getDirectoryHandle(id);
  const checked=await validateAndRepairDatasetDir(id,dir,{repair:true,rebuildStats:!!options.rebuildStats});
  if (!checked.ok){
    const msg=(checked.issues || []).slice(0,3).join(" / ") || "unknown integrity error";
    throw new Error(`Dataset integrity check failed for ${id}: ${msg}`);
  }
  return {id,dir,manifest:checked.manifest,chunks:checked.chunks,integrity:checked.integrity};
}

async function loadDatasetForWorkerReadOnly(id){
