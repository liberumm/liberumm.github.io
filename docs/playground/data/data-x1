function StoragePanel({ state, dispatch, post }) {
  const selected = state.storage.selectedIds;
  const openSelected = (mode) => {
    if (!selected.length) return dispatch({ type: "runtime/error", message: "保存済みDatasetを選択してください。", payload: {} });
    if (mode === "single") return post("OPFS_LOAD", { id: selected[0] }, { busy: true, label: "Open Dataset" });
    if (selected.length < 2) return dispatch({ type: "runtime/error", message: "複数Datasetを選択してください。", payload: {} });
    if (mode === "virtual") return post("OPFS_OPEN_VIRTUAL", { ids: selected, name: state.settings.virtualName }, { busy: true, label: "Open Virtual" });
    if (mode === "memory") return post("OPFS_OPEN_MEMORY", { ids: selected, name: state.settings.memoryName, maxMemoryMB: state.settings.maxMemoryMB }, { busy: true, label: "Open Memory" });
  };

  const removeSelected = () => {
    if (!selected.length) return dispatch({ type: "runtime/error", message: "削除するDatasetを選択してください。", payload: {} });
    if (!confirm(`${selected.length}件のDatasetを削除します。よろしいですか？`)) return;
    selected.forEach((id) => post("PURGE_SELECTED", { id }, { busy: true, label: "Delete Dataset" }));
  };

  const purgeAll = () => {
    if (!confirm("すべての保存済みDatasetを削除します。元に戻せません。")) return;
    post("PURGE_ALL", {}, { busy: true, label: "Purge All" });
  };

  return (
    <Section
      title="Storage Catalog"
      subtitle="OPFS上のDatasetをCold状態として扱い、必要な時だけActiveへ昇格します。"
      icon={<Storage fontSize="small" />}
      actions={[
        <Button key="list" startIcon={<FolderOpen />} onClick={() => post("OPFS_LIST")}>Refresh</Button>,
        <Button key="estimate" onClick={() => post("OPFS_ESTIMATE")}>Estimate</Button>,
        <Button key="open" variant="contained" onClick={() => openSelected("single")} disabled={!selected.length}>Open</Button>,
        <Button key="virtual" onClick={() => openSelected("virtual")} disabled={selected.length < 2}>Virtual</Button>,
        <Button key="memory" onClick={() => openSelected("memory")} disabled={selected.length < 2}>Memory</Button>,
        <Button key="delete" color="error" startIcon={<Delete />} onClick={removeSelected} disabled={!selected.length}>Delete</Button>,
        <Button key="purge" color="error" onClick={purgeAll}>Purge All</Button>,
      ]}
    >
      <Stack spacing={1}>
        <FieldRow>
          <TextField label="Virtual name" value={state.settings.virtualName} onChange={(e) => dispatch({ type: "settings/update", patch: { virtualName: e.target.value } })} />
          <TextField label="Memory name" value={state.settings.memoryName} onChange={(e) => dispatch({ type: "settings/update", patch: { memoryName: e.target.value } })} />
          <TextField label="Max memory MB" value={state.settings.maxMemoryMB} onChange={(e) => dispatch({ type: "settings/update", patch: { maxMemoryMB: e.target.value } })} />
          <Box sx={{ display: "flex", alignItems: "center" }}><Typography variant="caption">Estimate: {state.storage.estimate ? `${bytes(state.storage.estimate.usage)} / ${bytes(state.storage.estimate.quota)}` : "-"}</Typography></Box>
        </FieldRow>
        <TableContainer sx={{ maxHeight: 520, border: "1px solid", borderColor: "divider", borderRadius: 1 }}>
          <Table size="small" stickyHeader>
            <TableHead>
              <TableRow>
                <TableCell>Select</TableCell><TableCell>Name</TableCell><TableCell>Path</TableCell><TableCell>Rows</TableCell><TableCell>Cols</TableCell><TableCell>Chunks</TableCell><TableCell>Created</TableCell><TableCell>Mode</TableCell>
              </TableRow>
            </TableHead>
            <TableBody>
              {(state.storage.datasets || []).map((d) => (
                <TableRow key={d.id} hover>
                  <TableCell><Checkbox checked={selected.includes(d.id)} onChange={(e) => dispatch({ type: "storage/select", id: d.id, checked: e.target.checked })} /></TableCell>
                  <TableCell>{d.name || d.tableName || d.id}</TableCell>
                  <TableCell>{d.path || `${d.workspace || ""}/${d.collection || ""}/${d.tableName || ""}`}</TableCell>
                  <TableCell>{fmt(d.rows)}</TableCell>
                  <TableCell>{fmt(d.columns)}</TableCell>
                  <TableCell>{fmt(d.chunks)}</TableCell>
                  <TableCell>{d.createdAt ? new Date(d.createdAt).toLocaleString() : "-"}</TableCell>
                  <TableCell>{d.mode || "-"}</TableCell>
                </TableRow>
              ))}
            </TableBody>
          </Table>
        </TableContainer>
      </Stack>
    </Section>
  );
}

