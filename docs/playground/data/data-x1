function buildObservationPlan(queryPlan){
  const predicates=(Array.isArray(queryPlan?.predicates) ? queryPlan.predicates : []).map(compileObservationPredicate).filter(Boolean);
  const filterGroups=(Array.isArray(queryPlan?.filterGroups) ? queryPlan.filterGroups : [])
    .map((g, gi)=>{
      const conditions=(Array.isArray(g?.conditions) ? g.conditions : []).map(compileObservationPredicate).filter(Boolean);
      if (!conditions.length) return null;
      return {id:g?.id || `group_${gi+1}`, mode:String(g?.mode || "any").toLowerCase()==="all" ? "all" : "any", rowLevel:g?.rowLevel !== false, conditions};
    })
    .filter(Boolean);
  const required=new Set(Array.isArray(queryPlan?.requiredColumns) ? queryPlan.requiredColumns : []);
  for (const p of predicates) required.add(p.columnIndex);
  for (const g of filterGroups) for (const p of g.conditions) required.add(p.columnIndex);
  if (queryPlan?.sort) required.add(queryPlan.sort.columnIndex);
  if (queryPlan?.aggregate){
    const a=queryPlan.aggregate;
    for (const idx of [...(a.rowIdx || []), ...(a.colIdx || []), a.timeIdx, a.groupIdx, a.valIdx]){
      const n=Number(idx); if (Number.isFinite(n) && n >= 0) required.add(n);
    }
  }
  return {
    version:OBSERVATION_ENGINE_VERSION,
    sourcePlanVersion:queryPlan?.version || QUERY_PLAN_VERSION,
    name:queryPlan?.name || "query",
    requiredColumns:[...required].filter(i => Number.isFinite(Number(i))).map(Number).sort((a,b)=>a-b),
    predicates,
    filterGroups,
    sort:queryPlan?.sort || null,
    aggregate:queryPlan?.aggregate || null,
    projection:normalizeProjection(queryPlan?.projection || []),
    limit:normalizePlanLimit(queryPlan?.limit),
