const CHUNK_EXECUTION_ENGINE_VERSION = 1;

function executionTaskId(prefix="task"){
  const rand = crypto.getRandomValues(new Uint32Array(1))[0].toString(36);
  return `${prefix}_${Date.now().toString(36)}_${rand}`;
}

function activeChunkCount(){
  return Number(state.manifest?.chunks || state.dataset?.chunks?.length || 0);
}

function normalizePlanLimit(value){
  const n = Number(value);
  return Number.isFinite(n) && n > 0 ? n : Number.POSITIVE_INFINITY;
}

function selectChunksForPlan(plan){
  const total = activeChunkCount();
  const explicit = Array.isArray(plan?.chunks) ? plan.chunks : null;
  if (explicit && explicit.length){
    return [...new Set(explicit.map(Number).filter(i => Number.isFinite(i) && i >= 0 && i < total))].sort((a,b)=>a-b);
  }
  return Array.from({length:total}, (_,i)=>i);
}

function executionProgressText(label, ctx){
  return `${label}... ${ctx.position + 1}/${ctx.totalChunks} / skipped ${fmt(ctx.skippedChunks)} / rows ${fmt(ctx.scanned)} / matches ${fmt(ctx.matched)}`;
}

function sortComparatorForPlan(sortSpec){
  const sortDirection = sortSpec?.direction === "desc" ? "desc" : "asc";
  const dir = sortDirection === "desc" ? -1 : 1;
  const type = sortSpec?.type;
  const collator = type === "number" ? null : new Intl.Collator("ja", {numeric:true, sensitivity:"base"});
  return (a,b)=>{
    if (type === "number") {
      const an = Number(a?.value), bn = Number(b?.value);
      const av = Number.isFinite(an) ? an : (sortDirection === "desc" ? -Infinity : Infinity);
      const bv = Number.isFinite(bn) ? bn : (sortDirection === "desc" ? -Infinity : Infinity);
      return (av - bv) * dir || (Number(a?.rowId || 0) - Number(b?.rowId || 0));
    }
    return collator.compare(String(a?.value ?? ""), String(b?.value ?? "")) * dir || (Number(a?.rowId || 0) - Number(b?.rowId || 0));
  };
}

function sortPlanRows(sortable, sortSpec){
  if (!Array.isArray(sortable) || !sortSpec) return [];
  return sortable.sort(sortComparatorForPlan(sortSpec));
}

function workerYield(){ return new Promise(resolve => setTimeout(resolve, 0)); }

function heapPush(heap, item, cmp){
  heap.push(item);
  let i=heap.length-1;
  while(i>0){
    const p=(i-1)>>1;
    if (cmp(heap[i].item, heap[p].item) >= 0) break;
    [heap[i], heap[p]] = [heap[p], heap[i]];
    i=p;
  }
}

function heapPop(heap, cmp){
  if (!heap.length) return null;
  const top=heap[0];
  const last=heap.pop();
  if (heap.length && last){
    heap[0]=last;
    let i=0;
    for(;;){
      const l=i*2+1, r=l+1;
      let s=i;
      if (l<heap.length && cmp(heap[l].item, heap[s].item) < 0) s=l;
      if (r<heap.length && cmp(heap[r].item, heap[s].item) < 0) s=r;
      if (s===i) break;
      [heap[i], heap[s]] = [heap[s], heap[i]];
      i=s;
    }
  }
  return top;
}

async function sortPlanRowsToRowIds(sortable, sortSpec, limit=Number.POSITIVE_INFINITY, options={}){
  if (!Array.isArray(sortable) || !sortSpec) return [];
  const total=sortable.length;
  const cmp=sortComparatorForPlan(sortSpec);
  const requested=Number.isFinite(limit) ? Math.max(0, Number(limit)) : Number.POSITIVE_INFINITY;
  const takeAll=!Number.isFinite(requested);
  if (!total || requested === 0) return [];
  if (Number.isFinite(requested) && total > requested * 2 && options.topK !== false){
    postProgress(Number(options.progressBase ?? 88), `${options.label || "Global data query"}: Top-K sorting ${fmt(total)} rows -> ${fmt(requested)} rows...`);
    const ids=topKSortRowsToRowIds(sortable, sortSpec, requested);
    postProgress(Math.min(99, Number(options.progressBase ?? 88) + Number(options.progressSpan ?? 10)), `${options.label || "Global data query"}: Top-K row index ready ${fmt(ids.length)} rows`);
    return ids;
  }

  const label = options.label || "Global data query";
  const base = Number(options.progressBase ?? 88);
  const span = Number(options.progressSpan ?? 10);
  const chunkSize = Math.max(25000, Math.min(200000, Number(options.chunkSize || 100000)));
  const runCount = Math.ceil(total / chunkSize);

  postProgress(base, `${label}: sorting ${fmt(total)} rows...`);

  if (runCount <= 1){
    sortable.sort(cmp);
    postProgress(Math.min(99, base + span), `${label}: sorting complete / building row index...`);
    return (takeAll ? sortable : sortable.slice(0, requested)).map(x => x.rowId);
  }

  const runs=[];
  for(let start=0; start<total; start+=chunkSize){
    if (state.cancelled) throw new Error("Cancelled");
    const end=Math.min(total,start+chunkSize);
    const run=sortable.slice(start,end);
    run.sort(cmp);
    runs.push(run);
    const pct = runs.length / runCount;
    postProgress(base + Math.floor(span * 0.55 * pct), `${label}: sorted runs ${fmt(runs.length)}/${fmt(runCount)} / rows ${fmt(end)}/${fmt(total)}`);
    await workerYield();
  }

  const heap=[];
  for(let i=0;i<runs.length;i++){
    if (runs[i].length) heapPush(heap,{runIndex:i,itemIndex:0,item:runs[i][0]},cmp);
  }
  const out=[];
  const target = takeAll ? total : Math.min(total, requested);
  let merged=0;
  while(heap.length && out.length < target){
    if (state.cancelled) throw new Error("Cancelled");
    const top=heapPop(heap,cmp);
    out.push(top.item.rowId);
    merged++;
    const nextIndex=top.itemIndex+1;
    const run=runs[top.runIndex];
    if (nextIndex < run.length) heapPush(heap,{runIndex:top.runIndex,itemIndex:nextIndex,item:run[nextIndex]},cmp);
    if (merged % 100000 === 0){
      const pct = merged / Math.max(1,target);
      postProgress(base + Math.floor(span * (0.55 + 0.45 * pct)), `${label}: merging sorted runs ${fmt(merged)}/${fmt(target)} rows`);
      await workerYield();
    }
  }
  postProgress(Math.min(99, base + span), `${label}: row index ready ${fmt(out.length)} rows`);
  return out;
}


const CHUNK_DISTRIBUTED_AGG_VERSION = 1;

function cloneAgg(a){
  return {
    count:Number(a?.count || 0),
    n:Number(a?.n || 0),
    sum:Number(a?.sum || 0),
    min:a?.min == null ? null : Number(a.min),
    max:a?.max == null ? null : Number(a.max)
  };
}

function mergeAggInto(target, source){
  if (!source) return target;
  target.count += Number(source.count || 0);
  target.n += Number(source.n || 0);
  target.sum += Number(source.sum || 0);
  const smin = source.min == null ? null : Number(source.min);
  const smax = source.max == null ? null : Number(source.max);
  if (Number.isFinite(smin)) target.min = target.min == null ? smin : Math.min(target.min, smin);
  if (Number.isFinite(smax)) target.max = target.max == null ? smax : Math.max(target.max, smax);
  return target;
}

function valuesFromSetLike(value){
  if (!value) return [];
  if (value instanceof Set) return [...value];
  if (Array.isArray(value)) return value;
  if (typeof value.values === "function") return [...value.values()];
  return [];
}

function entriesFromMapLike(value){
  if (!value) return [];
  if (value instanceof Map) return [...value.entries()];
  if (Array.isArray(value)) return value;
  if (typeof value.entries === "function") return [...value.entries()];
  if (typeof value === "object") return Object.entries(value);
  return [];
}

function ensureAggInMap(map, key){
  let a = map.get(key);
  if (!a){ a = makeAgg(); map.set(key, a); }
  return a;
}

function createChunkAggregateMetrics(aggregate){
  if (!aggregate) return {};
  if (aggregate.type === "pivot"){
    return {
      aggregateType:"pivot",
      rowKeys:new Set(),
      colKeys:new Set(),
      cells:new Map(),
      rowTotals:new Map(),
      colTotals:new Map(),
      grand:makeAgg(),
      limitHit:false
    };
  }
  if (aggregate.type === "timeSeries"){
    return {
      aggregateType:"timeSeries",
      states:new Map(),
      timeBucketSet:new Set(),
      invalidTime:0,
      limitHit:false
    };
  }
  return {aggregateType:String(aggregate.type || "unknown")};
}

function applyPivotAggregateRow(metrics, chunk, localRow, aggregate){
  const rowIdx = Array.isArray(aggregate.rowIdx) ? aggregate.rowIdx : [];
  const colIdx = Array.isArray(aggregate.colIdx) ? aggregate.colIdx : [];
  const valIdx = Number(aggregate.valIdx);
  const countMode = !!aggregate.countMode;
  const rk = keyOf(rowIdx.map(i => keyCellValue(valueFromColumn(chunk.columns.get(i), localRow))));
  const ck = keyOf(colIdx.map(i => keyCellValue(valueFromColumn(chunk.columns.get(i), localRow))));
  metrics.rowKeys.add(rk);
  metrics.colKeys.add(ck);
  const v = countMode ? "" : valueFromColumn(chunk.columns.get(valIdx), localRow);
  let rm = metrics.cells.get(rk);
  if (!rm){ rm = new Map(); metrics.cells.set(rk, rm); }
  addAgg(ensureAggInMap(rm, ck), v, countMode);
  addAgg(ensureAggInMap(metrics.rowTotals, rk), v, countMode);
  addAgg(ensureAggInMap(metrics.colTotals, ck), v, countMode);
  addAgg(metrics.grand, v, countMode);
}

function applyTimeSeriesAggregateRow(metrics, chunk, localRow, aggregate){
  const timeIdx = Number(aggregate.timeIdx);
  const groupIdx = Number(aggregate.groupIdx);
  const valIdx = Number(aggregate.valIdx);
  const hasGroup = !!aggregate.hasGroup;
  const countMode = !!aggregate.countMode;
  const bucketLimit = Math.max(1, Number(aggregate.bucketLimit || 5000));
  const bucketKey = cachedTimeBucketFromColumn(chunk, timeIdx, localRow, aggregate.bucket || "month");
  if (!bucketKey){ metrics.invalidTime++; return; }
  if (!metrics.timeBucketSet.has(bucketKey)){
    if (metrics.timeBucketSet.size >= bucketLimit){ metrics.limitHit = true; return; }
    metrics.timeBucketSet.add(bucketKey);
  }
  const groupKey = hasGroup ? keyCellValue(valueFromColumn(chunk.columns.get(groupIdx), localRow)) : "(All)";
  const key = JSON.stringify([bucketKey, groupKey]);
  const v = countMode ? "" : valueFromColumn(chunk.columns.get(valIdx), localRow);
  addAgg(ensureAggInMap(metrics.states, key), v, countMode);
}

function applyAggregateRowToPartial(partial, chunk, localRow, aggregate){
  if (!aggregate || !partial?.metrics) return;
  if (aggregate.type === "pivot") applyPivotAggregateRow(partial.metrics, chunk, localRow, aggregate);
  else if (aggregate.type === "timeSeries") applyTimeSeriesAggregateRow(partial.metrics, chunk, localRow, aggregate);
}

function mergePivotAggregatePartials(partials, {rowLimit, colLimit}={}){
  const rowKeys=[], colKeys=[], rowSet=new Set(), colSet=new Set();
  const cells=new Map(), rowTotals=new Map(), colTotals=new Map(), grand=makeAgg();
  let limitHit=false;
  const safeRowLimit=Math.max(1, Number(rowLimit || 1000000));
  const safeColLimit=Math.max(1, Number(colLimit || 10000));

  function includeRow(key){
    if (rowSet.has(key)) return true;
    if (rowKeys.length >= safeRowLimit){ limitHit=true; return false; }
    rowSet.add(key); rowKeys.push(key); return true;
  }
  function includeCol(key){
    if (colSet.has(key)) return true;
    if (colKeys.length >= safeColLimit){ limitHit=true; return false; }
    colSet.add(key); colKeys.push(key); return true;
  }

  for (const partial of Array.isArray(partials) ? partials : []){
    const m=partial?.metrics || {};
    if (m.limitHit) limitHit=true;
    const cellEntries=entriesFromMapLike(m.cells);
    if (cellEntries.length){
      for (const [rk, rawCols] of cellEntries){
        if (!includeRow(String(rk))) continue;
        for (const [ck, rawAgg] of entriesFromMapLike(rawCols)){
          if (!includeCol(String(ck))) continue;
          const agg=cloneAgg(rawAgg);
          let rm=cells.get(String(rk));
          if (!rm){ rm=new Map(); cells.set(String(rk),rm); }
          mergeAggInto(ensureAggInMap(rm, String(ck)), agg);
          mergeAggInto(ensureAggInMap(rowTotals, String(rk)), agg);
          mergeAggInto(ensureAggInMap(colTotals, String(ck)), agg);
          mergeAggInto(grand, agg);
        }
      }
    } else {
      // Backward-compatible fallback for partials that only contain totals.
      for (const rk of valuesFromSetLike(m.rowKeys)) includeRow(String(rk));
      for (const ck of valuesFromSetLike(m.colKeys)) includeCol(String(ck));
    }
  }

  rowKeys.sort();
  colKeys.sort();
  return {rowKeys, colKeys, cells, rowTotals, colTotals, grand, limitHit};
}

function mergeTimeSeriesAggregatePartials(partials, {bucketLimit}={}){
  const states=new Map();
  const timeBucketSet=new Set();
  const safeBucketLimit=Math.max(1, Number(bucketLimit || 5000));
  let invalidTime=0, limitHit=false;

  for (const partial of Array.isArray(partials) ? partials : []){
    const m=partial?.metrics || {};
    invalidTime += Number(m.invalidTime || 0);
    if (m.limitHit) limitHit=true;
    for (const [key, rawAgg] of entriesFromMapLike(m.states)){
      let bucketKey="", groupKey="";
      try { [bucketKey, groupKey] = JSON.parse(key); } catch { [bucketKey, groupKey] = String(key).split("\u001f"); }
      if (!timeBucketSet.has(bucketKey)){
        if (timeBucketSet.size >= safeBucketLimit){ limitHit=true; continue; }
        timeBucketSet.add(bucketKey);
      }
      mergeAggInto(ensureAggInMap(states, String(key)), cloneAgg(rawAgg));
    }
  }

  return {states, timeBucketSet, invalidTime, limitHit};
}

async function executeChunkExecutionPlan(plan, options={}){
  const taskId = options.taskId || executionTaskId(plan?.name || "query");
  const chunks = selectChunksForPlan(plan);
  const collectRows = !!options.collectRows;
  const collectSort = !!options.collectSort && !!plan?.sort;
  const collectAggregate = !!plan?.aggregate;
  const collectPartials = !!options.collectPartials || collectAggregate;
  const limit = normalizePlanLimit(options.limit ?? plan?.limit);
  const progressLabel = options.progressLabel || plan?.name || "Executing chunks";
  const progressEvery = Math.max(1, Number(options.progressEvery || 5));
  const progress = options.progress !== false;
  const refs = [];
  const sortable = [];
  const partials = [];
  const t0 = now();
  let skippedChunks = 0, scanned = 0, matched = 0, stoppedByLimit = false;

  const totalChunks = chunks.length;
  if (!totalChunks){
    return {
      taskId, engineVersion:CHUNK_EXECUTION_ENGINE_VERSION, chunks, refs, sortable, partials,
      scanned, matched, skippedChunks, capped:false, ms:now()-t0, queryPlan:queryPlanSummary(plan)
    };
  }

  outer:
  for (let position=0; position<chunks.length; position++){
    if (state.cancelled) throw new Error("Cancelled");
    const chunkIndex = chunks[position];
    const ctxBase = () => ({
      taskId, plan, chunkIndex, position, totalChunks, scanned, matched, skippedChunks, refs, sortable, partials
    });

    if (canSkipChunkByQueryPlan(chunkIndex, plan)){
      skippedChunks++;
      if (progress && (position % progressEvery === 0 || position === chunks.length - 1)){
        const ctx=ctxBase();
        post("PROGRESS",{
          value:Math.floor(((position + 1) / totalChunks) * 100),
          text:typeof options.progressText === "function" ? options.progressText(ctx) : executionProgressText(progressLabel, ctx)
        });
      }
      continue;
    }

    const chunk = await readChunkColumns(chunkIndex, plan?.requiredColumns || []);
    const base = chunkBaseRow(chunkIndex);
    const partial = {taskId, chunkIndex, rowStart:base, rowCount:chunk.rowCount, scanned:0, matched:0, refs:[], sortable:[], metrics:createChunkAggregateMetrics(plan?.aggregate)};

    if (typeof options.onChunkStart === "function") await options.onChunkStart({...ctxBase(), chunk, base, partial});

    for (let localRow=0; localRow<chunk.rowCount; localRow++){
      scanned++;
      partial.scanned++;
      if (!rowMatchesQueryPlan(chunk, localRow, plan)) continue;
      matched++;
      partial.matched++;
      const rowId = base + localRow;

      if (collectSort){
        const value = valueFromColumn(chunk.columns.get(plan.sort.columnIndex), localRow);
        const item = {rowId, value};
        sortable.push(item);
        partial.sortable.push(item);
      } else if (collectRows){
        refs.push(rowId);
        partial.refs.push(rowId);
      }

      if (collectAggregate) applyAggregateRowToPartial(partial, chunk, localRow, plan.aggregate);

      if (typeof options.onMatch === "function"){
        const signal = await options.onMatch({...ctxBase(), chunk, base, localRow, rowId, partial});
        if (signal === "stop"){
          stoppedByLimit = true;
          break outer;
        }
      }

      if (!collectSort && collectRows && refs.length >= limit){
        stoppedByLimit = true;
        break outer;
      }
    }

    if (typeof options.onChunkEnd === "function") await options.onChunkEnd({...ctxBase(), chunk, base, partial});
    if (collectPartials) partials.push(partial);

    if (progress && (position % progressEvery === 0 || position === chunks.length - 1)){
      const ctx=ctxBase();
      post("PROGRESS",{
        value:Math.floor(((position + 1) / totalChunks) * 100),
        text:typeof options.progressText === "function" ? options.progressText(ctx) : executionProgressText(progressLabel, ctx)
      });
    }
  }

  return {
    taskId,
    engineVersion:CHUNK_EXECUTION_ENGINE_VERSION,
    chunks,
    refs,
    sortable,
    partials,
    scanned,
    matched,
    skippedChunks,
    capped:stoppedByLimit,
    ms:now()-t0,
    queryPlan:queryPlanSummary(plan)
  };
}


const REMOTE_EXECUTION_ADAPTER_VERSION = 1;

function normalizeRemoteExecutionConfig(config={}){
  const endpoint=String(config.endpoint || "").trim();
  const mode=["off","local-first","remote-first","remote-only"].includes(config.mode) ? config.mode : (config.enabled ? "remote-first" : "off");
  return {
    enabled:!!config.enabled && !!endpoint && mode !== "off",
    endpoint,
    token:String(config.token || ""),
    mode,
    timeoutMs:Math.max(5000, Math.min(15 * 60 * 1000, Number(config.timeoutMs || 120000))),
    lastProbe:config.lastProbe || null
  };
}

function configureRemoteExecution(config={}){
  state.remoteExecution=normalizeRemoteExecutionConfig(config);
  return remoteExecutionStatus();
}

function remoteExecutionStatus(extra={}){
  const cfg=state.remoteExecution || {};
  return {
    remoteExecutionAdapterVersion:REMOTE_EXECUTION_ADAPTER_VERSION,
    enabled:!!cfg.enabled,
    endpoint:cfg.endpoint || "",
    mode:cfg.mode || "off",
    timeoutMs:Number(cfg.timeoutMs || 120000),
    lastProbe:cfg.lastProbe || null,
    ...extra
  };
}

function canUseRemoteExecution(plan, options={}, chunks=[]){
  const cfg=state.remoteExecution || {};
  if (!cfg.enabled || !cfg.endpoint || cfg.mode === "off") return false;
  if (options.remote === false) return false;
  if (activeIsMemory()) return false;
  if (activeIsExternalStorage()) return false;
  if (!Array.isArray(chunks) || !chunks.length) return false;
  if (typeof fetch !== "function" || typeof AbortController === "undefined") return false;
  if (!(options.collectRows || options.collectSort || options.collectPartials || plan?.aggregate)) return false;
  const context=chunkExecutionContextSnapshot();
  // OPFS-backed storage cannot be read by an arbitrary server. The remote endpoint must either
  // understand this context or return {fallback:true}. This adapter keeps the local path intact.
  if (context.mode !== "storage" && context.mode !== "virtual") return false;
  return true;
}

function serializableRemoteExecutionRequest(plan, options={}, chunks=[]){
  return {
    protocol:"quantum-csv-grid.remote-execution.v1",
    adapterVersion:REMOTE_EXECUTION_ADAPTER_VERSION,
    requestId:options.taskId || executionTaskId(`${plan?.name || "query"}_remote`),
    createdAt:new Date().toISOString(),
    context:chunkExecutionContextSnapshot(),
    plan:{...plan,chunks,limit:Number.isFinite(Number(plan?.limit)) ? Number(plan.limit) : null},
    options:{
      collectRows:!!options.collectRows,
      collectSort:!!options.collectSort,
      collectPartials:!!options.collectPartials || !!plan?.aggregate,
      limit:Number.isFinite(Number(options.limit ?? plan?.limit)) ? Number(options.limit ?? plan?.limit) : null,
      progress:false
    }
  };
}

async function fetchJsonWithTimeout(url, payload, {token="", timeoutMs=120000}={}){
  const controller=new AbortController();
  const timer=setTimeout(()=>controller.abort(new Error("Remote execution timeout")), timeoutMs);
  try{
    const res=await fetch(url,{
      method:"POST",
      headers:{
        "content-type":"application/json",
        ...(token ? {"authorization":`Bearer ${token}`} : {})
      },
      body:JSON.stringify(payload),
      signal:controller.signal
    });
    const text=await res.text();
    let data=null;
    try{ data=text ? JSON.parse(text) : null; }catch{ data={raw:text}; }
    if (!res.ok) throw new Error(data?.message || data?.error || `Remote execution HTTP ${res.status}`);
    return data;
  }finally{
    clearTimeout(timer);
  }
}

function normalizeRemoteExecutionResult(plan, options, chunks, response, t0){
  if (!response || response.fallback) throw new Error(response?.message || "Remote executor requested local fallback");
  const result=response.result || response;
  const refs=Array.isArray(result.refs) ? result.refs : [];
  const sortable=Array.isArray(result.sortable) ? result.sortable : [];
  const partials=Array.isArray(result.partials) ? result.partials : [];
  return {
    taskId:result.taskId || response.requestId || options.taskId || executionTaskId(`${plan?.name || "query"}_remote`),
    engineVersion:CHUNK_EXECUTION_ENGINE_VERSION,
    remoteExecutionAdapterVersion:REMOTE_EXECUTION_ADAPTER_VERSION,
    executionMode:"remote-execution",
    remoteEndpoint:state.remoteExecution?.endpoint || "",
    chunks:Array.isArray(result.chunks) ? result.chunks : chunks,
    refs,
    sortable,
    partials,
    scanned:Number(result.scanned || 0),
    matched:Number(result.matched || refs.length || sortable.length || 0),
    skippedChunks:Number(result.skippedChunks || 0),
    capped:!!result.capped,
    ms:Number(result.ms || (now()-t0)),
    queryPlan:{...queryPlanSummary(plan), executionEngine:"remote-v1", remoteExecution:{version:REMOTE_EXECUTION_ADAPTER_VERSION, endpoint:state.remoteExecution?.endpoint || ""}}
  };
}

async function probeRemoteExecution(config={}){
  const merged=normalizeRemoteExecutionConfig({...state.remoteExecution,...config,enabled:true});
  if (!merged.endpoint) throw new Error("Remote execution endpoint is empty");
  const t0=now();
  const response=await fetchJsonWithTimeout(merged.endpoint,{protocol:"quantum-csv-grid.remote-execution.v1",type:"PING",createdAt:new Date().toISOString()},{token:merged.token,timeoutMs:Math.min(merged.timeoutMs,15000)});
  state.remoteExecution={...merged,lastProbe:{ok:true,checkedAt:new Date().toISOString(),ms:Math.round(now()-t0),response}};
  return remoteExecutionStatus({probe:response});
}

async function executeChunkExecutionPlanRemote(plan, options={}, chunks=null){
  const selected=chunks || selectChunksForPlan(plan);
  const cfg=state.remoteExecution || {};
  const t0=now();
  const request=serializableRemoteExecutionRequest(plan, options, selected);
  post("PROGRESS",{value:1,text:`${options.progressLabel || plan?.name || "Executing chunks"} with Remote Execution... chunks ${fmt(selected.length)}`});
  const response=await fetchJsonWithTimeout(cfg.endpoint,request,{token:cfg.token,timeoutMs:cfg.timeoutMs});
  const result=normalizeRemoteExecutionResult(plan,{...options,taskId:request.requestId},selected,response,t0);
  post("PROGRESS",{value:100,text:`Remote Execution complete... chunks ${fmt(selected.length)} / rows ${fmt(result.scanned)} / matches ${fmt(result.matched)}`});
  return result;
}


