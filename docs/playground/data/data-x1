function pivotViewportToTable(viewport) {
  if (!viewport || !Array.isArray(viewport.tiles) || !viewport.tiles.length) return null;
  const rowStart = Number(viewport.rowStart || 0);
  const rowEnd = Number(viewport.rowEnd || rowStart);
  const colStart = Number(viewport.colStart || 0);
  const colEnd = Number(viewport.colEnd || colStart);
  const rowLabels = new Map();
  const colLabels = new Map();
  const cells = new Map();

  for (const tile of viewport.tiles) {
    const tr0 = Number(tile.rowStart || 0);
    const tc0 = Number(tile.colStart || 0);
    (tile.rowLabels || []).forEach((label, i) => rowLabels.set(tr0 + i, label));
    (tile.colLabels || []).forEach((label, i) => colLabels.set(tc0 + i, label));
    (tile.values || []).forEach((row, ri) => {
      (row || []).forEach((value, ci) => cells.set(`${tr0 + ri}:${tc0 + ci}`, value));
    });
  }

  const header = ["Rows"];
  for (let c = colStart; c < colEnd; c++) header.push(colLabels.get(c) ?? `C${c + 1}`);
  const rows = [];
  for (let r = rowStart; r < rowEnd; r++) {
    const row = [rowLabels.get(r) ?? `R${r + 1}`];
    for (let c = colStart; c < colEnd; c++) row.push(cells.get(`${r}:${c}`) ?? "");
    rows.push(row);
  }
  return { header, rows, startRow: rowStart, meta: viewport };
}

