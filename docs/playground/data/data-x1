function observationPlanSummary(oplan){
  return {
    version:oplan?.version || OBSERVATION_ENGINE_VERSION,
    name:oplan?.name || "query",
    requiredColumns:oplan?.requiredColumns || [],
    predicates:(oplan?.predicates || []).map(p=>({columnIndex:p.columnIndex,columnName:p.columnName,op:p.op,type:p.type,compiled:true})),
    filterGroups:(oplan?.filterGroups || []).map(g=>({id:g.id,mode:g.mode,conditions:g.conditions.length})),
    sort:oplan?.sort || null,
    aggregate:oplan?.aggregate ? {type:oplan.aggregate.type, mode:oplan.aggregate.mode || null, countMode:!!oplan.aggregate.countMode} : null,
    bitsetEvaluation:true,
    dictionaryIdMatching:true,
    lazyMaterialization:true,
    topKSort:true
  };
}

function compareCompiledString(raw, p){
  const s=String(raw ?? "");
  const lower=s.toLowerCase();
  const q=p.targetLower;
  if (p.op === "contains") return lower.includes(q);
  if (p.op === "notcontains") return !lower.includes(q);
  if (p.op === "startswith") return lower.startsWith(q);
  if (p.op === "endswith") return lower.endsWith(q);
  if (p.op === "regex") return p.regex ? p.regex.test(s) : false;
  if (p.op === "eq") return lower === q;
  if (p.op === "ne") return lower !== q;
  if (p.op === "gt") return s.localeCompare(p.targetRaw, undefined, {numeric:true, sensitivity:"base"}) > 0;
  if (p.op === "ge") return s.localeCompare(p.targetRaw, undefined, {numeric:true, sensitivity:"base"}) >= 0;
  if (p.op === "lt") return s.localeCompare(p.targetRaw, undefined, {numeric:true, sensitivity:"base"}) < 0;
  if (p.op === "le") return s.localeCompare(p.targetRaw, undefined, {numeric:true, sensitivity:"base"}) <= 0;
  return false;
}

function compareCompiledValue(v, p){
  const isNull = v === "" || v == null || (typeof v === "number" && Number.isNaN(v));
  if (p.op === "isnull") return isNull;
  if (p.op === "notnull") return !isNull;
  if (p.op === "isempty") return isNull || String(v ?? "").trim() === "";
  if (p.op === "notempty") return !isNull && String(v ?? "").trim() !== "";
  if (p.type === "number" && ["eq","ne","gt","ge","lt","le"].includes(p.op)){
    const n=Number(v), t=Number(p.targetNumber);
    if (!Number.isFinite(n) || !Number.isFinite(t)) return false;
    if (p.op === "eq") return n === t;
    if (p.op === "ne") return n !== t;
    if (p.op === "gt") return n > t;
    if (p.op === "ge") return n >= t;
    if (p.op === "lt") return n < t;
    if (p.op === "le") return n <= t;
  }
  return compareCompiledString(v, p);
}

function matchingDictionaryIds(dict, p){
  const matched=new Set();
  const list=Array.isArray(dict) ? dict : [];
  for(let i=0;i<list.length;i++){
    if (compareCompiledValue(list[i] ?? "", p)) matched.add(i);
  }
  return matched;
}

function evaluatePredicateBitset(chunk, predicate){
  const rowCount=Number(chunk?.rowCount || 0);
  if (!predicate?.rowLevel) return makeFullBitset(rowCount);
  const colData=chunk.columns.get(predicate.columnIndex);
  if (!colData) return makeEmptyBitset(rowCount);
  const bs=makeEmptyBitset(rowCount);

  if (colData.type === "number"){
    const arr=colData.data || [];
    for(let r=0;r<rowCount;r++){
      const raw=arr[r];
      const v=Number.isNaN(raw) ? "" : raw;
      if (compareCompiledValue(v, predicate)) bitsetSet(bs,r);
    }
    return bs;
  }

  const ids=colData.ids || [];
  const dict=Array.isArray(colData.dict) ? colData.dict : [];
  const matchedIds=matchingDictionaryIds(dict, predicate);
  const nullMatches=compareCompiledValue("", predicate);
  for(let r=0;r<rowCount;r++){
    const id=ids[r];
    if (id < 0 ? nullMatches : matchedIds.has(id)) bitsetSet(bs,r);
  }
  return bs;
}

function evaluateQueryPlanBitset(chunk, oplan){
  const rowCount=Number(chunk?.rowCount || 0);
  let current=makeFullBitset(rowCount);
  for (const p of oplan.predicates || []){
    bitsetAndInto(current, evaluatePredicateBitsetSurfaceCached(chunk, p));
  }
  for (const g of oplan.filterGroups || []){
    if (g.rowLevel === false) continue;
    const conditions=Array.isArray(g.conditions) ? g.conditions : [];
    if (!conditions.length) continue;
    let groupBits = g.mode === "all" ? makeFullBitset(rowCount) : makeEmptyBitset(rowCount);
    for (const p of conditions){
      const pb=evaluatePredicateBitsetSurfaceCached(chunk, p);
      if (g.mode === "all") bitsetAndInto(groupBits, pb);
      else bitsetOrInto(groupBits, pb);
    }
    bitsetAndInto(current, groupBits);
  }
  return current;
}

function topKSortRowsToRowIds(sortable, sortSpec, limit=Number.POSITIVE_INFINITY){
  if (!Array.isArray(sortable) || !sortSpec) return [];
  const requested=Number.isFinite(Number(limit)) ? Math.max(0, Number(limit)) : Number.POSITIVE_INFINITY;
  const cmp=sortComparatorForPlan(sortSpec);
  if (!sortable.length || requested === 0) return [];
  if (!Number.isFinite(requested) || sortable.length <= requested){
    sortable.sort(cmp);
    return sortable.map(x=>x.rowId);
  }
  const worstCmp=(a,b)=>-cmp(a,b);
  const heap=[];
  for (const item of sortable){
    if (heap.length < requested) heapPush(heap, item, worstCmp);
    else if (cmp(item, heap[0].item) < 0){
      heap[0]={item};
      let i=0;
      for(;;){
        const l=i*2+1, r=l+1;
        let s=i;
        if (l<heap.length && worstCmp(heap[l].item, heap[s].item) < 0) s=l;
        if (r<heap.length && worstCmp(heap[r].item, heap[s].item) < 0) s=r;
        if (s===i) break;
        [heap[i], heap[s]]=[heap[s], heap[i]];
        i=s;
      }
    }
  }
  return heap.map(x=>x.item).sort(cmp).map(x=>x.rowId);
}

function topKAccept(heap, item, sortSpec, limit){
  const requested=Number(limit);
  const cmp=sortComparatorForPlan(sortSpec);
  const worstCmp=(a,b)=>-cmp(a,b);
  if (!Number.isFinite(requested) || requested <= 0) return false;
  if (heap.length < requested){ heapPush(heap,item,worstCmp); return true; }
  if (cmp(item, heap[0].item) < 0){
    heap[0]={item};
    let i=0;
    for(;;){
      const l=i*2+1, r=l+1;
      let s=i;
      if (l<heap.length && worstCmp(heap[l].item, heap[s].item) < 0) s=l;
      if (r<heap.length && worstCmp(heap[r].item, heap[s].item) < 0) s=r;
      if (s===i) break;
      [heap[i], heap[s]]=[heap[s], heap[i]];
      i=s;
    }
    return true;
  }
  return false;
}

function sortTopKHeapToRowIds(heap, sortSpec){
  return (Array.isArray(heap) ? heap.map(x=>x.item) : []).sort(sortComparatorForPlan(sortSpec)).map(x=>x.rowId);
}

function cachedTimeBucketFromColumn(chunk, timeIdx, localRow, bucket){
  const col=chunk?.columns?.get(Number(timeIdx));
  if (!col) return null;
  if (col.type !== "string") return parseTimeBucket(valueFromColumn(col, localRow), bucket);
  const id=col.ids?.[localRow];
  if (id == null || id < 0) return null;
  let byCol=observationTimeBucketCache.get(col);
  if (!byCol){ byCol=new Map(); observationTimeBucketCache.set(col, byCol); }
  const key=`${bucket || "month"}\u001f${id}`;
  if (byCol.has(key)) return byCol.get(key);
  const b=parseTimeBucket(col.dict?.[id] ?? "", bucket);
  byCol.set(key,b);
  return b;
}

function canUseObservationEngine(plan, options={}){
  if (state.observationEngine?.enabled === false) return false;
  if (options.observation === false) return false;
  if (!state.manifest || !state.dataset) return false;
  if (options.parallel === true && options.forceChunkWorkerPool) return false;
  return true;
}

async function executeObservationPlan(plan, options={}){
  const oplan=buildObservationPlan(plan);
  const taskId=options.taskId || executionTaskId(`${oplan.name || "query"}_obs`);
  const chunks=Array.isArray(options.chunks) ? options.chunks : selectChunksForPlan(plan);
  const collectRows=!!options.collectRows;
  const collectSort=!!options.collectSort && !!oplan.sort;
  const collectAggregate=!!oplan.aggregate;
  const collectPartials=!!options.collectPartials || collectAggregate;
  const limit=normalizePlanLimit(options.limit ?? oplan.limit);
  const useTopK=collectSort && Number.isFinite(limit);
  const progressLabel=options.progressLabel || oplan.name || "Observing chunks";
  const progressEvery=Math.max(1, Number(options.progressEvery || 5));
  const progress=options.progress !== false;
  const surfacePlan=buildSurfaceReadPlan(oplan, state.adaptiveKernel?.lastStrategy || {});
  const prefetch=await prefetchSurfaceForPlan(chunks, oplan, state.adaptiveKernel?.lastStrategy || {}).catch(err=>({prefetched:0,error:err?.message || String(err)}));
  const refs=[];
  const sortable=[];
  const topK=[];
  const partials=[];
  const t0=now();
  let skippedChunks=0, scanned=0, matched=0, stoppedByLimit=false;

  for (let position=0; position<chunks.length; position++){
    if (state.cancelled) throw new Error("Cancelled");
    const chunkIndex=chunks[position];
    const ctxBase=()=>({taskId, plan, oplan, chunkIndex, position, totalChunks:chunks.length, scanned, matched, skippedChunks, refs, sortable, partials});

    if (oplan.pushdown && canSkipChunkByQueryPlan(chunkIndex, plan)){
      skippedChunks++;
      if (progress && (position % progressEvery === 0 || position === chunks.length - 1)){
        const ctx=ctxBase();
        post("PROGRESS",{value:Math.floor(((position + 1) / Math.max(1,chunks.length)) * 100), text:typeof options.progressText === "function" ? options.progressText(ctx) : `${progressLabel} / Observation... ${position+1}/${chunks.length} / skipped ${fmt(skippedChunks)} / matches ${fmt(matched)}`});
      }
      continue;
    }

    const chunk=await readChunkColumns(chunkIndex, oplan.requiredColumns, {surfacePlan});
    const base=chunkBaseRow(chunkIndex);
    const bitset=evaluateQueryPlanBitset(chunk, oplan);
    const chunkMatched=countBits(bitset);
    scanned += chunk.rowCount;
    matched += chunkMatched;
    const partial={taskId, chunkIndex, rowStart:base, rowCount:chunk.rowCount, scanned:chunk.rowCount, matched:chunkMatched, refs:[], sortable:[], metrics:createChunkAggregateMetrics(oplan.aggregate)};

    if (typeof options.onChunkStart === "function") await options.onChunkStart({...ctxBase(), chunk, base, partial, bitset});

    for(let wordIndex=0; wordIndex<bitset.length; wordIndex++){
      let word=bitset[wordIndex] >>> 0;
      while(word){
        const bit = 31 - Math.clz32(word & -word);
        const localRow=wordIndex * 32 + bit;
        if (localRow >= chunk.rowCount) break;
        const rowId=base + localRow;

        if (collectSort){
          const value=valueFromColumn(chunk.columns.get(oplan.sort.columnIndex), localRow);
          const item={rowId,value};
          if (useTopK) topKAccept(topK,item,oplan.sort,limit);
          else { sortable.push(item); partial.sortable.push(item); }
        } else if (collectRows){
          refs.push(rowId);
          partial.refs.push(rowId);
        }

        if (collectAggregate) applyAggregateRowToPartial(partial, chunk, localRow, oplan.aggregate);

        if (typeof options.onMatch === "function"){
          const signal=await options.onMatch({...ctxBase(), chunk, base, localRow, rowId, partial, bitset});
          if (signal === "stop"){ stoppedByLimit=true; break; }
        }
        if (!collectSort && collectRows && refs.length >= limit){ stoppedByLimit=true; break; }
        word &= word - 1;
      }
      if (stoppedByLimit) break;
    }

    if (typeof options.onChunkEnd === "function") await options.onChunkEnd({...ctxBase(), chunk, base, partial, bitset});
    if (collectPartials) partials.push(partial);

    if (progress && (position % progressEvery === 0 || position === chunks.length - 1)){
      const found=collectSort ? (useTopK ? topK.length : sortable.length) : refs.length;
      post("PROGRESS",{value:Math.floor(((position + 1) / Math.max(1,chunks.length)) * 100), text:`${progressLabel} / Observation... ${position+1}/${chunks.length} / skipped ${fmt(skippedChunks)} / rows ${fmt(scanned)} / matches ${fmt(matched)} / kept ${fmt(found)}`});
    }
    if (stoppedByLimit) break;
    if (position % 4 === 0) await workerYield();
  }

  if (useTopK){
    for (const rowId of sortTopKHeapToRowIds(topK, oplan.sort)) sortable.push({rowId});
  }

  return {
    taskId,
    engineVersion:CHUNK_EXECUTION_ENGINE_VERSION,
    observationEngineVersion:OBSERVATION_ENGINE_VERSION,
    executionMode:"observation-v1",
    chunks,
    refs,
    sortable,
    partials,
    scanned,
    matched,
    skippedChunks,
    capped:stoppedByLimit || (!collectSort && collectRows && Number.isFinite(limit) && matched > refs.length),
    ms:now()-t0,
    hybridSurface:hybridSurfaceStatus(),
    surfaceReadPlan:surfacePlan,
    prefetch,
    queryPlan:{...queryPlanSummary(plan), executionEngine:"observation-v1", observationPlan:observationPlanSummary(oplan), hybridSurface:hybridSurfaceStatus(), surfaceReadPlan:surfacePlan, prefetch}
  };
}

async function runPerfBench({sampleChunks=8, searchColumnIndex=null, searchValue=""}={}){
  if (!state.manifest || !state.dataset) throw new Error("No active dataset for PERF_BENCH");
  const t0=now();
  const chunks=selectChunksForPlan({chunks:Array.from({length:Math.min(activeChunkCount(), Math.max(1, Number(sampleChunks || 8)))},(_,i)=>i)});
  const firstCol=state.manifest.columns[Number.isFinite(Number(searchColumnIndex)) ? Number(searchColumnIndex) : 0];
  const searchCol=firstCol?.index ?? 0;
  const plan=buildQueryPlan({
    name:"perfBenchSearch",
    predicates:[{columnIndex:searchCol, op:String(searchValue || "") ? "contains" : "notnull", value:String(searchValue || ""), source:"perfBench"}],
    projection:[searchCol],
    limit:Number.POSITIVE_INFINITY,
    pushdown:true
  });
  const scanStart=now();
  let rows=0, bytes=0;
  for (const c of chunks){
    const chunk=await readChunkColumns(c,[searchCol]);
    rows += Number(chunk.rowCount || 0);
    const col=chunk.columns.get(searchCol);
    bytes += estimateColumnDataBytes(col);
  }
  const scanMs=now()-scanStart;
  const obsStart=now();
  const exec=await executeHyperTensorAdaptivePlan({...plan,chunks},{collectRows:true,limit:100000,progress:false});
  const obsMs=now()-obsStart;
  const result={
    observationEngineVersion:OBSERVATION_ENGINE_VERSION,
    chunks:chunks.length,
    rows,
    approxReadMB:Math.round(bytes/1024/1024*100)/100,
    scanRowsPerSec:Math.round(rows/Math.max(0.001,scanMs/1000)),
    observationRowsPerSec:Math.round(exec.scanned/Math.max(0.001,obsMs/1000)),
    matches:exec.refs.length,
    cache:chunkCacheSnapshot(),
    ms:now()-t0,
    checkedAt:new Date().toISOString()
  };
  state.observationEngine={...(state.observationEngine || {}),lastBench:result};
  return result;
}



/* =========================================================
 * HYPERTENSOR ADAPTIVE KERNEL v2
 * ---------------------------------------------------------
 * A higher-dimensional execution layer over Observation Engine v1.
 * It treats CSV datasets as sparse observation spaces:
 *   Data  = state space
 *   Query = operator graph
 *   Result = measured projection
 *
 * Practical rule: the abstraction never replaces the low-level kernel.
 * It selects strategy, annotates plans, caches hot row-id results, then
 * delegates physical work to the Observation Engine / classic engine.
 * ========================================================= */

const HYPERTENSOR_KERNEL_VERSION = 2;
const ADAPTIVE_EXECUTION_KERNEL_VERSION = 2;
const adaptiveRowIdResultCache = new Map();
const ADAPTIVE_ROW_CACHE_MAX_ENTRIES = 24;
const ADAPTIVE_ROW_CACHE_MAX_IDS = 2_000_000;

function adaptiveStatus(extra={}){
  const cfg=state.adaptiveKernel || {};
  return {
    adaptiveExecutionKernelVersion:ADAPTIVE_EXECUTION_KERNEL_VERSION,
    hyperTensorKernelVersion:HYPERTENSOR_KERNEL_VERSION,
    enabled:cfg.enabled !== false,
    mode:cfg.mode || "adaptive",
    cache:cfg.cache !== false,
    selfTuning:cfg.selfTuning !== false,
    cacheEntries:adaptiveRowIdResultCache.size,
    lastStrategy:cfg.lastStrategy || null,
    lastBench:cfg.lastBench || null,
    executionPlane:executionPlaneStatus ? executionPlaneStatus({surface:null}) : null,
    surface:hybridSurfaceStatus ? hybridSurfaceStatus() : null,
    ...extra
  };
}

function configureAdaptiveKernel(config={}){
  const prev=state.adaptiveKernel || {};
  state.adaptiveKernel={
    ...prev,
    enabled:config.enabled !== false,
    version:ADAPTIVE_EXECUTION_KERNEL_VERSION,
    mode:["classic","observation","adaptive","hypertensor"].includes(config.mode) ? config.mode : (prev.mode || "adaptive"),
    cache:config.cache !== false,
    selfTuning:config.selfTuning !== false,
    lastStrategy:prev.lastStrategy || null,
    lastBench:prev.lastBench || null
  };
  return adaptiveStatus();
}

function clearAdaptiveCaches(){
  adaptiveRowIdResultCache.clear();
  return adaptiveStatus({cacheCleared:true});
}

function stableStringify(value){
  const seen=new WeakSet();
  return JSON.stringify(value, function(k,v){
    if (v && typeof v === "object"){
      if (seen.has(v)) return "[Circular]";
      seen.add(v);
      if (!Array.isArray(v)){
        const out={};
        for (const key of Object.keys(v).sort()) out[key]=v[key];
        return out;
      }
    }
    if (typeof v === "number" && !Number.isFinite(v)) return String(v);
    return v;
  });
}

function hashText32(text){
  let h=2166136261;
  const s=String(text ?? "");
  for(let i=0;i<s.length;i++){ h ^= s.charCodeAt(i); h=Math.imul(h,16777619); }
  return (h>>>0).toString(36);
}

function adaptivePlanHash(plan, options={}){
  return hashText32(stableStringify({
    dataset:state.manifest?.id || state.dataset?.id || "active",
    totalRows:state.manifest?.totalRows || 0,
    plan:{
      name:plan?.name,
      predicates:plan?.predicates || [],
      filterGroups:plan?.filterGroups || [],
      projection:plan?.projection || [],
      sort:plan?.sort || null,
      aggregate:plan?.aggregate || null,
      limit:Number.isFinite(Number(plan?.limit)) ? Number(plan.limit) : "Infinity",
      pushdown:plan?.pushdown !== false,
      chunks:Array.isArray(plan?.chunks) ? plan.chunks : null
    },
    options:{
      collectRows:!!options.collectRows,
      collectSort:!!options.collectSort,
      collectPartials:!!options.collectPartials,
      limit:Number.isFinite(Number(options.limit ?? plan?.limit)) ? Number(options.limit ?? plan?.limit) : "Infinity"
    }
  }));
}

function rememberAdaptiveCache(key, value){
  if (!key || !value) return;
  adaptiveRowIdResultCache.set(key,{...value,lastUsed:now(),hits:0});
  while(adaptiveRowIdResultCache.size > ADAPTIVE_ROW_CACHE_MAX_ENTRIES){
    let oldestKey=null, oldest=Infinity;
    for (const [k,v] of adaptiveRowIdResultCache.entries()){
      const t=Number(v.lastUsed || 0);
      if (t < oldest){ oldest=t; oldestKey=k; }
    }
    if (!oldestKey) break;
    adaptiveRowIdResultCache.delete(oldestKey);
  }
}

function getAdaptiveCache(key){
  const hit=adaptiveRowIdResultCache.get(key);
  if (!hit) return null;
  hit.lastUsed=now();
  hit.hits=Number(hit.hits || 0)+1;
  return hit;
}

function buildOperatorGraph(queryPlan){
  const operators=[];
  for (const p of queryPlan?.predicates || []) operators.push({kind:"filter", mode:"and", predicate:p});
  for (const g of queryPlan?.filterGroups || []) operators.push({kind:"filterGroup", mode:g.mode || "any", conditions:g.conditions || []});
  if (queryPlan?.aggregate) operators.push({kind:"aggregate", aggregate:queryPlan.aggregate});
  if (queryPlan?.sort) operators.push({kind:"sort", sort:queryPlan.sort});
  operators.push({kind:"measure", projection:queryPlan?.projection || [], limit:normalizePlanLimit(queryPlan?.limit)});
  const graph={
    version:HYPERTENSOR_KERNEL_VERSION,
    source:state.manifest?.id || state.dataset?.id || "activeDataset",
    axes:["chunk","row","column","dictId","timeBucket","graphNode","graphEdge","queryState","storageTier","executionLane","distributionShard"],
    sparse:true,
    operators,
    measurement:{projection:queryPlan?.projection || [], limit:normalizePlanLimit(queryPlan?.limit), sort:queryPlan?.sort || null},
    surfaceReadPlan:buildSurfaceReadPlan(buildObservationPlan(queryPlan || {})),
    createdAt:new Date().toISOString()
  };
  state.hyperTensor={...(state.hyperTensor || {}),enabled:true,version:HYPERTENSOR_KERNEL_VERSION,lastPlan:graph};
  return graph;
}

function operatorGraphSummary(graph){
  return {
    version:graph?.version || HYPERTENSOR_KERNEL_VERSION,
    source:graph?.source || "activeDataset",
    axes:graph?.axes || [],
    sparse:!!graph?.sparse,
    operators:(graph?.operators || []).map(o=>({kind:o.kind, mode:o.mode || null, columnIndex:o.predicate?.columnIndex ?? null, aggregate:o.aggregate?.type || null})),
    measurement:graph?.measurement || null,
    surfaceReadPlan:graph?.surfaceReadPlan || null
  };
}

function estimateColumnAcrossChunks(columnIndex){
  const chunks=state.dataset?.chunks || [];
  let rowCount=0, nullCount=0, distinctSum=0, statCount=0, min=null, max=null, lowerHashComplete=true;
  for (let i=0;i<chunks.length;i++){
    const stat=columnStatFromChunkMeta(chunks[i], columnIndex);
    if (!stat) continue;
    statCount++;
    rowCount += Number(stat.rowCount || chunks[i]?.rowCount || 0);
    nullCount += Number(stat.nullCount || 0);
    if (Number.isFinite(Number(stat.distinctCount))) distinctSum += Number(stat.distinctCount);
    if (stat.type === "number"){
      const smin=stat.min == null ? null : Number(stat.min);
      const smax=stat.max == null ? null : Number(stat.max);
      if (Number.isFinite(smin)) min = min == null ? smin : Math.min(min,smin);
      if (Number.isFinite(smax)) max = max == null ? smax : Math.max(max,smax);
    }
    if (stat.type !== "string" || !stat.lowerHashComplete) lowerHashComplete=false;
  }
  const manifestRows=Number(state.manifest?.totalRows || rowCount || 0);
  const estimatedDistinct=statCount ? Math.max(1, Math.round(distinctSum / Math.max(1, statCount))) : 0;
  return {columnIndex,rowCount:rowCount || manifestRows,nullCount,nonNullCount:Math.max(0,(rowCount || manifestRows)-nullCount),estimatedDistinct,min,max,lowerHashComplete,statCount};
}

function estimatePredicateCost(predicate){
  const col=state.manifest?.columns?.[Number(predicate?.columnIndex)];
  const stats=estimateColumnAcrossChunks(Number(predicate?.columnIndex));
  const rows=Math.max(1, Number(stats.rowCount || state.manifest?.totalRows || 1));
  let selectivity=1;
  if (!col) selectivity=1;
  else if (predicate.op === "isnull") selectivity=Math.min(1, stats.nullCount / rows);
  else if (predicate.op === "notnull") selectivity=Math.min(1, stats.nonNullCount / rows);
  else if (col.type === "number" && ["eq","gt","ge","lt","le"].includes(predicate.op)){
    const t=Number(predicate.value);
    if (predicate.op === "eq") selectivity=stats.estimatedDistinct ? 1 / stats.estimatedDistinct : 0.05;
    else if (Number.isFinite(t) && Number.isFinite(Number(stats.min)) && Number.isFinite(Number(stats.max)) && Number(stats.max) !== Number(stats.min)){
      const min=Number(stats.min), max=Number(stats.max);
      if (predicate.op === "gt" || predicate.op === "ge") selectivity=Math.max(0,Math.min(1,(max-t)/(max-min)));
      if (predicate.op === "lt" || predicate.op === "le") selectivity=Math.max(0,Math.min(1,(t-min)/(max-min)));
    } else selectivity=0.5;
  } else if (col.type === "string" && predicate.op === "eq") selectivity=stats.estimatedDistinct ? 1 / stats.estimatedDistinct : 0.05;
  else if (col.type === "string" && ["contains","startswith","endswith","regex"].includes(predicate.op)) selectivity=0.2;
  else if (predicate.op === "notcontains" || predicate.op === "ne") selectivity=0.8;
  const estimatedRows=Math.max(0, Math.round(rows * selectivity));
  const dictionaryCost=col?.type === "string" ? Math.max(1, stats.estimatedDistinct || 1) : Infinity;
  const scanCost=rows;
  const bitsetCost=Math.ceil(rows / 32);
  const indexCost=(col?.type === "string" && predicate.op === "eq" && stats.estimatedDistinct > 1 && stats.estimatedDistinct <= 8192) ? Math.log2(stats.estimatedDistinct + 1) + estimatedRows : Infinity;
  let preferred="compiled-scan";
  if (indexCost < scanCost * 0.35) preferred="dictionary-index";
  else if (dictionaryCost < scanCost * 0.25) preferred="dictionary";
  else if (bitsetCost < scanCost * 0.75) preferred="bitset";
  return {columnIndex:Number(predicate?.columnIndex),columnName:col?.name || "",type:col?.type || "unknown",op:predicate?.op,selectivity,estimatedRows,dictionaryCost,scanCost,bitsetCost,indexCost,preferred,stats};
}

function estimatePlanCost(queryPlan, oplan){
  const predicates=[...(oplan?.predicates || [])];
  for (const g of oplan?.filterGroups || []) for (const p of g.conditions || []) predicates.push(p);
  const predicateCosts=predicates.map(estimatePredicateCost);
  const totalRows=Number(state.manifest?.totalRows || 0);
  let estimatedRows=totalRows;
  for (const pc of predicateCosts) estimatedRows=Math.max(0, Math.round(estimatedRows * Math.max(0.000001, Math.min(1, pc.selectivity))));
  const limit=normalizePlanLimit(queryPlan?.limit);
  return {totalRows,estimatedRows,predicateCosts,limit,hasSort:!!queryPlan?.sort,hasAggregate:!!queryPlan?.aggregate,chunkCount:activeChunkCount()};
}

function chooseAdaptiveStrategy(queryPlan, oplan, cost, options={}){
  const cfg=state.adaptiveKernel || {};
  const mode=cfg.mode || "adaptive";
  const limit=normalizePlanLimit(options.limit ?? queryPlan?.limit);
  const predicatePreferred=(cost?.predicateCosts || []).map(x=>x.preferred);
  const hasLowCardinalityString=(cost?.predicateCosts || []).some(x=>x.type === "string" && x.stats?.estimatedDistinct > 0 && x.stats.estimatedDistinct <= 8192);
  const hasManyPredicates=(oplan?.predicates?.length || 0) + (oplan?.filterGroups || []).reduce((a,g)=>a+(g.conditions?.length || 0),0) >= 2;
  let predicateMode="compiled-scan";
  if (predicatePreferred.includes("dictionary-index")) predicateMode="dictionary-index";
  else if (hasLowCardinalityString) predicateMode="dictionary";
  else if (hasManyPredicates) predicateMode="bitset";
  let sortMode="none";
  if (queryPlan?.sort) sortMode=Number.isFinite(limit) ? "top-k" : "chunk-sort-merge";
  let aggregateMode="none";
  if (queryPlan?.aggregate?.type === "pivot") aggregateMode="dictionary-aware-pivot";
  else if (queryPlan?.aggregate?.type === "timeSeries") aggregateMode="time-bucket-cache";
  else if (queryPlan?.aggregate) aggregateMode="distributed-reduce";
  const materializeMode=(options.collectRows || options.collectSort) ? "lazy" : "none";
  const engineMode=mode === "classic" ? "classic" : mode === "observation" ? "observation" : "hypertensor-adaptive";
  return {
    version:ADAPTIVE_EXECUTION_KERNEL_VERSION,
    engineMode,
    predicateMode,
    sortMode,
    aggregateMode,
    materializeMode,
    cacheMode:cfg.cache === false ? "off" : "hot-rowid-cache",
    surfaceMode:"hybrid-surface-bus-v1",
    scaleReady:true,
    estimatedRows:cost?.estimatedRows || 0,
    totalRows:cost?.totalRows || 0,
    reason:[
      hasLowCardinalityString ? "low-cardinality string columns" : null,
      hasManyPredicates ? "multi-predicate bitset composition" : null,
      queryPlan?.sort && Number.isFinite(limit) ? "limited sorted query uses Top-K" : null,
      queryPlan?.aggregate?.type === "timeSeries" ? "time bucket cache" : null,
      queryPlan?.aggregate?.type === "pivot" ? "dictionary-aware aggregate" : null
    ].filter(Boolean)
  };
}

function canUseAdaptiveKernel(plan, options={}){
  const cfg=state.adaptiveKernel || {};
  if (cfg.enabled === false) return false;
  if (options.adaptive === false) return false;
  if (!canUseObservationEngine(plan, options)) return false;
  return true;
}

function canUseAdaptiveRowIdCache(plan, options={}){
  const cfg=state.adaptiveKernel || {};
  if (cfg.cache === false) return false;
  if (!options.collectRows || options.collectSort || options.collectPartials || plan?.aggregate) return false;
  if (typeof options.onMatch === "function" || typeof options.onChunkStart === "function" || typeof options.onChunkEnd === "function") return false;
  const limit=normalizePlanLimit(options.limit ?? plan?.limit);
  return Number.isFinite(limit) && limit <= ADAPTIVE_ROW_CACHE_MAX_IDS;
}

async function executeHyperTensorAdaptivePlan(plan, options={}){
  const cfg=state.adaptiveKernel || {};
  if (cfg.mode === "classic") return await executeChunkExecutionPlan(plan,{...options,observation:false,adaptive:false});
  const oplan=buildObservationPlan(plan);
  const operatorGraph=buildOperatorGraph(plan);
  const cost=estimatePlanCost(plan, oplan);
  let strategy=chooseAdaptiveStrategy(plan, oplan, cost, options);
  const plane=chooseExecutionPlane(plan, options, strategy, cost);
  const surfacePlan=buildSurfaceReadPlan(oplan,strategy);
  strategy={...strategy,executionPlane:plane,surfaceReadPlan:surfacePlan};
  state.adaptiveKernel={...(state.adaptiveKernel || {}),lastStrategy:strategy};

  const chunks=Array.isArray(options.chunks) ? options.chunks : selectChunksForPlan(plan);
  const remoteCfg=state.remoteExecution || {};
  if (plane.mode === "scale-out-remote"){
    try{
      hybridSurfaceRuntime.metrics.scaleOutDispatches++;
      const remoteExec=await executeChunkExecutionPlanRemote(plan, options, chunks);
      remoteExec.adaptiveExecutionKernelVersion=ADAPTIVE_EXECUTION_KERNEL_VERSION;
      remoteExec.hyperTensorKernelVersion=HYPERTENSOR_KERNEL_VERSION;
      remoteExec.executionMode="hypertensor-adaptive-v2-remote-scaleout";
      remoteExec.adaptiveStrategy=strategy;
      remoteExec.operatorGraph=operatorGraphSummary(operatorGraph);
      remoteExec.costModel=cost;
      return decorateExecutionWithPlane(remoteExec, plane, surfacePlan);
    }catch(err){
      if (remoteCfg.mode === "remote-only") throw err;
      post("PROGRESS",{value:0,text:`Scale-out remote fallback: ${err?.message || err}`});
    }
  }

  if (plane.mode === "scale-up-worker-pool"){
    try{
      hybridSurfaceRuntime.metrics.scaleUpDispatches++;
      const poolExec=await executeChunkExecutionPlanLocalMaybeParallel(plan,{...options,adaptive:false,observation:false,parallel:true});
      poolExec.adaptiveExecutionKernelVersion=ADAPTIVE_EXECUTION_KERNEL_VERSION;
      poolExec.hyperTensorKernelVersion=HYPERTENSOR_KERNEL_VERSION;
      poolExec.executionMode=poolExec.executionMode === "worker-pool" ? "hypertensor-adaptive-v2-local-scaleup" : poolExec.executionMode;
      poolExec.adaptiveStrategy=strategy;
      poolExec.operatorGraph=operatorGraphSummary(operatorGraph);
      poolExec.costModel=cost;
      hybridSurfaceRuntime.metrics.distributedDispatches++;
      return decorateExecutionWithPlane(poolExec, plane, surfacePlan);
    }catch(err){
      post("PROGRESS",{value:0,text:`Scale-up worker pool fallback: ${err?.message || err}`});
    }
  }

  const cacheable=canUseAdaptiveRowIdCache(plan, options);
  const cacheKey=cacheable ? adaptivePlanHash(plan, options) : null;
  const cached=cacheKey ? getAdaptiveCache(cacheKey) : null;
  if (cached){
    const exec={
      taskId:executionTaskId(`${plan?.name || "query"}_adaptive_cache`),
      engineVersion:CHUNK_EXECUTION_ENGINE_VERSION,
      observationEngineVersion:OBSERVATION_ENGINE_VERSION,
      adaptiveExecutionKernelVersion:ADAPTIVE_EXECUTION_KERNEL_VERSION,
      hyperTensorKernelVersion:HYPERTENSOR_KERNEL_VERSION,
      executionMode:"hypertensor-adaptive-v2-cache",
      chunks:selectChunksForPlan(plan),
      refs:[...cached.refs],
      sortable:[],
      partials:[],
      scanned:0,
      matched:cached.refs.length,
      skippedChunks:0,
      capped:!!cached.capped,
      ms:0,
      cacheHit:true,
      queryPlan:{...queryPlanSummary(plan),executionEngine:"hypertensor-adaptive-v2-cache",operatorGraph:operatorGraphSummary(operatorGraph),adaptiveStrategy:strategy,costModel:cost}
    };
    return decorateExecutionWithPlane(exec, plane, surfacePlan);
  }

  const exec=await executeObservationPlan(plan, {...options,surfacePlan});
  exec.adaptiveExecutionKernelVersion=ADAPTIVE_EXECUTION_KERNEL_VERSION;
  exec.hyperTensorKernelVersion=HYPERTENSOR_KERNEL_VERSION;
  exec.executionMode=strategy.engineMode === "observation" ? "observation-v1" : "hypertensor-adaptive-v2";
  exec.adaptiveStrategy=strategy;
  exec.operatorGraph=operatorGraphSummary(operatorGraph);
  exec.costModel=cost;
  exec.queryPlan={...(exec.queryPlan || queryPlanSummary(plan)),executionEngine:exec.executionMode,operatorGraph:exec.operatorGraph,adaptiveStrategy:strategy,costModel:cost};
  decorateExecutionWithPlane(exec, plane, surfacePlan);

  if (cacheKey && Array.isArray(exec.refs)) rememberAdaptiveCache(cacheKey,{refs:[...exec.refs],capped:!!exec.capped,createdAt:new Date().toISOString(),strategy});
  return exec;
}

async function runAdaptivePerfBench(args={}){
