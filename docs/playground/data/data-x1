  const validateMerge = () => {
    if (files.length < 2) return dispatch({ type: "runtime/error", message: "Merge validationには2つ以上のCSVが必要です。", payload: {} });
    withBusy("VALIDATE_MERGE", { ...commandBase(state), files }, "Validate Merge");
