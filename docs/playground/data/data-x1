      rowFields: state.pivot.rowFields.map(Number),
      columnFields: state.pivot.columnFields.map(Number),
      valueField: Number(state.pivot.valueField),
      aggregation: state.pivot.aggregation,
      maxRows: state.pivot.maxRows,
      maxCols: state.pivot.maxCols,
    }, { busy: true, label: "Build Pivot" });
