async function openVirtualDatasetForWorkerReadOnly(ids, name){
  clearChunkCache();
  const list=(Array.isArray(ids) ? ids : []).filter(Boolean);
  if (list.length < 2) throw new Error("Virtual worker pool requires at least two saved tables");
  const sources=[];
  for (const id of list) sources.push(await loadDatasetForWorkerReadOnly(id));
  const base=sources[0].manifest;
  const baseSig=schemaFullSignatureFromColumns(base.columns);
  for (const item of sources.slice(1)){
    const sig=schemaFullSignatureFromColumns(item.manifest.columns);
    if (sig !== baseSig) throw new Error(`Virtual worker pool blocked: ${item.manifest.name || item.id} has a different column name/type layout`);
  }

  let rowOffset=0;
  const globalChunks=[];
  const virtualSources=sources.map((item, sourceIndex)=>{
    const src={id:item.id,dir:item.dir,manifest:item.manifest,chunks:item.chunks,rowOffset,rows:Number(item.manifest.totalRows || 0)};
    for (let c=0; c<item.chunks.length; c++){
      const rowCount=Number(item.chunks[c]?.rowCount || 0);
      globalChunks.push({sourceIndex, sourceChunkIndex:c, rowStart:rowOffset, rowEnd:rowOffset + rowCount, rowCount, stats:item.chunks[c]?.stats, columnStats:item.chunks[c]?.columnStats, indexVersion:item.chunks[c]?.indexVersion});
      rowOffset += rowCount;
    }
    return src;
  });

  const tableName=cleanMetaValue(name || `virtual_${list.length}_tables`, `virtual_${list.length}_tables`);
  const manifest={
    ...base,
    id:`virtual:${list.join("+")}`,
    name:tableName,
    storageWorkspace:"Virtual",
    storageCollection:"Cross Workspace",
    tableName,
    storagePath:`Virtual / Cross Workspace / ${tableName}`,
    originalFileName:sources.map(x=>x.manifest.name || x.id).join(" + "),
    sourceDatasets:sources.map(x=>({id:x.id,workspace:manifestWorkspace(x.manifest),collection:manifestCollection(x.manifest),tableName:manifestTableName(x.manifest),name:x.manifest.name,rows:x.manifest.totalRows,chunks:x.manifest.chunks,createdAt:x.manifest.createdAt})),
    createdAt:new Date().toISOString(),
    mode:"virtual-dataset",
    totalRows:rowOffset,
    sourceRows:sources.reduce((a,x)=>a+Number(x.manifest.sourceRows || x.manifest.totalRows || 0),0),
    chunks:globalChunks.length,
    fileSize:sources.reduce((a,x)=>a+Number(x.manifest.fileSize || 0),0)
  };
  state.virtual={sources:virtualSources, globalChunks};
  state.memory=null;
  state.dir=null;
  state.manifest=manifest;
  state.dataset={id:manifest.id,manifest,chunks:globalChunks};
}

function colFileName(index, type){ return `col_${String(index).padStart(4,"0")}.${type === "number" ? "f64" : "i32"}.bin`; }
function dictFileName(index){ return `col_${String(index).padStart(4,"0")}.dict.json`; }


function hashString32(value){
  // FNV-1a 32-bit. Used only as a compact membership index for exact string equality skips.
  let h = 2166136261;
  const s = String(value ?? "").toLowerCase();
  for (let i=0;i<s.length;i++){
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}

function makeColumnStatForMeta(stat, rowCount, stringValues){
  const nullCount = Number(stat?.nulls ?? stat?.nullCount ?? 0);
  const base={
    type:stat?.type || "string",
    rowCount:Number(rowCount || 0),
    nullCount,
    nonNullCount:Math.max(0, Number(rowCount || 0) - nullCount),
    changedCells:Number(stat?.changedCells || 0)
  };
  if (base.type === "number"){
    return {
      ...base,
      invalidNumbers:Number(stat?.invalidNumbers || 0),
      min:stat?.min == null ? null : Number(stat.min),
      max:stat?.max == null ? null : Number(stat.max)
    };
  }
  const distinctCount = Array.isArray(stringValues) ? stringValues.length : Number(stat?.distinct ?? stat?.distinctCount ?? 0);
  const lowerHashLimit = 8192;
  const lowerHashComplete = Array.isArray(stringValues) && stringValues.length <= lowerHashLimit;
  const lowerHashes = lowerHashComplete
    ? [...new Set(stringValues.map(v => hashString32(v)))].sort((a,b)=>a-b)
    : undefined;
  return {
    ...base,
    distinctCount,
    lowerHashComplete,
    ...(lowerHashComplete ? {lowerHashes} : {})
  };
}

function normalizeColumnStat(raw, rowCount){
  if (!raw) return null;
  const type = raw.type || "string";
  const nullCount = Number(raw.nullCount ?? raw.nulls ?? 0);
  const base={
    type,
    rowCount:Number(raw.rowCount ?? rowCount ?? 0),
    nullCount,
    nonNullCount:Number(raw.nonNullCount ?? Math.max(0, Number(rowCount || raw.rowCount || 0) - nullCount)),
    changedCells:Number(raw.changedCells || 0)
  };
  if (type === "number"){
    return {
      ...base,
      invalidNumbers:Number(raw.invalidNumbers || 0),
      min:raw.min == null ? null : Number(raw.min),
      max:raw.max == null ? null : Number(raw.max)
    };
  }
  return {
    ...base,
    distinctCount:Number(raw.distinctCount ?? raw.distinct ?? 0),
    lowerHashComplete:!!raw.lowerHashComplete,
    lowerHashes:Array.isArray(raw.lowerHashes) ? raw.lowerHashes : null
  };
}

function chunkMetaForIndex(chunkIndex){
  if (activeIsMemory()) return state.dataset?.chunks?.[chunkIndex] || state.memory?.chunks?.[chunkIndex] || null;
  if (activeIsExternalStorage()) return state.externalDataset?.chunks?.[chunkIndex] || state.dataset?.chunks?.[chunkIndex] || null;
  if (activeIsVirtual()){
    const vc=state.virtual?.globalChunks?.[chunkIndex];
    const src=vc ? state.virtual.sources[vc.sourceIndex] : null;
    return src?.chunks?.[vc.sourceChunkIndex] || vc || null;
  }
  return state.dataset?.chunks?.[chunkIndex] || null;
}

function columnStatFromChunkMeta(meta, columnIndex){
  if (!meta) return null;
  const key=String(columnIndex);
  const raw = meta.columnStats?.[key] || meta.columnStats?.[columnIndex] || meta.stats?.[columnIndex] || null;
  return normalizeColumnStat(raw, meta.rowCount);
}

function arrayIncludesNumber(arr, value){
  if (!Array.isArray(arr)) return false;
  let lo=0, hi=arr.length-1;
  while(lo<=hi){
    const mid=(lo+hi)>>1;
    const mv=Number(arr[mid]);
    if (mv===value) return true;
    if (mv<value) lo=mid+1; else hi=mid-1;
  }
  return false;
}

function canSkipByNumberStat(stat, op, target){
  if (!stat || stat.type !== "number") return false;
  const rowCount=Number(stat.rowCount || 0);
  const nullCount=Number(stat.nullCount || 0);
  if (op === "isnull") return nullCount === 0;
  if (op === "notnull") return nullCount >= rowCount;
  const t=Number(target);
  if (!Number.isFinite(t)) return true;
  const min=stat.min == null ? null : Number(stat.min);
  const max=stat.max == null ? null : Number(stat.max);
  if (!Number.isFinite(min) || !Number.isFinite(max)) return true;
  if (op === "gt") return max <= t;
  if (op === "ge") return max < t;
  if (op === "lt") return min >= t;
  if (op === "le") return min > t;
  if (op === "eq") return t < min || t > max;
  if (op === "ne") return min === max && min === t && nullCount === 0;
  return false;
}

function canSkipByStringStat(stat, op, target){
  if (!stat || stat.type !== "string") return false;
  const rowCount=Number(stat.rowCount || 0);
  const nullCount=Number(stat.nullCount || 0);
  if (op === "isnull") return nullCount === 0;
  if (op === "notnull") return nullCount >= rowCount;
  if (op === "eq" && stat.lowerHashComplete && Array.isArray(stat.lowerHashes)){
    const h=hashString32(target);
    return !arrayIncludesNumber(stat.lowerHashes,h);
  }
  return false;
}

function canSkipByColumnStat(stat, op, target, type){
  if (!stat) return false;
  return (type === "number" || stat.type === "number")
    ? canSkipByNumberStat(stat, op, target)
    : canSkipByStringStat(stat, op, target);
}

function canSkipChunkByFilters(chunkIndex, filters){
  if (!filters || !filters.length) return false;
  const meta=chunkMetaForIndex(chunkIndex);
  for (const f of filters){
    const col=state.manifest.columns[f.columnIndex];
    const stat=columnStatFromChunkMeta(meta, f.columnIndex);
    if (canSkipByColumnStat(stat, f.op, f.value, col?.type)) return true;
  }
  return false;
}

function canSkipChunkForSearch(chunkIndex, columnIndex, op, value){
  const col=state.manifest.columns[columnIndex];
  const meta=chunkMetaForIndex(chunkIndex);
  const stat=columnStatFromChunkMeta(meta, columnIndex);
  return canSkipByColumnStat(stat, op, value, col?.type);
}

function canSkipChunkForTime(chunkIndex, timeField){
  const meta=chunkMetaForIndex(chunkIndex);
  const stat=columnStatFromChunkMeta(meta, timeField);
  return !!stat && Number(stat.rowCount || meta?.rowCount || 0) > 0 && Number(stat.nullCount || 0) >= Number(stat.rowCount || meta?.rowCount || 0);
}


const QUERY_PLAN_VERSION = 1;

function normalizeQueryOp(op, type){
  const raw=String(op || "contains").toLowerCase().trim().replace(/[\s_-]+/g," ");
  const aliases={
    "=":"eq", "==":"eq", "===":"eq", "eq":"eq", "equal":"eq", "equals":"eq", "is":"eq",
    "!=" :"ne", "!==":"ne", "<>":"ne", "ne":"ne", "not equal":"ne", "not equals":"ne", "is not":"ne",
    ">":"gt", "gt":"gt", "greater than":"gt",
    ">=":"ge", "ge":"ge", "greater or equal":"ge", "greater than or equal":"ge",
    "<":"lt", "lt":"lt", "less than":"lt",
    "<=":"le", "le":"le", "less or equal":"le", "less than or equal":"le",
    "like":"contains", "contains":"contains", "contain":"contains", "includes":"contains",
    "not like":"notcontains", "not contains":"notcontains", "not contain":"notcontains", "does not contain":"notcontains", "excludes":"notcontains",
    "starts with":"startswith", "start with":"startswith", "begins with":"startswith", "prefix":"startswith",
    "ends with":"endswith", "end with":"endswith", "suffix":"endswith",
    "regex":"regex", "regexp":"regex", "rlike":"regex", "matches":"regex",
    "is null":"isnull", "null":"isnull",
    "is not null":"notnull", "not null":"notnull",
    "is empty":"isempty", "empty":"isempty", "blank":"isempty",
    "is not empty":"notempty", "not empty":"notempty", "not blank":"notempty"
  };
  const x=aliases[raw] || raw.replace(/\s+/g,"");
  if (["eq","ne","gt","ge","lt","le","contains","notcontains","startswith","endswith","regex","isnull","notnull","isempty","notempty"].includes(x)) return x;
  return type === "number" ? "eq" : "contains";
}

function normalizeProjection(columns){
  const set=new Set();
  for (const raw of Array.isArray(columns) ? columns : []){
    const idx=Number(raw);
    if (Number.isFinite(idx) && idx >= 0 && state.manifest?.columns?.[idx]) set.add(idx);
  }
  return [...set].sort((a,b)=>a-b);
}

function normalizeQueryPredicate(raw){
  const columnIndex=Number(raw?.columnIndex);
  const col=state.manifest?.columns?.[columnIndex];
  if (!Number.isFinite(columnIndex) || columnIndex < 0 || !col) return null;
  const op=normalizeQueryOp(raw?.op, col.type);
  return {
    id:raw?.id || "",
    columnIndex,
    columnName:col.name,
    type:col.type,
    op,
    value:raw?.value ?? "",
    source:raw?.source || "filter",
    rowLevel:raw?.rowLevel !== false,
    pushdown:raw?.pushdown !== false
  };
}

function normalizeQueryFilterGroups(groups){
  return (Array.isArray(groups) ? groups : [])
    .map((g, gi) => {
      const conditions = (Array.isArray(g?.conditions) ? g.conditions : Array.isArray(g?.filters) ? g.filters : [])
        .map(normalizeQueryPredicate)
        .filter(Boolean);
      if (!conditions.length) return null;
      const mode = String(g?.mode || g?.matchMode || "any").toLowerCase() === "all" ? "all" : "any";
      return {
        id:g?.id || `group_${gi + 1}`,
        mode,
        conditions,
        rowLevel:g?.rowLevel !== false,
        pushdown:false
      };
    })
    .filter(Boolean);
}

function buildQueryPlan({name="query", predicates=[], filterGroups=[], projection=[], sort=null, limit=0, pushdown=true}={}){
  const compiledPredicates=(Array.isArray(predicates) ? predicates : [])
    .map(normalizeQueryPredicate)
    .filter(Boolean);
  const compiledFilterGroups=normalizeQueryFilterGroups(filterGroups);

  let sortSpec=null;
  const sortColumn = sort && sort.columnIndex !== "" && sort.columnIndex != null ? Number(sort.columnIndex) : -1;
  const sortCol=state.manifest?.columns?.[sortColumn];
  if (Number.isFinite(sortColumn) && sortColumn >= 0 && sortCol){
    sortSpec={
      columnIndex:sortColumn,
      columnName:sortCol.name,
      type:sortCol.type,
      direction:sort?.direction === "desc" ? "desc" : "asc"
    };
  }

  const required=new Set(normalizeProjection(projection));
  for (const p of compiledPredicates) required.add(p.columnIndex);
  for (const g of compiledFilterGroups) for (const p of g.conditions || []) required.add(p.columnIndex);
  if (sortSpec) required.add(sortSpec.columnIndex);

  return {
    version:QUERY_PLAN_VERSION,
    name,
    predicates:compiledPredicates,
    filterGroups:compiledFilterGroups,
    projection:normalizeProjection(projection),
    sort:sortSpec,
    requiredColumns:[...required].sort((a,b)=>a-b),
    limit:Number(limit || 0) > 0 ? Number(limit) : Number.POSITIVE_INFINITY,
    pushdown:!!pushdown
  };
}

function canSkipChunkByQueryPlan(chunkIndex, plan){
  if (!plan?.pushdown || !Array.isArray(plan.predicates) || !plan.predicates.length) return false;
  for (const p of plan.predicates){
    if (!p.pushdown) continue;
    const meta=chunkMetaForIndex(chunkIndex);
    const stat=columnStatFromChunkMeta(meta, p.columnIndex);
    if (canSkipByColumnStat(stat, p.op, p.value, p.type)) return true;
  }
  return false;
}

function queryPredicateMatches(chunk, localRow, predicate){
  if (!predicate?.rowLevel) return true;
  const v=valueFromColumn(chunk.columns.get(predicate.columnIndex), localRow);
  return compareValue(v, predicate.op, predicate.value, predicate.type);
}

function rowMatchesQueryPlan(chunk, localRow, plan){
  const predicates = Array.isArray(plan?.predicates) ? plan.predicates : [];
  const groups = Array.isArray(plan?.filterGroups) ? plan.filterGroups : [];
  if (!predicates.length && !groups.length) return true;
  for (const p of predicates){
    if (!queryPredicateMatches(chunk, localRow, p)) return false;
  }
  for (const g of groups){
    if (g?.rowLevel === false) continue;
    const conditions = Array.isArray(g?.conditions) ? g.conditions : [];
    if (!conditions.length) continue;
    const matched = String(g.mode || "any").toLowerCase() === "all"
      ? conditions.every((p) => queryPredicateMatches(chunk, localRow, p))
      : conditions.some((p) => queryPredicateMatches(chunk, localRow, p));
    if (!matched) return false;
  }
  return true;
}

function queryPlanSummary(plan){
  return {
    version:plan?.version || QUERY_PLAN_VERSION,
    name:plan?.name || "query",
    predicates:(plan?.predicates || []).map(p=>({
      columnIndex:p.columnIndex,
      columnName:p.columnName,
      op:p.op,
      type:p.type,
      source:p.source,
      rowLevel:p.rowLevel,
      pushdown:p.pushdown
    })),
    sort:plan?.sort || null,
    aggregate:plan?.aggregate ? {
      type:plan.aggregate.type,
      mode:plan.aggregate.mode || null,
      countMode:!!plan.aggregate.countMode,
      distributedReduce:true
    } : null,
    requiredColumns:plan?.requiredColumns || [],
    predicatePushdown:!!plan?.pushdown,
    executionEngine:"chunk-v1",
    workerPoolReady:true,
    distributedAggregateReduce:!!plan?.aggregate
  };
}


/* =========================================================
 * OBSERVATION ENGINE v1
 * ---------------------------------------------------------
 * QueryPlan compatibility layer that evaluates predicates as
 * chunk-local bitsets, uses dictionary-id matching for string
 * columns, compiled predicates for row-level comparisons, lazy
 * row materialization through row ids, Top-K sort for limited
 * sorted queries, and aggregate partials for Pivot/Time.
 *
 * Safety rule: the old chunk execution engine is kept intact.
 * Set state.observationEngine.enabled=false or pass
 * {observation:false} to any execution path to fall back.
 * ========================================================= */

const OBSERVATION_ENGINE_VERSION = 1;
const OBSERVATION_BITSET_WORD_BITS = 32;
const observationTimeBucketCache = new WeakMap();

function observationStatus(extra={}){
