async function resolveChunkReadTarget(chunkIndex){
  let chunkDir, sourceManifest=state.manifest, datasetId=state.dataset?.id || state.manifest?.id || "active";
  let physicalChunkIndex=Number(chunkIndex);
  let catalogMeta=null;

  if (activeIsVirtual()){
    const vc=state.virtual.globalChunks[chunkIndex];
    if (!vc) throw new Error(`Virtual chunk is out of range: ${chunkIndex}`);
    const src=state.virtual.sources[vc.sourceIndex];
    sourceManifest=src.manifest;
    datasetId=src.id || src.manifest?.id || `source_${vc.sourceIndex}`;
    physicalChunkIndex=Number(vc.sourceChunkIndex);
    catalogMeta=vc;
    chunkDir=await src.dir.getDirectoryHandle(`chunk_${String(physicalChunkIndex).padStart(6,"0")}`);
  } else if (activeIsExternalStorage()){
    catalogMeta=state.externalDataset?.chunks?.[chunkIndex] || state.dataset?.chunks?.[chunkIndex] || null;
    datasetId=state.externalDataset?.id || state.dataset?.id || state.manifest?.id || "external";
    sourceManifest=state.externalDataset?.manifest || state.manifest;
    physicalChunkIndex=Number(chunkIndex);
  } else {
    catalogMeta=state.dataset?.chunks?.[chunkIndex] || null;
    chunkDir=await state.dir.getDirectoryHandle(`chunk_${String(chunkIndex).padStart(6,"0")}`);
  }

  let rowCount=Number(catalogMeta?.rowCount || 0);
  let meta=catalogMeta;
  if (!rowCount){
    if (activeIsExternalStorage()) meta=await externalReadJson(`${state.externalDataset.base}/chunk_${String(physicalChunkIndex).padStart(6,"0")}/meta.json`);
    else meta=await readJson(chunkDir,"meta.json");
    rowCount=Number(meta.rowCount || 0);
  }

  return {chunkDir, sourceManifest, datasetId, physicalChunkIndex, rowCount, meta, external:activeIsExternalStorage(), externalBase:state.externalDataset?.base || ""};
}

async function readCachedColumn(target, col){
  const key=chunkCacheKey(target.datasetId, target.physicalChunkIndex, col.index, col.type);
  const hit=chunkColumnCache.map.get(key);
  if (hit){
    chunkColumnCache.hits++;
    return touchChunkCacheEntry(key, hit);
  }

  chunkColumnCache.misses++;
  let value;
  const chunkPath=`${target.externalBase}/chunk_${String(target.physicalChunkIndex).padStart(6,"0")}`;
  if (col.type === "number"){
    const buf=target.external ? await externalReadBuffer(`${chunkPath}/${colFileName(col.index,col.type)}`) : await readBuffer(target.chunkDir,colFileName(col.index,col.type));
    value={type:"number", data:new Float64Array(buf)};
  } else {
    const buf=target.external ? await externalReadBuffer(`${chunkPath}/${colFileName(col.index,col.type)}`) : await readBuffer(target.chunkDir,colFileName(col.index,col.type));
    const dict=target.external ? await externalReadJson(`${chunkPath}/${dictFileName(col.index)}`) : await readJson(target.chunkDir,dictFileName(col.index));
    value={type:"string", ids:new Int32Array(buf), dict};
  }
  return putChunkCacheEntry(key, value, estimateColumnDataBytes(value));
}


/* =========================================================
 * HYBRID SURFACE BUS v1 + EXECUTION PLANE v3
 * ---------------------------------------------------------
 * The runtime uses Tile = dataset x chunk x column x representation
 * as the common unit across OPFS, Memory, Cache, local workers and
 * remote execution. OPFS is the cold durable surface, warm cache is
 * decoded column residency, and hot memory is promoted high-value tiles.
 *
 * Scale-up: local Worker Pool across chunk surfaces.
 * Scale-out: Remote Execution Adapter when configured.
 * Distributed: aggregate partials and sortable row references are reduced
 *              back into the main Worker.
 * ========================================================= */

const HYBRID_SURFACE_BUS_VERSION = 1;
const EXECUTION_PLANE_VERSION = 3;
const ROW_SURFACE_BUS_VERSION = 1;
const hybridSurfaceRuntime = {
  hot:new Map(),
  warm:new Map(),
  bitsets:new Map(),
  rowSlabs:new Map(),
  hotBytes:0,
  warmBytes:0,
  bitsetBytes:0,
  rowSlabBytes:0,
  metrics:{requests:0,hotHits:0,warmHits:0,opfsReads:0,memoryReads:0,promotions:0,evictions:0,prefetches:0,bitsetHits:0,bitsetWrites:0,distributedDispatches:0,scaleUpDispatches:0,scaleOutDispatches:0,rowRequests:0,rowSlabHits:0,rowSlabMisses:0,rowSlabWrites:0,rowSlabEvictions:0,rowPrefetches:0,rowMaterialized:0,rowBatchReads:0}
};

function surfaceDefaultConfig(){
  return {
    enabled:true,
    tiering:true,
    autoPromote:true,
    prefetch:true,
    bitsetCache:true,
    hotBudgetBytes:256 * 1024 * 1024,
    warmBudgetBytes:256 * 1024 * 1024,
    bitsetBudgetBytes:128 * 1024 * 1024,
    rowSurface:true,
    rowSlabCache:true,
    rowPagePrefetch:true,
    rowSlabBudgetBytes:256 * 1024 * 1024,
    rowSlabMaxRows:4096,
    rowPrefetchPages:2,
    fullRowProjectionThreshold:0.6,
    promotionReadThreshold:2,
    representationBudget:true
  };
}

function executionPlaneDefaultConfig(){
  return {
    enabled:true,
    scaleUp:true,
    scaleOut:true,
    distributedReduce:true,
    preferRemote:false,
    workerPoolThresholdChunks:8,
    remoteThresholdRows:2_000_000,
    surfaceAware:true,
    mode:"adaptive"
  };
}

function surfaceConfig(){
  if (!state.hybridSurfaceBus) state.hybridSurfaceBus=surfaceDefaultConfig();
  state.hybridSurfaceBus={...surfaceDefaultConfig(),...(state.hybridSurfaceBus || {})};
  return state.hybridSurfaceBus;
}

function executionPlaneConfig(){
  if (!state.executionPlane) state.executionPlane=executionPlaneDefaultConfig();
  state.executionPlane={...executionPlaneDefaultConfig(),...(state.executionPlane || {})};
  return state.executionPlane;
}

function activeSurfaceDatasetId(){
  if (activeIsMemory()) return state.memory?.id || state.dataset?.id || state.manifest?.id || "memory";
  if (activeIsExternalStorage()) return state.externalDataset?.id || state.dataset?.id || state.manifest?.id || "external";
  if (activeIsVirtual()) return state.manifest?.id || `virtual:${(state.virtual?.sources || []).map(s=>s.id).join("+")}`;
  return state.dataset?.id || state.manifest?.id || "active";
}

function surfaceTileKey(datasetId, chunkIndex, columnIndex, representation="column"){
  return `${datasetId || activeSurfaceDatasetId()}\u001f${Number(chunkIndex)}\u001f${Number(columnIndex)}\u001f${representation || "column"}`;
}

function estimateTileBytes(value, representation="column"){
  if (!value) return 0;
  if (representation === "predicate-bitset" || value instanceof Uint32Array) return Number(value.byteLength || 0);
  if (representation === "time-bucket") return Number(value.byteLength || 0) || estimateColumnDataBytes(value);
  return estimateColumnDataBytes(value);
}

function surfaceTouch(map, key, tier){
  const entry=map.get(key);
  if (!entry) return null;
  map.delete(key);
  entry.lastUsed=now();
  entry.hits=Number(entry.hits || 0)+1;
  map.set(key,entry);
  if (tier === "hot") hybridSurfaceRuntime.metrics.hotHits++;
  if (tier === "warm") hybridSurfaceRuntime.metrics.warmHits++;
  if (tier === "bitset") hybridSurfaceRuntime.metrics.bitsetHits++;
  return entry.value;
}

function surfaceEvictTier(tier){
  const cfg=surfaceConfig();
  const map=tier === "hot" ? hybridSurfaceRuntime.hot : tier === "bitset" ? hybridSurfaceRuntime.bitsets : hybridSurfaceRuntime.warm;
  const budget=tier === "hot" ? cfg.hotBudgetBytes : tier === "bitset" ? cfg.bitsetBudgetBytes : cfg.warmBudgetBytes;
  const bytesProp=tier === "hot" ? "hotBytes" : tier === "bitset" ? "bitsetBytes" : "warmBytes";
  while(hybridSurfaceRuntime[bytesProp] > budget && map.size){
    let victimKey=null, victimScore=Infinity;
    for (const [k,e] of map.entries()){
      const age=Math.max(1, now() - Number(e.lastUsed || 0));
      const score=(Number(e.hits || 0)+1) / age;
      if (score < victimScore){ victimScore=score; victimKey=k; }
    }
    if (!victimKey) break;
    const old=map.get(victimKey);
    hybridSurfaceRuntime[bytesProp] -= Number(old?.bytes || 0);
    map.delete(victimKey);
    hybridSurfaceRuntime.metrics.evictions++;
  }
}

function surfaceRemember(tier, key, value, bytes, meta={}){
  const cfg=surfaceConfig();
  if (cfg.enabled === false || !key || !value) return value;
  const map=tier === "hot" ? hybridSurfaceRuntime.hot : tier === "bitset" ? hybridSurfaceRuntime.bitsets : hybridSurfaceRuntime.warm;
  const bytesProp=tier === "hot" ? "hotBytes" : tier === "bitset" ? "bitsetBytes" : "warmBytes";
  const safeBytes=Math.max(0, Number(bytes || estimateTileBytes(value, meta.representation)));
  if (tier === "hot" && safeBytes > cfg.hotBudgetBytes) return value;
  if (tier === "warm" && safeBytes > cfg.warmBudgetBytes) return value;
  if (tier === "bitset" && safeBytes > cfg.bitsetBudgetBytes) return value;
  if (map.has(key)){
    const old=map.get(key);
    hybridSurfaceRuntime[bytesProp] -= Number(old.bytes || 0);
    map.delete(key);
  }
  map.set(key,{value,bytes:safeBytes,lastUsed:now(),createdAt:now(),hits:0,...meta});
  hybridSurfaceRuntime[bytesProp] += safeBytes;
  if (tier === "bitset") hybridSurfaceRuntime.metrics.bitsetWrites++;
  surfaceEvictTier(tier);
  return value;
}

function surfaceClear(){
  hybridSurfaceRuntime.hot.clear();
  hybridSurfaceRuntime.warm.clear();
  hybridSurfaceRuntime.bitsets.clear();
  hybridSurfaceRuntime.rowSlabs.clear();
  hybridSurfaceRuntime.hotBytes=0;
  hybridSurfaceRuntime.warmBytes=0;
  hybridSurfaceRuntime.bitsetBytes=0;
  hybridSurfaceRuntime.rowSlabBytes=0;
  hybridSurfaceRuntime.metrics={requests:0,hotHits:0,warmHits:0,opfsReads:0,memoryReads:0,promotions:0,evictions:0,prefetches:0,bitsetHits:0,bitsetWrites:0,distributedDispatches:0,scaleUpDispatches:0,scaleOutDispatches:0,rowRequests:0,rowSlabHits:0,rowSlabMisses:0,rowSlabWrites:0,rowSlabEvictions:0,rowPrefetches:0,rowMaterialized:0,rowBatchReads:0};
  clearChunkCache();
  return hybridSurfaceStatus({cleared:true});
}

function configureHybridSurfaceBus(config={}){
  state.hybridSurfaceBus={...surfaceDefaultConfig(),...(state.hybridSurfaceBus || {}),...config};
  return hybridSurfaceStatus();
}

function configureExecutionPlane(config={}){
  state.executionPlane={...executionPlaneDefaultConfig(),...(state.executionPlane || {}),...config};
  return executionPlaneStatus();
}

function hybridSurfaceStatus(extra={}){
  const cfg=surfaceConfig();
  return {
    hybridSurfaceBusVersion:HYBRID_SURFACE_BUS_VERSION,
    enabled:cfg.enabled !== false,
    tiering:cfg.tiering !== false,
    autoPromote:cfg.autoPromote !== false,
    prefetch:cfg.prefetch !== false,
    bitsetCache:cfg.bitsetCache !== false,
    hotEntries:hybridSurfaceRuntime.hot.size,
    warmEntries:hybridSurfaceRuntime.warm.size,
    bitsetEntries:hybridSurfaceRuntime.bitsets.size,
    rowSurfaceBusVersion:ROW_SURFACE_BUS_VERSION,
    rowSurface:cfg.rowSurface !== false,
    rowSlabCache:cfg.rowSlabCache !== false,
    rowPagePrefetch:cfg.rowPagePrefetch !== false,
    rowSlabEntries:hybridSurfaceRuntime.rowSlabs.size,
    hotMB:Math.round(hybridSurfaceRuntime.hotBytes / 1024 / 1024),
    warmMB:Math.round(hybridSurfaceRuntime.warmBytes / 1024 / 1024),
    bitsetMB:Math.round(hybridSurfaceRuntime.bitsetBytes / 1024 / 1024),
    rowSlabMB:Math.round(hybridSurfaceRuntime.rowSlabBytes / 1024 / 1024),
    metrics:{...hybridSurfaceRuntime.metrics},
    chunkCache:chunkCacheSnapshot(),
    ...extra
  };
}

function executionPlaneStatus(extra={}){
  const cfg=executionPlaneConfig();
  return {
    executionPlaneVersion:EXECUTION_PLANE_VERSION,
    enabled:cfg.enabled !== false,
    scaleUp:cfg.scaleUp !== false,
    scaleOut:cfg.scaleOut !== false,
    distributedReduce:cfg.distributedReduce !== false,
    preferRemote:!!cfg.preferRemote,
    workerPoolThresholdChunks:Number(cfg.workerPoolThresholdChunks || 8),
    remoteThresholdRows:Number(cfg.remoteThresholdRows || 2_000_000),
    surfaceAware:cfg.surfaceAware !== false,
    mode:cfg.mode || "adaptive",
    surface:hybridSurfaceStatus(),
    ...extra
  };
}

function shouldPromoteSurfaceTile(req, value, options={}){
  const cfg=surfaceConfig();
  if (cfg.autoPromote === false) return false;
  if (req.hot === true || options.hot === true) return true;
  const hotColumns=options.surfacePlan?.hotColumns || options.hotColumns || [];
  if (hotColumns.includes(Number(req.columnIndex))) return true;
  const key=req.key;
  const warm=key ? hybridSurfaceRuntime.warm.get(key) : null;
  return Number(warm?.hits || 0) + 1 >= Number(cfg.promotionReadThreshold || 2);
}

function memoryColumnTile(chunkIndex, columnIndex){
  const memChunk=state.memory?.chunks?.[Number(chunkIndex)];
  if (!memChunk) return null;
  return memChunk.columns?.get(Number(columnIndex)) || null;
}

async function readSurfaceTiles(tileRequests, options={}){
  const cfg=surfaceConfig();
  const requests=Array.isArray(tileRequests) ? tileRequests : [];
  const tiles=new Map();
  const stats={fromHot:0,fromWarm:0,fromOPFS:0,fromMemory:0,promoted:0,bytes:0,requests:requests.length};
  if (!requests.length) return {tiles,stats,status:hybridSurfaceStatus()};

  for (const raw of requests){
    if (state.cancelled) throw new Error("Cancelled");
    const req={representation:"column",...raw};
    const datasetId=req.datasetId || activeSurfaceDatasetId();
    const key=req.key || surfaceTileKey(datasetId, req.chunkIndex, req.columnIndex, req.representation);
    req.key=key;
    hybridSurfaceRuntime.metrics.requests++;

    if (cfg.enabled !== false){
      const hot=surfaceTouch(hybridSurfaceRuntime.hot,key,"hot");
      if (hot){ tiles.set(key,hot); stats.fromHot++; stats.bytes += estimateTileBytes(hot,req.representation); continue; }
      const warm=surfaceTouch(hybridSurfaceRuntime.warm,key,"warm");
      if (warm){
        tiles.set(key,warm); stats.fromWarm++; stats.bytes += estimateTileBytes(warm,req.representation);
        if (shouldPromoteSurfaceTile(req,warm,options)){
          surfaceRemember("hot",key,warm,estimateTileBytes(warm,req.representation),{representation:req.representation,datasetId,chunkIndex:req.chunkIndex,columnIndex:req.columnIndex,promoted:true});
          hybridSurfaceRuntime.metrics.promotions++; stats.promoted++;
        }
        continue;
      }
    }

    let value=null;
    if (activeIsMemory()){
      value=memoryColumnTile(req.chunkIndex, req.columnIndex);
      if (!value) continue;
      hybridSurfaceRuntime.metrics.memoryReads++;
      stats.fromMemory++;
    } else {
      const target=options.target && Number(options.target.physicalChunkIndex) === Number(req.physicalChunkIndex ?? options.target.physicalChunkIndex) ? options.target : await resolveChunkReadTarget(req.chunkIndex);
      const cols=options.cols || target.sourceManifest?.columns || state.manifest?.columns || [];
      const col=cols[Number(req.columnIndex)];
      if (!col) continue;
      value=await readCachedColumn(target,col);
      hybridSurfaceRuntime.metrics.opfsReads++;
      stats.fromOPFS++;
    }
    const bytes=estimateTileBytes(value,req.representation);
    stats.bytes += bytes;
    if (cfg.enabled !== false){
      const tier=shouldPromoteSurfaceTile(req,value,options) ? "hot" : "warm";
      surfaceRemember(tier,key,value,bytes,{representation:req.representation,datasetId,chunkIndex:req.chunkIndex,columnIndex:req.columnIndex});
      if (tier === "hot"){ hybridSurfaceRuntime.metrics.promotions++; stats.promoted++; }
    }
    tiles.set(key,value);
  }
  return {tiles,stats,status:hybridSurfaceStatus()};
}

function buildSurfaceReadPlan(planOrObservationPlan, strategy={}){
  const hot=new Set();
  const warm=new Set();
  const required=new Set(Array.isArray(planOrObservationPlan?.requiredColumns) ? planOrObservationPlan.requiredColumns.map(Number) : []);
  for (const p of planOrObservationPlan?.predicates || []){ hot.add(Number(p.columnIndex)); required.add(Number(p.columnIndex)); }
  for (const g of planOrObservationPlan?.filterGroups || []) for (const p of g.conditions || []){ hot.add(Number(p.columnIndex)); required.add(Number(p.columnIndex)); }
  if (planOrObservationPlan?.sort){ hot.add(Number(planOrObservationPlan.sort.columnIndex)); required.add(Number(planOrObservationPlan.sort.columnIndex)); }
  const a=planOrObservationPlan?.aggregate;
  if (a){
    for (const idx of [...(a.rowIdx || []), ...(a.colIdx || []), a.timeIdx, a.groupIdx, a.valIdx]){
      const n=Number(idx); if (Number.isFinite(n) && n >= 0){ required.add(n); hot.add(n); }
    }
  }
  for (const idx of required) if (!hot.has(idx)) warm.add(idx);
  return {
    version:HYBRID_SURFACE_BUS_VERSION,
    surface:"chunk-column-tile",
    hotColumns:[...hot].filter(Number.isFinite).sort((a,b)=>a-b),
    warmColumns:[...warm].filter(Number.isFinite).sort((a,b)=>a-b),
    requiredColumns:[...required].filter(Number.isFinite).sort((a,b)=>a-b),
    strategy:strategy?.predicateMode || null
  };
}

function predicateBitsetSurfaceKey(chunk, predicate){
  const s=chunk?.surface || {};
  const datasetId=s.datasetId || activeSurfaceDatasetId();
  const physicalChunkIndex=s.physicalChunkIndex ?? s.chunkIndex ?? 0;
  const raw=`${predicate?.columnIndex}|${predicate?.op}|${predicate?.targetRaw ?? predicate?.value ?? ""}|${predicate?.type}|${predicate?.rowLevel !== false}`;
  return surfaceTileKey(datasetId, physicalChunkIndex, hashText32(raw), "predicate-bitset");
}

function evaluatePredicateBitsetSurfaceCached(chunk, predicate){
  const cfg=surfaceConfig();
  if (cfg.bitsetCache !== false && chunk?.surface && predicate?.rowLevel !== false){
    const key=predicateBitsetSurfaceKey(chunk,predicate);
    const cached=surfaceTouch(hybridSurfaceRuntime.bitsets,key,"bitset");
    if (cached && Number(cached.rowCount || chunk.rowCount) === Number(chunk.rowCount || 0)) return cached.bitset || cached;
    const bs=evaluatePredicateBitset(chunk,predicate);
    surfaceRemember("bitset",key,{bitset:bs,rowCount:chunk.rowCount},Number(bs.byteLength || 0),{representation:"predicate-bitset",predicate:{columnIndex:predicate.columnIndex,op:predicate.op}});
    return bs;
  }
  return evaluatePredicateBitset(chunk,predicate);
}

async function prefetchSurfaceForPlan(chunks, oplan, strategy={}){
  const cfg=surfaceConfig();
  if (cfg.prefetch === false) return {prefetched:0,reason:"prefetch disabled"};
  const surfacePlan=buildSurfaceReadPlan(oplan,strategy);
  const cols=surfacePlan.hotColumns.slice(0,8);
  if (!cols.length) return {prefetched:0,reason:"no hot columns"};
  const maxChunks=Math.min(Number(chunks?.length || 0), 4);
  const requests=[];
  for (let i=0;i<maxChunks;i++) for (const columnIndex of cols) requests.push({chunkIndex:chunks[i],columnIndex,representation:"column",hot:true});
  if (!requests.length) return {prefetched:0};
  hybridSurfaceRuntime.metrics.prefetches += requests.length;
  await readSurfaceTiles(requests,{surfacePlan,hot:true});
  return {prefetched:requests.length,surfacePlan};
}

function chooseExecutionPlane(plan, options={}, strategy={}, cost={}){
  const cfg=executionPlaneConfig();
  const chunks=Array.isArray(options.chunks) ? options.chunks : selectChunksForPlan(plan);
  const totalRows=Number(cost?.totalRows || state.manifest?.totalRows || 0);
  const remoteCfg=state.remoteExecution || {};
  const remoteEligible=cfg.scaleOut !== false && canUseRemoteExecution(plan, options, chunks);
  const remotePreferred=remoteEligible && (cfg.preferRemote || remoteCfg.mode === "remote-first" || remoteCfg.mode === "remote-only" || totalRows >= Number(cfg.remoteThresholdRows || 2_000_000));
  const poolOptions={...options,adaptive:false,observation:false};
  const workerPoolEligible=cfg.scaleUp !== false && chunks.length >= Number(cfg.workerPoolThresholdChunks || 8) && canUseChunkWorkerPool(plan,poolOptions,chunks);
  let mode="single-surface-worker";
  let scale="single";
  let reason="surface-aware single worker";
  if (remotePreferred){ mode="scale-out-remote"; scale="scale-out"; reason="remote execution adapter is eligible/preferred"; }
  else if (workerPoolEligible){ mode="scale-up-worker-pool"; scale="scale-up"; reason="chunk surface can be sharded across local workers"; }
  else if (activeIsMemory()){ mode="memory-surface"; scale="scale-up-memory"; reason="active dataset is already memory-resident"; }
  return {
    version:EXECUTION_PLANE_VERSION,
    enabled:cfg.enabled !== false,
    mode,
    scale,
    reason,
    chunks:chunks.length,
    totalRows,
    remoteEligible,
    workerPoolEligible,
    distributedReduce:cfg.distributedReduce !== false,
    surfaceAware:cfg.surfaceAware !== false,
    busVersion:HYBRID_SURFACE_BUS_VERSION
  };
}

function decorateExecutionWithPlane(exec, plane, surfacePlan=null){
  exec.executionPlane=plane;
  exec.hybridSurface=hybridSurfaceStatus();
  exec.surfaceReadPlan=surfacePlan;
  exec.queryPlan={...(exec.queryPlan || {}),executionPlane:plane,hybridSurface:hybridSurfaceStatus(),surfaceReadPlan:surfacePlan};
  return exec;
}

async function readChunkColumns(chunkIndex, colIndices, options={}){
  const unique=[...new Set((Array.isArray(colIndices) ? colIndices : []).map(Number).filter(i=>Number.isFinite(i)))];
  if (activeIsMemory()){
    const memChunk=state.memory.chunks[chunkIndex];
    if (!memChunk) throw new Error(`In-memory chunk is out of range: ${chunkIndex}`);
    const result={rowCount:memChunk.rowCount, columns:new Map(), cache:chunkCacheSnapshot(), surface:{datasetId:activeSurfaceDatasetId(),chunkIndex,physicalChunkIndex:chunkIndex,mode:"memory"}};
    const requests=unique.map(columnIndex=>({chunkIndex,columnIndex,representation:"column",datasetId:result.surface.datasetId,hot:options?.surfacePlan?.hotColumns?.includes(columnIndex)}));
    const surface=await readSurfaceTiles(requests,{...options,surfacePlan:options.surfacePlan});
    for (const req of requests){
      const key=surfaceTileKey(result.surface.datasetId,chunkIndex,req.columnIndex,"column");
      const stored=surface.tiles.get(key) || memChunk.columns.get(Number(req.columnIndex));
      if (stored) result.columns.set(Number(req.columnIndex), stored);
    }
    result.surface.stats=surface.stats;
    result.surface.status=surface.status;
    return result;
  }

  const target=await resolveChunkReadTarget(chunkIndex);
  const cols=(target.sourceManifest.columns || state.manifest.columns || []);
  const surfacePlan=options.surfacePlan || null;
  const requests=unique.map(columnIndex=>({
    datasetId:target.datasetId,
    chunkIndex,
    physicalChunkIndex:target.physicalChunkIndex,
    columnIndex,
    representation:"column",
    hot:surfacePlan?.hotColumns?.includes(Number(columnIndex))
  }));
  const surface=await readSurfaceTiles(requests,{...options,target,cols,surfacePlan});
  const result={rowCount:target.rowCount, columns:new Map(), cache:chunkCacheSnapshot(), surface:{datasetId:target.datasetId,chunkIndex,physicalChunkIndex:target.physicalChunkIndex,mode:target.external ? "external" : activeIsVirtual() ? "virtual" : "opfs",stats:surface.stats,status:surface.status}};

  for (const req of requests){
    const key=surfaceTileKey(target.datasetId,req.physicalChunkIndex,req.columnIndex,"column");
    const key2=surfaceTileKey(target.datasetId,chunkIndex,req.columnIndex,"column");
    const value=surface.tiles.get(key) || surface.tiles.get(key2);
    if (value) result.columns.set(Number(req.columnIndex), value);
  }
  result.cache=chunkCacheSnapshot();
  return result;
}

function valueFromColumn(colData, localRow){
  if (!colData) return "";
  if (colData.type === "number"){
    const v=colData.data[localRow];
    return Number.isNaN(v) ? "" : v;
  }
  const id=colData.ids[localRow];
  return id < 0 ? "" : (colData.dict[id] ?? "");
}

function rowAddress(globalRow){
  const target=Math.max(0, Number(globalRow || 0));
  if (activeIsMemory()){
    for (let i=0; i<state.memory.chunks.length; i++){
      const ch=state.memory.chunks[i];
      if (target >= ch.rowStart && target < ch.rowEnd) return {chunkIndex:i, localRow:target - ch.rowStart};
    }
    const last=state.memory.chunks[state.memory.chunks.length-1];
    return {chunkIndex:Math.max(0,state.memory.chunks.length-1), localRow:Math.max(0, Number(last?.rowCount || 1) - 1)};
  }
  if (activeIsVirtual()){
    for (let i=0; i<state.virtual.globalChunks.length; i++){
      const ch=state.virtual.globalChunks[i];
      if (target >= ch.rowStart && target < ch.rowEnd) return {chunkIndex:i, localRow:target - ch.rowStart};
    }
    const last=state.virtual.globalChunks[state.virtual.globalChunks.length-1];
    return {chunkIndex:Math.max(0,state.virtual.globalChunks.length-1), localRow:Math.max(0, Number(last?.rowCount || 1) - 1)};
  }
  const chunks=state.dataset?.chunks || [];
  let start=0;
  for (let i=0;i<chunks.length;i++){
    const rowCount=Number(chunks[i]?.rowCount || 0);
    const end=start + rowCount;
    if (target >= start && target < end) return {chunkIndex:i, localRow:target - start};
    start=end;
  }
  const last=chunks[chunks.length-1];
  return {chunkIndex:Math.max(0,chunks.length-1), localRow:Math.max(0, Number(last?.rowCount || 1) - 1)};
}

function normalizeCols(cols){
  if (!Array.isArray(cols) || cols.length===0) return state.manifest.columns.map(c=>c.index);
  return cols.map(Number).filter(i=>Number.isFinite(i) && i>=0 && i<state.manifest.columns.length);
}

function rowSurfaceProjectionMode(selected){
  const total=Math.max(1, Number(state.manifest?.columns?.length || selected?.length || 1));
  const ratio=(Array.isArray(selected) ? selected.length : 0) / total;
  const cfg=surfaceConfig();
  return ratio >= Number(cfg.fullRowProjectionThreshold ?? 0.6) ? "full-row" : "projection-row";
}

function rowSurfaceProjectionKey(selected, mode="projection-row"){
  const projection=Array.isArray(selected) ? selected.map(Number).filter(Number.isFinite) : [];
  return hashText32(`${mode}|${projection.join(",")}`);
}

function rowSlabKey(datasetId, chunkIndex, rowStart, rowEnd, selected, mode="projection-row"){
  return `${datasetId || activeSurfaceDatasetId()}\u001f${Number(chunkIndex)}\u001f${Number(rowStart)}\u001f${Number(rowEnd)}\u001f${rowSurfaceProjectionKey(selected,mode)}\u001frow-slab`;
}

function estimateRowSlabBytes(slab){
  if (!slab) return 0;
  const rows=Array.isArray(slab.rows) ? slab.rows : [];
  let bytes=64;
  for (let r=0; r<rows.length; r++){
    const row=Array.isArray(rows[r]) ? rows[r] : [];
    bytes += 16 + row.length * 8;
    for (let c=0; c<row.length; c++){
      const v=row[c];
      if (typeof v === "string") bytes += v.length * 2;
      else if (typeof v === "number") bytes += 8;
      else if (v != null) bytes += String(v).length * 2;
    }
  }
  return bytes;
}

function rowSlabTouch(key){
  const entry=hybridSurfaceRuntime.rowSlabs.get(key);
  if (!entry) return null;
  hybridSurfaceRuntime.rowSlabs.delete(key);
  entry.lastUsed=now();
  entry.hits=Number(entry.hits || 0)+1;
  hybridSurfaceRuntime.rowSlabs.set(key,entry);
  hybridSurfaceRuntime.metrics.rowSlabHits++;
  return entry.value;
}

function rowSlabEvict(){
  const cfg=surfaceConfig();
  const budget=Number(cfg.rowSlabBudgetBytes || 256 * 1024 * 1024);
  const map=hybridSurfaceRuntime.rowSlabs;
  while(hybridSurfaceRuntime.rowSlabBytes > budget && map.size){
    let victimKey=null, victimScore=Infinity;
    for (const [k,e] of map.entries()){
      const age=Math.max(1, now() - Number(e.lastUsed || 0));
      const rows=Number(e.value?.rows?.length || 1);
      const score=(Number(e.hits || 0)+1) / Math.max(1, age * Math.log2(rows + 1));
      if (score < victimScore){ victimScore=score; victimKey=k; }
    }
    if (!victimKey) break;
    const old=map.get(victimKey);
    hybridSurfaceRuntime.rowSlabBytes -= Number(old?.bytes || 0);
    map.delete(victimKey);
    hybridSurfaceRuntime.metrics.rowSlabEvictions++;
  }
}

function rowSlabRemember(key, slab){
  const cfg=surfaceConfig();
  if (cfg.enabled === false || cfg.rowSlabCache === false || !key || !slab) return slab;
  const bytes=estimateRowSlabBytes(slab);
  if (bytes > Number(cfg.rowSlabBudgetBytes || 256 * 1024 * 1024)) return slab;
  if (hybridSurfaceRuntime.rowSlabs.has(key)){
    const old=hybridSurfaceRuntime.rowSlabs.get(key);
    hybridSurfaceRuntime.rowSlabBytes -= Number(old?.bytes || 0);
    hybridSurfaceRuntime.rowSlabs.delete(key);
  }
  hybridSurfaceRuntime.rowSlabs.set(key,{value:slab,bytes,lastUsed:now(),createdAt:now(),hits:0,representation:"row-slab"});
  hybridSurfaceRuntime.rowSlabBytes += bytes;
  hybridSurfaceRuntime.metrics.rowSlabWrites++;
  rowSlabEvict();
  return slab;
}

function sliceRowsFromSlab(slab, rowStart, rowEnd){
  if (!slab || !Array.isArray(slab.rows)) return null;
  const from=Math.max(0, Number(rowStart) - Number(slab.rowStart || 0));
  const to=Math.max(from, Number(rowEnd) - Number(slab.rowStart || 0));
  return slab.rows.slice(from,to);
}

function findCoveringRowSlab(datasetId, chunkIndex, rowStart, rowEnd, selected, mode){
  const key=rowSlabKey(datasetId, chunkIndex, rowStart, rowEnd, selected, mode);
  const exact=rowSlabTouch(key);
  if (exact) return {slab:exact, key, exact:true};
  // Try a covering slab with the same dataset, chunk, and projection. This makes page prefetch usable.
  const suffix=`\u001f${rowSurfaceProjectionKey(selected,mode)}\u001frow-slab`;
  const prefix=`${datasetId || activeSurfaceDatasetId()}\u001f${Number(chunkIndex)}\u001f`;
  for (const [k,e] of hybridSurfaceRuntime.rowSlabs.entries()){
    if (!k.startsWith(prefix) || !k.endsWith(suffix)) continue;
    const slab=e.value;
    if (Number(slab.rowStart) <= Number(rowStart) && Number(slab.rowEnd) >= Number(rowEnd)){
      hybridSurfaceRuntime.rowSlabs.delete(k);
      e.lastUsed=now(); e.hits=Number(e.hits || 0)+1;
      hybridSurfaceRuntime.rowSlabs.set(k,e);
      hybridSurfaceRuntime.metrics.rowSlabHits++;
      return {slab:{...slab,rows:sliceRowsFromSlab(slab,rowStart,rowEnd),rowStart,rowEnd}, key:k, exact:false};
    }
  }
  hybridSurfaceRuntime.metrics.rowSlabMisses++;
  return null;
}

function buildRowSurfacePlan({page=1,pageSize=500,startRow=null,rowIds=null,cols=[]}={}){
  const selected=normalizeCols(cols);
  const mode=rowSurfaceProjectionMode(selected);
  const total=Number(state.manifest?.totalRows || 0);
  const start=startRow == null ? Math.max(0,(Number(page || 1)-1)*Number(pageSize || 500)) : Math.max(0,Number(startRow || 0));
  const end=Math.min(total,start + Math.max(0,Number(pageSize || 500)));
  return {
    version:ROW_SURFACE_BUS_VERSION,
    surface:"chunk-row-slab",
    datasetId:activeSurfaceDatasetId(),
    mode,
    projection:selected,
    projectionHash:rowSurfaceProjectionKey(selected,mode),
    startRow:start,
    endRow:end,
    page:Number(page || 1),
    pageSize:Number(pageSize || 500),
    rowCount:Array.isArray(rowIds) ? rowIds.length : Math.max(0,end-start),
    rowIds:Array.isArray(rowIds) ? rowIds.length : null,
    fullRowMode:mode === "full-row"
  };
}

function bucketRowIdsByChunk(rowIds){
  const buckets=new Map();
  const ids=Array.isArray(rowIds) ? rowIds : [];
  for (let order=0; order<ids.length; order++){
    const global=Number(ids[order]);
    if (!Number.isFinite(global)) continue;
    const addr=rowAddress(global);
    let bucket=buckets.get(addr.chunkIndex);
    if (!bucket){ bucket=[]; buckets.set(addr.chunkIndex,bucket); }
    bucket.push({order,global,localRow:addr.localRow});
  }
  return buckets;
}

function contiguousRangesFromLocals(locals, maxRows=null){
  const sorted=[...new Set((Array.isArray(locals) ? locals : []).map(Number).filter(Number.isFinite))].sort((a,b)=>a-b);
  const ranges=[];
  let start=null, prev=null;
  const limit=maxRows == null ? Number(surfaceConfig().rowSlabMaxRows || 4096) : Number(maxRows || 4096);
  for (const local of sorted){
    if (start == null){ start=local; prev=local; continue; }
    if (local === prev + 1 && (local - start + 1) <= limit){ prev=local; continue; }
    ranges.push({start,end:prev+1});
    start=local; prev=local;
  }
  if (start != null) ranges.push({start,end:prev+1});
  return ranges;
}

function findRangeForLocalRow(ranges, localRow){
  for (const r of ranges) if (localRow >= r.start && localRow < r.end) return r;
  return null;
}

async function materializeRowSlab(chunkIndex, rowStart, rowEnd, selected, options={}){
  const cfg=surfaceConfig();
  const datasetId=options.datasetId || activeSurfaceDatasetId();
  const mode=options.mode || rowSurfaceProjectionMode(selected);
  const safeStart=Math.max(0,Number(rowStart || 0));
  const safeEnd=Math.max(safeStart,Number(rowEnd || safeStart));
  const key=rowSlabKey(datasetId, chunkIndex, safeStart, safeEnd, selected, mode);
  hybridSurfaceRuntime.metrics.rowRequests++;
  if (cfg.enabled !== false && cfg.rowSurface !== false && cfg.rowSlabCache !== false){
    const cached=findCoveringRowSlab(datasetId,chunkIndex,safeStart,safeEnd,selected,mode);
    if (cached?.slab) return cached.slab;
  }
  const surfacePlan={version:ROW_SURFACE_BUS_VERSION,surface:"row-slab-materialization",requiredColumns:selected,warmColumns:selected,hotColumns:mode === "full-row" ? selected : []};
  const chunk=await readChunkColumns(chunkIndex, selected, {surfacePlan});
  const end=Math.min(safeEnd,Number(chunk.rowCount || safeEnd));
  const rows=[];
  for (let r=safeStart; r<end; r++) rows.push(selected.map(i=>valueFromColumn(chunk.columns.get(i),r)));
  const slab={datasetId,chunkIndex,rowStart:safeStart,rowEnd:end,projection:selected,projectionHash:rowSurfaceProjectionKey(selected,mode),mode,rows,rowCount:rows.length,createdAt:new Date().toISOString()};
  hybridSurfaceRuntime.metrics.rowMaterialized += rows.length;
  hybridSurfaceRuntime.metrics.rowBatchReads++;
  if (cfg.enabled !== false && cfg.rowSurface !== false && cfg.rowSlabCache !== false) rowSlabRemember(key,slab);
  return slab;
}

async function materializeRowIdsSurface(rowIds, cols, options={}){
  const selected=normalizeCols(cols);
  const mode=options.mode || rowSurfaceProjectionMode(selected);
  const buckets=bucketRowIdsByChunk(rowIds);
  const rows=new Array((Array.isArray(rowIds) ? rowIds : []).length);
  const details=[];
  for (const [chunkIndex, refs] of buckets.entries()){
    refs.sort((a,b)=>a.localRow-b.localRow);
    const ranges=contiguousRangesFromLocals(refs.map(x=>x.localRow));
    const slabByRange=new Map();
    for (const range of ranges){
      const slab=await materializeRowSlab(chunkIndex,range.start,range.end,selected,{...options,mode});
      slabByRange.set(`${range.start}|${range.end}`,slab);
      details.push({chunkIndex,rowStart:range.start,rowEnd:range.end,rows:slab.rows.length,mode});
    }
    for (const ref of refs){
      const range=findRangeForLocalRow(ranges,ref.localRow);
      const slab=range ? slabByRange.get(`${range.start}|${range.end}`) : null;
      rows[ref.order]=slab?.rows?.[ref.localRow - range.start] || selected.map(()=>"");
    }
    if (state.cancelled) throw new Error("Cancelled");
  }
  return {header:selected.map(i=>state.manifest.columns[i].name), rows:rows.filter(r=>Array.isArray(r)), rowSurface:{plan:buildRowSurfacePlan({rowIds,cols:selected}), details, status:hybridSurfaceStatus()}};
}

async function prefetchRowPageSurface(startRow, pageSize, selected, options={}){
  const cfg=surfaceConfig();
  if (cfg.rowPagePrefetch === false || cfg.rowSurface === false) return {prefetched:0,reason:"row prefetch disabled"};
  const pages=Math.max(0,Number(cfg.rowPrefetchPages || 2));
  if (!pages) return {prefetched:0,reason:"no row prefetch pages"};
  const total=Number(state.manifest?.totalRows || 0);
  let cursor=Math.max(0,Number(startRow || 0)) + Number(pageSize || 0);
  let prefetched=0;
  const slabs=[];
  for (let p=0; p<pages && cursor<total; p++){
    const end=Math.min(total,cursor+Number(pageSize || 0));
    let global=cursor;
    while(global<end){
      const addr=rowAddress(global);
      const base=chunkBaseRow(addr.chunkIndex);
      const chunkMeta=chunkMetaForIndex(addr.chunkIndex);
      const chunkRows=Number(chunkMeta?.rowCount || 0);
      const localEnd=Math.min(chunkRows, addr.localRow + (end-global));
      materializeRowSlab(addr.chunkIndex,addr.localRow,localEnd,selected,{...options,prefetch:true}).catch(()=>{});
      slabs.push({chunkIndex:addr.chunkIndex,rowStart:addr.localRow,rowEnd:localEnd});
      prefetched += Math.max(0,localEnd-addr.localRow);
      global=base+localEnd;
      if (global <= cursor) break;
    }
    cursor=end;
  }
  hybridSurfaceRuntime.metrics.rowPrefetches += prefetched;
  return {prefetched,slabs};
}

async function readPage(page,pageSize,cols){
  const selected=normalizeCols(cols);
  const total=Number(state.manifest.totalRows || 0);
  const start=Math.max(0,(Number(page || 1)-1)*Number(pageSize || 500));
  const end=Math.min(total,start+Number(pageSize || 500));
  const rows=[];
  const slabs=[];
  let global=start;
  while(global<end){
    const addr=rowAddress(global);
    const base=chunkBaseRow(addr.chunkIndex);
    const chunkMeta=chunkMetaForIndex(addr.chunkIndex);
    const chunkRows=Number(chunkMeta?.rowCount || 0);
    const localEnd=Math.min(chunkRows, addr.localRow + (end-global));
    const slab=await materializeRowSlab(addr.chunkIndex,addr.localRow,localEnd,selected,{mode:rowSurfaceProjectionMode(selected)});
    rows.push(...slab.rows);
    slabs.push({chunkIndex:addr.chunkIndex,rowStart:addr.localRow,rowEnd:localEnd,rows:slab.rows.length,mode:slab.mode});
    global=base+localEnd;
    if (global <= start || state.cancelled) break;
  }
  const prefetch=prefetchRowPageSurface(start,Number(pageSize || 500),selected).catch(()=>null);
  return {header:selected.map(i=>state.manifest.columns[i].name), rows, startRow:start, rowSurface:{plan:buildRowSurfacePlan({page,pageSize,startRow:start,cols:selected}), slabs, status:hybridSurfaceStatus(), prefetchScheduled:!!prefetch}};
}

async function readRowsByGlobal(rowIds, cols){
  return await materializeRowIdsSurface(rowIds, cols);
}

function compareValue(v, op, target, type){
  const o=normalizeQueryOp(op, type);
  const isNull = v === "" || v == null || (typeof v === "number" && Number.isNaN(v));
  if (o === "isnull") return isNull;
  if (o === "notnull") return !isNull;
  if (o === "isempty") return isNull || String(v ?? "").trim() === "";
  if (o === "notempty") return !isNull && String(v ?? "").trim() !== "";
  if (type === "number" && ["eq","ne","gt","ge","lt","le"].includes(o)){
    const n=Number(v), t=Number(target);
    if (!Number.isFinite(n) || !Number.isFinite(t)) return false;
    if (o==="eq") return n===t; if (o==="ne") return n!==t; if (o==="gt") return n>t; if (o==="ge") return n>=t; if (o==="lt") return n<t; if (o==="le") return n<=t;
  }
  const raw=String(v ?? ""), rawTarget=String(target ?? "");
  const s=raw.toLowerCase(), q=rawTarget.toLowerCase();
  if (o==="contains") return s.includes(q);
  if (o==="notcontains") return !s.includes(q);
  if (o==="startswith") return s.startsWith(q);
  if (o==="endswith") return s.endsWith(q);
  if (o==="regex") {
    try { return new RegExp(rawTarget, "i").test(raw); } catch { return false; }
  }
  if (o==="eq") return s===q;
  if (o==="ne") return s!==q;
  if (o==="gt") return raw.localeCompare(rawTarget, undefined, {numeric:true, sensitivity:"base"}) > 0;
  if (o==="ge") return raw.localeCompare(rawTarget, undefined, {numeric:true, sensitivity:"base"}) >= 0;
  if (o==="lt") return raw.localeCompare(rawTarget, undefined, {numeric:true, sensitivity:"base"}) < 0;
  if (o==="le") return raw.localeCompare(rawTarget, undefined, {numeric:true, sensitivity:"base"}) <= 0;
  return false;
}

async function runSearch({columnIndex, op, value, maxMatches}){
  const idx=Number(columnIndex);
  const col=state.manifest.columns[idx];
  if (!col) throw new Error("Search column is not selected");
  const cap=normalizePlanLimit(maxMatches);
  const plan=buildQueryPlan({
    name:"search",
    predicates:[{columnIndex:idx, op, value, source:"search"}],
    projection:[idx],
    limit:cap,
    pushdown:true
  });

  const exec=await executeChunkExecutionPlanMaybeParallel(plan,{
    collectRows:true,
    limit:cap,
    progressLabel:"Searching chunks",
    progressEvery:5,
    progressText:(ctx)=>`Searching chunks... ${ctx.position+1}/${ctx.totalChunks} / skipped ${fmt(ctx.skippedChunks)} / matches ${fmt(ctx.refs.length)}`
  });

  state.searchMatches=exec.refs;
  return {
    matches:exec.refs.length,
    capped:exec.capped,
    scanned:exec.scanned,
    skippedChunks:exec.skippedChunks,
    queryPlan:exec.queryPlan,
    executionEngine:{version:exec.engineVersion,mode:exec.executionMode || "single-worker",workerPoolVersion:exec.workerPoolVersion || null,workers:exec.workerCount || 1,taskId:exec.taskId,chunks:exec.chunks.length},
    ms:exec.ms
  };
}

function normalizeGlobalFilters(filters){
  return (Array.isArray(filters) ? filters : [])
    .map(f => {
      const columnIndex=Number(f.columnIndex);
      const col=state.manifest.columns[columnIndex];
      return { id:f?.id || "", columnIndex, op:normalizeQueryOp(f.op || "contains", col?.type), value:f.value ?? "", source:f?.source || "globalFilter" };
    })
    .filter(f => Number.isFinite(f.columnIndex) && f.columnIndex >= 0 && state.manifest.columns[f.columnIndex]);
}

function normalizeGlobalFilterGroups(groups){
  return (Array.isArray(groups) ? groups : [])
    .map((g, gi) => {
      const conditions = normalizeGlobalFilters(Array.isArray(g?.conditions) ? g.conditions : Array.isArray(g?.filters) ? g.filters : []);
      if (!conditions.length) return null;
      return {
        id:g?.id || `group_${gi + 1}`,
        mode:String(g?.mode || g?.matchMode || "any").toLowerCase() === "all" ? "all" : "any",
        conditions
      };
    })
    .filter(Boolean);
}

async function runDataQuery({filters, filterGroups, sort, maxRows, projection}){
  const normalizedFilters = normalizeGlobalFilters(filters);
  const normalizedFilterGroups = normalizeGlobalFilterGroups(filterGroups);
  const requestedLimit = normalizePlanLimit(maxRows);
  const normalizedProjection = normalizeProjection(projection);
  const plan=buildQueryPlan({
    name:"dataQuery",
    predicates:normalizedFilters,
    filterGroups:normalizedFilterGroups,
    projection:normalizedProjection,
    sort,
    limit:requestedLimit,
    pushdown:true
  });
  const hasSort=!!plan.sort;
  if (!plan.predicates.length && !(plan.filterGroups || []).length && !hasSort) {
    state.dataQueryMatches = null;
    state.dataQueryMeta = { filters:normalizedFilters, filterGroups:normalizedFilterGroups, sort:null, capped:false, queryPlan:queryPlanSummary(plan), projection:normalizedProjection };
    return {matches:state.manifest.totalRows, active:false, capped:false, projection:normalizedProjection, ms:0, queryPlan:queryPlanSummary(plan)};
  }

  const scanLimit = hasSort ? Number.POSITIVE_INFINITY : requestedLimit;
  const exec=await executeChunkExecutionPlanMaybeParallel(plan,{
    collectRows:!hasSort,
    collectSort:hasSort,
    limit:scanLimit,
    progressLabel:"Global filter/sort chunks",
    progressEvery:5,
    progressText:(ctx)=>{
      const found = hasSort ? ctx.sortable.length : ctx.refs.length;
      return `Global filter/sort chunks... ${ctx.position+1}/${ctx.totalChunks} / skipped ${fmt(ctx.skippedChunks)} / matches ${fmt(found)}`;
    }
  });

  let capped = exec.capped;
  if (hasSort) {
    capped = Number.isFinite(requestedLimit) && exec.sortable.length > requestedLimit;
    state.dataQueryMatches = await sortPlanRowsToRowIds(exec.sortable, plan.sort, requestedLimit, {
      label:"Global data query",
      progressBase:88,
      progressSpan:10,
      chunkSize:100000
    });
  } else {
    state.dataQueryMatches = exec.refs;
  }
  postProgress(99, `Global data query row index ready: ${fmt(state.dataQueryMatches.length)} rows`);

  state.dataQueryMeta = {
    filters:normalizedFilters,
    filterGroups:normalizedFilterGroups,
    sort:plan.sort ? {columnIndex:plan.sort.columnIndex,direction:plan.sort.direction} : null,
    capped,
    queryPlan:exec.queryPlan,
    projection:normalizedProjection,
    executionEngine:{version:exec.engineVersion,mode:exec.executionMode || "single-worker",workerPoolVersion:exec.workerPoolVersion || null,workers:exec.workerCount || 1,taskId:exec.taskId,chunks:exec.chunks.length}
  };
  return {
    matches:state.dataQueryMatches.length,
    active:true,
    capped,
    projection:normalizedProjection,
    scanned:exec.scanned,
    skippedChunks:exec.skippedChunks,
    queryPlan:exec.queryPlan,
    executionEngine:{version:exec.engineVersion,mode:exec.executionMode || "single-worker",workerPoolVersion:exec.workerPoolVersion || null,workers:exec.workerCount || 1,taskId:exec.taskId,chunks:exec.chunks.length},
    ms:exec.ms
  };
}

async function readDataQueryPage(page,pageSize,cols){
  if (!Array.isArray(state.dataQueryMatches)) throw new Error("Global data query is not active");
  const total = state.dataQueryMatches.length;
  const start = Math.max(0,(page-1)*pageSize);
  const ids = state.dataQueryMatches.slice(start, start + pageSize);
  const projectedCols = Array.isArray(state.dataQueryMeta?.projection) && state.dataQueryMeta.projection.length
    ? state.dataQueryMeta.projection
    : cols;
  const result = await readRowsByGlobal(ids, projectedCols);
  return {...result, startRow:start, totalMatches:total};
}


function normalizeGraphJoinLimit(value){
  const n = Number(value || 0);
  return Number.isFinite(n) && n > 0 ? Math.floor(n) : Number.POSITIVE_INFINITY;
}

function cleanJoinAlias(value, fallback){
  const s = String(value || "").normalize("NFKC").trim().replace(/[^A-Za-z0-9_\u3040-\u30ff\u3400-\u9fff-]+/g, "_");
  return s || fallback;
}

async function readStoredDatasetChunkColumns(opened, chunkIndex, colIndices){
  const chunkDir = await opened.dir.getDirectoryHandle(`chunk_${String(chunkIndex).padStart(6,"0")}`);
  const meta = opened.chunks?.[chunkIndex] || await readJson(chunkDir,"meta.json");
  const rowCount = Number(meta?.rowCount || 0);
  const result = {rowCount, columns:new Map()};
  const cols = opened.manifest?.columns || [];
  const unique = [...new Set((Array.isArray(colIndices) ? colIndices : []).map(Number).filter(i => Number.isFinite(i) && cols[i]))];
  for (const idx of unique){
    const col = cols[idx];
    if (col.type === "number"){
      const buf = await readBuffer(chunkDir, colFileName(col.index, col.type));
      result.columns.set(idx, {type:"number", data:new Float64Array(buf)});
    } else {
      const buf = await readBuffer(chunkDir, colFileName(col.index, col.type));
      const dict = await readJson(chunkDir, dictFileName(col.index));
      result.columns.set(idx, {type:"string", ids:new Int32Array(buf), dict});
    }
  }
  return result;
}

function normalizeJoinFieldRef(raw){
  if (!raw) return null;
  if (typeof raw === "string"){
    const [sourceId, col] = raw.split(":");
    const columnIndex = Number(col);
    return sourceId && Number.isFinite(columnIndex) ? {sourceId, columnIndex} : null;
  }
  const sourceId = raw.sourceId || raw.source || raw.dataset || "";
  const columnIndex = Number(raw.columnIndex);
  return sourceId && Number.isFinite(columnIndex) ? {sourceId, columnIndex} : null;
}

function joinFieldKey(field){ return `${field.sourceId}:${field.columnIndex}`; }

function sourceSpecById(sources, id){ return (sources || []).find(s => String(s.id) === String(id)) || null; }

function sourceManifestColumn(sourceSpec, openedMap, columnIndex){
  const opened = openedMap.get(sourceSpec.id);
  return opened?.manifest?.columns?.[Number(columnIndex)] || null;
}

function joinOutputHeader(selectedFields, sources, openedMap){
  return selectedFields.map((f) => {
    const src = sourceSpecById(sources, f.sourceId) || {alias:f.sourceId};
    const col = sourceManifestColumn(src, openedMap, f.columnIndex);
    return `${cleanJoinAlias(src.alias || src.id, src.id)}.${col?.name || `Column${Number(f.columnIndex)+1}`}`;
  });
}

function makeBlankPayload(fields){
  const out = new Map();
  for (const f of fields) out.set(joinFieldKey(f), "");
  return out;
}

function payloadFromChunk(sourceId, chunk, localRow, fields){
  const out = new Map();
  for (const f of fields){
    if (f.sourceId !== sourceId) continue;
    out.set(joinFieldKey(f), valueFromColumn(chunk.columns.get(f.columnIndex), localRow));
  }
  return out;
}

function rowFromPayloads(selectedFields, payloads){
  return selectedFields.map((f) => {
    const key = joinFieldKey(f);
    for (const p of payloads){ if (p && p.has(key)) return p.get(key); }
    return "";
  });
}

async function buildJoinSideHash(opened, sourceId, keyColumnIndex, outputFields){
  const sourceFields = outputFields.filter(f => f.sourceId === sourceId);
  const required = [...new Set([Number(keyColumnIndex), ...sourceFields.map(f => Number(f.columnIndex))].filter(Number.isFinite))];
  const map = new Map();
  let rows = 0;
  for (let c=0; c<(opened.chunks || []).length; c++){
    if (state.cancelled) throw new Error("Cancelled");
    const chunk = await readStoredDatasetChunkColumns(opened, c, required);
    for (let r=0; r<chunk.rowCount; r++){
      const key = valueFromColumn(chunk.columns.get(Number(keyColumnIndex)), r);
      if (key === "" || key == null) continue;
      const k = String(key);
      const payload = payloadFromChunk(sourceId, chunk, r, sourceFields);
      if (!map.has(k)) map.set(k, []);
      map.get(k).push(payload);
      rows++;
    }
    if (c % 5 === 0) post("PROGRESS", {value:Math.min(70, Math.floor((c+1)/Math.max(1, opened.chunks.length)*45)), text:`JOIN hash build: ${fmt(rows)} rows indexed`});
  }
  return {map, rows, blank:makeBlankPayload(sourceFields)};
}

function defaultJoinSelectedFields(sources, openedMap){
  const out=[];
  for (const src of sources){
    const cols = openedMap.get(src.id)?.manifest?.columns || [];
    for (const c of cols.slice(0, Math.min(6, cols.length))) out.push({sourceId:src.id, columnIndex:Number(c.index)});
  }
  return out.slice(0, 16);
}

async function runGraphJoinQuery({plan, pageSize}){
  const t0 = now();
  if (!plan || !Array.isArray(plan.sources) || plan.sources.length < 2) throw new Error("JOIN requires at least two Dataset Source nodes");
  if (!Array.isArray(plan.joins) || !plan.joins.length) throw new Error("JOIN node is not configured");

  const sources = plan.sources.map((s, i) => ({
    id:String(s.id || `source_${i+1}`),
    datasetId:String(s.datasetId || ""),
    alias:cleanJoinAlias(s.alias || `t${i+1}`, `t${i+1}`)
  }));
  for (const src of sources){
    if (!src.datasetId || src.datasetId === "__active__") {
      if (!state.dataset?.id) throw new Error(`Source ${src.alias} has no saved dataset id`);
      src.datasetId = state.dataset.id;
    }
  }

  const openedMap = new Map();
  for (const src of sources){
    openedMap.set(src.id, await loadValidatedDataset(src.datasetId, {rebuildStats:false}));
  }

  const join = plan.joins[0];
  const leftSourceId = String(join.leftSourceId || sources[0].id);
  const rightSourceId = String(join.rightSourceId || sources[1].id);
  const left = sourceSpecById(sources, leftSourceId);
  const right = sourceSpecById(sources, rightSourceId);
  if (!left || !right) throw new Error("JOIN source is not selected");
  const leftKey = Number(join.leftColumnIndex);
  const rightKey = Number(join.rightColumnIndex);
  if (!Number.isFinite(leftKey) || !Number.isFinite(rightKey)) throw new Error("JOIN key columns are not selected");
  const joinType = ["left","inner"].includes(String(join.joinType || "inner")) ? String(join.joinType || "inner") : "inner";
  const requestedLimit = normalizeGraphJoinLimit(plan.maxRows || 0);

  let selectedFields = (Array.isArray(plan.selectedFields) ? plan.selectedFields : []).map(normalizeJoinFieldRef).filter(Boolean);
  if (!selectedFields.length) selectedFields = defaultJoinSelectedFields(sources, openedMap);
  selectedFields = selectedFields.filter(f => openedMap.get(f.sourceId)?.manifest?.columns?.[f.columnIndex]);
  if (!selectedFields.length) throw new Error("No output columns are selected for JOIN");

  const rightHash = await buildJoinSideHash(openedMap.get(right.id), right.id, rightKey, selectedFields);
  const leftFields = selectedFields.filter(f => f.sourceId === left.id);
  const leftRequired = [...new Set([leftKey, ...leftFields.map(f => f.columnIndex)].filter(Number.isFinite))];
  const rows=[];
  let scanned=0, matched=0, capped=false;
  const leftOpened = openedMap.get(left.id);
  post("PROGRESS", {value:72, text:`JOIN probing ${left.alias} against ${right.alias}...`});

  outer:
  for (let c=0; c<(leftOpened.chunks || []).length; c++){
    if (state.cancelled) throw new Error("Cancelled");
    const chunk = await readStoredDatasetChunkColumns(leftOpened, c, leftRequired);
    for (let r=0; r<chunk.rowCount; r++){
      scanned++;
      const key = valueFromColumn(chunk.columns.get(leftKey), r);
      const matches = key === "" || key == null ? null : rightHash.map.get(String(key));
      const leftPayload = payloadFromChunk(left.id, chunk, r, leftFields);
      if (matches && matches.length){
        for (const rp of matches){
          rows.push(rowFromPayloads(selectedFields, [leftPayload, rp]));
          matched++;
          if (rows.length >= requestedLimit){ capped=true; break outer; }
        }
      } else if (joinType === "left"){
        rows.push(rowFromPayloads(selectedFields, [leftPayload, rightHash.blank]));
        if (rows.length >= requestedLimit){ capped=true; break outer; }
      }
    }
    if (c % 5 === 0) post("PROGRESS", {value:72 + Math.min(25, Math.floor((c+1)/Math.max(1, leftOpened.chunks.length)*25)), text:`JOIN probing chunks... ${c+1}/${leftOpened.chunks.length} / rows ${fmt(rows.length)}`});
  }

  const header = joinOutputHeader(selectedFields, sources, openedMap);
  state.graphJoinResult = {header, rows, plan, sources, selectedFields, totalMatches:rows.length, capped, scanned, matched, ms:now()-t0};
  const ps = Number(pageSize || 500);
  return {
    active:true,
    matches:rows.length,
    totalMatches:rows.length,
    capped,
    scanned,
    matched,
    rightIndexed:rightHash.rows,
    header,
    rows:rows.slice(0, ps),
    startRow:0,
    page:1,
    pageSize:ps,
    joinType,
    ms:now()-t0
  };
}

async function readGraphJoinPage(page,pageSize,origin=""){
  if (!state.graphJoinResult) throw new Error("Graph JOIN result is not active");
  const total = state.graphJoinResult.rows.length;
  const start = Math.max(0, (Number(page || 1)-1) * Number(pageSize || 500));
  const rows = state.graphJoinResult.rows.slice(start, start + Number(pageSize || 500));
  return {header:state.graphJoinResult.header, rows, startRow:start, totalMatches:total, page:Number(page||1), pageSize:Number(pageSize||500), ms:state.graphJoinResult.ms || 0, origin};
}

function makeAgg(){ return {count:0,n:0,sum:0,min:null,max:null}; }
function addAgg(a, v, countMode){
  a.count++;
  if (countMode) return;
  const n=Number(v);
  if (Number.isFinite(n)){ a.n++; a.sum+=n; a.min=a.min==null?n:Math.min(a.min,n); a.max=a.max==null?n:Math.max(a.max,n); }
}
function aggValue(a,mode){
  if (!a) return "";
  if (mode==="Count") return a.count;
  if (mode==="Sum") return a.n ? Math.round(a.sum*1e6)/1e6 : "";
  if (mode==="Average") return a.n ? Math.round((a.sum/a.n)*1e6)/1e6 : "";
  if (mode==="Min") return a.n ? a.min : "";
  if (mode==="Max") return a.n ? a.max : "";
  return a.count;
}
function keyCellValue(v){
  return v === "" || v == null || (typeof v === "number" && Number.isNaN(v))
    ? "(blank)"
    : String(v);
}
function keyOf(parts){
  return parts.length ? JSON.stringify(parts.map(keyCellValue)) : JSON.stringify(["(All)"]);
}
function splitKey(k){
  try {
    const arr = JSON.parse(k);
    return Array.isArray(arr) ? arr.map(v => String(v)) : [String(arr)];
  } catch {
    return String(k).split("\u001f");
  }
}

const PIVOT_TILE_ROWS = 64;
const PIVOT_TILE_COLS = 32;

function pivotColumnLabel(key, colIdx){
  return colIdx.length ? splitKey(key).join(" / ") : "Value";
}

function pivotRowLabelParts(key){
  return splitKey(key);
}

async function buildPivot({rowFields,columnFields,valueField,aggregation,maxRows,maxCols}){
  const rowIdx=(rowFields||[]).map(Number).filter(i => state.manifest?.columns?.[i]);
  const colIdx=(columnFields||[]).map(Number).filter(i => state.manifest?.columns?.[i]);
  const valIdx=Number(valueField);
  const countMode = !Number.isFinite(valIdx) || valIdx < 0 || !state.manifest?.columns?.[valIdx];
  const mode=countMode?"Count":aggregation;
  const rowLimit=Math.max(1, Number(maxRows || 1000000));
  const colLimit=Math.max(1, Number(maxCols || 10000));
  const required=[...new Set([...rowIdx,...colIdx,...(countMode?[]:[valIdx])])];
  const plan=buildQueryPlan({
    name:"pivotTile",
    projection:required,
    pushdown:true
  });
  plan.aggregate={
    type:"pivot",
    rowIdx,
    colIdx,
    valIdx:countMode ? -1 : valIdx,
    countMode,
    mode,
    rowLimit,
    colLimit
  };

  state.pivotTable=null;
  state.pivotTileIndex=null;

  const exec=await executeChunkExecutionPlanMaybeParallel(plan,{
    collectPartials:true,
    progressLabel:"Pivot distributed reduce",
    progressEvery:1,
    progressText:(ctx)=>`Pivot distributed reduce... ${ctx.position+1}/${ctx.totalChunks} / rows ${fmt(ctx.scanned)} / partials ${fmt(ctx.partials.length)}`
  });

  const reduced=mergePivotAggregatePartials(exec.partials,{rowLimit,colLimit});
  const rowHeaderNames = rowIdx.length ? rowIdx.map(i=>state.manifest.columns[i].name) : ["Rows"];
  const colHeaderNames = colIdx.length ? colIdx.map(i=>state.manifest.columns[i].name) : ["Columns"];

  state.pivotTileIndex={
    rowKeys:reduced.rowKeys,
    colKeys:reduced.colKeys,
    cells:reduced.cells,
    rowTotals:reduced.rowTotals,
    colTotals:reduced.colTotals,
    grand:reduced.grand,
    mode,
    countMode,
    rowIdx,
    colIdx,
    valueField:countMode ? -1 : valIdx,
    rowHeaderNames,
    colHeaderNames,
    tileRows:PIVOT_TILE_ROWS,
    tileCols:PIVOT_TILE_COLS,
    scanned:exec.scanned,
    limitHit:reduced.limitHit || exec.capped,
    queryPlan:exec.queryPlan,
    ms:exec.ms,
    executionEngine:{
      version:exec.engineVersion,
      mode:exec.executionMode || "single-worker",
      workerPoolVersion:exec.workerPoolVersion || null,
      workers:exec.workerCount || 1,
      distributedAggregateReduceVersion:CHUNK_DISTRIBUTED_AGG_VERSION,
      taskId:exec.taskId,
      chunks:exec.chunks.length
    },
    builtAt:new Date().toISOString()
  };

  return pivotTileMeta();
}

function pivotTileMeta(){
  const p=state.pivotTileIndex;
  if (!p) throw new Error("Pivot tile index is empty");
  return {
    totalRows:p.rowKeys.length + 1,
    totalDataRows:p.rowKeys.length,
    totalCols:p.colKeys.length + 1,
    totalDataCols:p.colKeys.length,
    tileRows:p.tileRows,
    tileCols:p.tileCols,
    rowHeaderNames:p.rowHeaderNames,
    colHeaderNames:p.colHeaderNames,
    mode:p.mode,
    scanned:p.scanned,
    limitHit:p.limitHit,
    queryPlan:p.queryPlan,
    executionEngine:p.executionEngine || null,
    ms:p.ms,
    builtAt:p.builtAt
  };
}

function pivotCellValue(rowIndex, colIndex){
  const p=state.pivotTileIndex;
  if (!p) return "";
  const isGrandRow = rowIndex >= p.rowKeys.length;
  const isGrandCol = colIndex >= p.colKeys.length;
  if (isGrandRow && isGrandCol) return aggValue(p.grand, p.mode);
  if (isGrandRow){
    const ck=p.colKeys[colIndex];
    return aggValue(p.colTotals.get(ck), p.mode);
  }
  if (isGrandCol){
    const rk=p.rowKeys[rowIndex];
    return aggValue(p.rowTotals.get(rk), p.mode);
  }
  const rk=p.rowKeys[rowIndex];
  const ck=p.colKeys[colIndex];
  return aggValue((p.cells.get(rk)||new Map()).get(ck), p.mode);
}

function pivotRowLabel(rowIndex){
  const p=state.pivotTileIndex;
  if (!p) return [""];
  if (rowIndex >= p.rowKeys.length) return ["Grand Total"];
  return pivotRowLabelParts(p.rowKeys[rowIndex]);
}

function pivotColLabel(colIndex){
  const p=state.pivotTileIndex;
  if (!p) return [""];
  if (colIndex >= p.colKeys.length) return ["Grand Total"];
  return [pivotColumnLabel(p.colKeys[colIndex], p.colIdx)];
}

function readPivotViewport({rowStart=0,colStart=0,viewportRows=90,viewportCols=40,overscan=1}={}){
  const p=state.pivotTileIndex;
  if (!p) throw new Error("Pivot tile index is empty");
  const meta=pivotTileMeta();
  const totalRows=meta.totalRows, totalCols=meta.totalCols;
  const safeRows=Math.max(1, Math.min(240, Number(viewportRows || 90)));
  const safeCols=Math.max(1, Math.min(120, Number(viewportCols || 40)));
  const extra=Math.max(0, Math.min(3, Number(overscan || 0)));
  const rs=Math.max(0, Math.min(totalRows-1, Math.floor(Number(rowStart || 0))));
  const cs=Math.max(0, Math.min(totalCols-1, Math.floor(Number(colStart || 0))));
  const re=Math.min(totalRows, rs + safeRows);
  const ce=Math.min(totalCols, cs + safeCols);
  const tileY0=Math.max(0, Math.floor(rs/p.tileRows)-extra);
  const tileY1=Math.min(Math.floor((totalRows-1)/p.tileRows), Math.floor(Math.max(rs,re-1)/p.tileRows)+extra);
  const tileX0=Math.max(0, Math.floor(cs/p.tileCols)-extra);
  const tileX1=Math.min(Math.floor((totalCols-1)/p.tileCols), Math.floor(Math.max(cs,ce-1)/p.tileCols)+extra);
  const tiles=[];

  for (let ty=tileY0; ty<=tileY1; ty++){
    const row0=ty*p.tileRows;
    const row1=Math.min(totalRows,row0+p.tileRows);
    const rowLabels=[];
    for (let r=row0; r<row1; r++) rowLabels.push(pivotRowLabel(r));
    for (let tx=tileX0; tx<=tileX1; tx++){
      const col0=tx*p.tileCols;
      const col1=Math.min(totalCols,col0+p.tileCols);
      const colLabels=[];
      for (let c=col0; c<col1; c++) colLabels.push(pivotColLabel(c));
      const values=[];
      for (let r=row0; r<row1; r++){
        const row=[];
        for (let c=col0; c<col1; c++) row.push(pivotCellValue(r,c));
        values.push(row);
      }
      tiles.push({tileY:ty,tileX:tx,rowStart:row0,rowEnd:row1,colStart:col0,colEnd:col1,rowLabels,colLabels,values});
    }
  }

  return {...meta,rowStart:rs,rowEnd:re,colStart:cs,colEnd:ce,tileY0,tileY1,tileX0,tileX1,tiles,generatedAt:now()};
}

function exportPivotCsvFromTileIndex(){
  const p=state.pivotTileIndex;
  if (!p) throw new Error("Pivot tile index is empty");
  const header=[...p.rowHeaderNames, ...p.colKeys.map(k=>pivotColumnLabel(k,p.colIdx)), "Grand Total"];
  const lines=[header.map(csvEscape).join(",")];
  for (let r=0; r<p.rowKeys.length; r++){
    const row=[...pivotRowLabel(r)];
    while(row.length < p.rowHeaderNames.length) row.push("");
    for (let c=0; c<p.colKeys.length; c++) row.push(pivotCellValue(r,c));
    row.push(pivotCellValue(r,p.colKeys.length));
    lines.push(row.map(csvEscape).join(","));
  }
  const grand=["Grand Total"];
  while(grand.length < p.rowHeaderNames.length) grand.push("");
  for (let c=0; c<p.colKeys.length; c++) grand.push(pivotCellValue(p.rowKeys.length,c));
  grand.push(pivotCellValue(p.rowKeys.length,p.colKeys.length));
  lines.push(grand.map(csvEscape).join(","));
  return lines.join("\n");
}


function parseTimeBucket(value, bucket){
  if (value == null || value === "") return null;
  let s = String(value).trim();
  if (!s) return null;

  // Normalize common Japanese/date separators.
  s = s
    .replace(/[年月]/g, "-")
    .replace(/[日]/g, "")
    .replace(/\//g, "-")
    .replace("T", " ");

  let d = new Date(s);
  if (Number.isNaN(d.getTime())) {
    // YYYYMMDD or YYYYMMDDHHMMSS fallback.
    const m = s.match(/^(\d{4})(\d{2})(\d{2})(\d{2})?(\d{2})?(\d{2})?/);
    if (m) {
      d = new Date(
        Number(m[1]),
        Number(m[2]) - 1,
        Number(m[3]),
        Number(m[4] || 0),
        Number(m[5] || 0),
        Number(m[6] || 0)
      );
    }
  }
  if (Number.isNaN(d.getTime())) return null;

  const y = d.getFullYear();
  const mo = String(d.getMonth() + 1).padStart(2, "0");
  const da = String(d.getDate()).padStart(2, "0");
  const h = String(d.getHours()).padStart(2, "0");

  if (bucket === "year") return `${y}`;
  if (bucket === "month") return `${y}-${mo}`;
  if (bucket === "day") return `${y}-${mo}-${da}`;
  if (bucket === "hour") return `${y}-${mo}-${da} ${h}:00`;
  return `${y}-${mo}`;
}

async function buildTimeSeries({timeField, bucket, groupField, valueField, aggregation, maxBuckets}){
  const timeIdx = Number(timeField);
  const groupIdx = Number(groupField);
  const valIdx = Number(valueField);
  const hasGroup = Number.isFinite(groupIdx) && groupIdx >= 0 && !!state.manifest.columns[groupIdx];
  const countMode = !Number.isFinite(valIdx) || valIdx < 0 || !state.manifest.columns[valIdx];
  const mode = countMode ? "Count" : aggregation;
  const required = [...new Set([timeIdx, ...(hasGroup ? [groupIdx] : []), ...(countMode ? [] : [valIdx])])];

  if (!state.manifest.columns[timeIdx]) throw new Error("Time field is not selected");
  const bucketLimit = Math.max(1, Number(maxBuckets || 5000));
  const plan=buildQueryPlan({
    name:"timeSeries",
    predicates:[{columnIndex:timeIdx, op:"notnull", value:"", rowLevel:false, source:"timeField"}],
    projection:required,
    pushdown:true
  });
  plan.aggregate={
    type:"timeSeries",
    timeIdx,
    bucket:bucket || "month",
    groupIdx:hasGroup ? groupIdx : -1,
    valIdx:countMode ? -1 : valIdx,
    hasGroup,
    countMode,
    mode,
    bucketLimit
  };

  const exec=await executeChunkExecutionPlanMaybeParallel(plan,{
    collectPartials:true,
    progressLabel:"Time distributed reduce",
    progressEvery:1,
    progressText:(ctx)=>`Time distributed reduce... ${ctx.position+1}/${ctx.totalChunks} / skipped ${fmt(ctx.skippedChunks)} / rows ${fmt(ctx.scanned)} / partials ${fmt(ctx.partials.length)}`
  });

  const reduced=mergeTimeSeriesAggregatePartials(exec.partials,{bucketLimit});
  const header = hasGroup ? ["Time", "Group", mode] : ["Time", mode];
  const rows = [...reduced.states.entries()].sort((a,b)=>a[0].localeCompare(b[0])).map(([key, agg])=>{
    let b = "", g = "";
    try { [b, g] = JSON.parse(key); } catch { [b, g] = String(key).split("\u001f"); }
    return hasGroup ? [b, g, aggValue(agg, mode)] : [b, aggValue(agg, mode)];
  });

  state.timeTable = {header, rows};
  return {
    header,
    rows,
    scanned:exec.scanned,
    invalidTime:reduced.invalidTime,
    limitHit:reduced.limitHit || exec.capped,
    skippedChunks:exec.skippedChunks,
    queryPlan:exec.queryPlan,
    executionEngine:{
      version:exec.engineVersion,
      mode:exec.executionMode || "single-worker",
      workerPoolVersion:exec.workerPoolVersion || null,
      workers:exec.workerCount || 1,
      distributedAggregateReduceVersion:CHUNK_DISTRIBUTED_AGG_VERSION,
      taskId:exec.taskId,
      chunks:exec.chunks.length
    },
    ms:exec.ms
  };
}


function csvEscape(v){
  if (v == null) return "";
  let s=String(v).replaceAll('"','""');
  return /[",\r\n]/.test(s) ? `"${s}"` : s;
}


const GRAPH_DERIVED_FORBIDDEN_WORKER = /\b(?:window|document|self|globalThis|Function|eval|fetch|XMLHttpRequest|WebSocket|Worker|importScripts|postMessage|navigator|localStorage|indexedDB|crypto|process|require)\b/;
const GRAPH_DERIVED_FN_CACHE_WORKER = new Map();

function normalizeGraphDerivedColumnsForWorker(items){
  return (Array.isArray(items) ? items : [])
    .map((d, i) => ({
      id:String(d?.id || `derived_${i+1}`),
      newColumnName:String(d?.newColumnName || d?.name || `new_column_${i+1}`).trim() || `new_column_${i+1}`,
      valueMode:String(d?.valueMode || "constant"),
      constantValue:d?.constantValue ?? "",
      formulaExpression:String(d?.formulaExpression || "")
    }))
    .filter((d) => d.newColumnName);
}

function valueByFlexibleNameForWorker(rowMap, key){
  if (rowMap == null) return undefined;
  if (Object.prototype.hasOwnProperty.call(rowMap, key)) return rowMap[key];
  const lower = String(key || "").toLowerCase();
  const found = Object.keys(rowMap).find((k) => String(k).toLowerCase() === lower);
  return found == null ? undefined : rowMap[found];
}

function evaluateGraphDerivedColumnForWorker(d, rowMap){
  try{
    if ((d.valueMode || "constant") !== "formula") return d.constantValue ?? "";
    const expr = String(d.formulaExpression || "").trim();
    if (!expr) return "";
    if (GRAPH_DERIVED_FORBIDDEN_WORKER.test(expr)) return "#BLOCKED";
    const col = (name) => valueByFlexibleNameForWorker(rowMap, name);
    const num = (v, fallback=0) => {
      const n = Number(v);
      return Number.isFinite(n) ? n : fallback;
    };
    const str = (v) => v == null ? "" : String(v);
    const concat = (...xs) => xs.map((x) => x == null ? "" : String(x)).join("");
    const coalesce = (...xs) => xs.find((x) => x !== null && x !== undefined && x !== "") ?? "";
    const lower = (v) => str(v).toLowerCase();
    const upper = (v) => str(v).toUpperCase();
    const round = (v, digits=0) => {
      const m = Math.pow(10, Number(digits) || 0);
      return Math.round(num(v) * m) / m;
    };

    const splitText = (v, sep="/") => str(v).split(sep);
    const pathParts = (v) => str(v).replace(/\\+/g,"/").split("/").filter(Boolean);
    const pathPart = (v, index=0) => {
      const parts = pathParts(v);
      let i = Number(index) || 0;
      if (i < 0) i = parts.length + i;
      return parts[i] ?? "";
    };
    const basename = (v) => {
      const parts = pathParts(v);
      return parts.length ? parts[parts.length - 1] : "";
    };
    const filename = basename;
    const dirname = (v) => {
      const s = str(v).replace(/\\+/g,"/");
      const p = s.lastIndexOf("/");
      return p >= 0 ? s.slice(0, p) : "";
    };
    const ext = (v) => {
      const b = basename(v);
      const p = b.lastIndexOf(".");
      return p > 0 ? b.slice(p + 1) : "";
    };
    const extname = (v) => {
      const e = ext(v);
      return e ? `.${e}` : "";
    };
    const stem = (v) => {
      const b = basename(v);
      const p = b.lastIndexOf(".");
      return p > 0 ? b.slice(0, p) : b;
    };
    const before = (v, mark) => {
      const s = str(v), m = str(mark);
      const p = s.indexOf(m);
      return p >= 0 ? s.slice(0, p) : "";
    };
    const after = (v, mark) => {
      const s = str(v), m = str(mark);
      const p = s.indexOf(m);
      return p >= 0 ? s.slice(p + m.length) : "";
    };
    const between = (v, start, end) => {
      const a = after(v, start);
      return a ? before(a, end) : "";
    };
    const sliceText = (v, start=0, end=undefined) => str(v).slice(Number(start)||0, end == null ? undefined : Number(end));
    const left = (v, n=1) => str(v).slice(0, Math.max(0, Number(n)||0));
    const right = (v, n=1) => {
      const s = str(v);
      return s.slice(Math.max(0, s.length - (Number(n)||0)));
    };
    const replaceText = (v, search, replacement="") => str(v).split(str(search)).join(str(replacement));
    const regexExtract = (v, pattern, group=1, flags="") => {
      try{
        const re = new RegExp(String(pattern), String(flags).replace(/[^gimsuy]/g,""));
        const m = re.exec(str(v));
        return m ? (m[Number(group)||0] ?? "") : "";
      }catch{ return ""; }
    };
    let fn = GRAPH_DERIVED_FN_CACHE_WORKER.get(expr);
    if (!fn) {
      fn = new Function(
        "col", "num", "str", "concat", "coalesce", "lower", "upper", "round", "abs", "min", "max", "row",
        "split", "part", "pathParts", "pathPart", "basename", "filename", "dirname", "ext", "extname", "stem",
        "before", "after", "between", "sliceText", "left", "right", "replaceText", "regexExtract",
        `"use strict"; return (${expr});`
      );
      if (GRAPH_DERIVED_FN_CACHE_WORKER.size > 100) GRAPH_DERIVED_FN_CACHE_WORKER.clear();
      GRAPH_DERIVED_FN_CACHE_WORKER.set(expr, fn);
    }
    const value = fn(
      col, num, str, concat, coalesce, lower, upper, round, Math.abs, Math.min, Math.max, rowMap,
      splitText, pathPart, pathParts, pathPart, basename, filename, dirname, ext, extname, stem,
      before, after, between, sliceText, left, right, replaceText, regexExtract
    );
    return value == null ? "" : value;
  }catch(e){
    return `#ERR ${e?.message || "formula"}`;
  }
}

function graphExportHeader(header, derivedColumns, outputColumnNames=null){
  const derived = normalizeGraphDerivedColumnsForWorker(derivedColumns);
  const full = [...(header || []), ...derived.map((d) => d.newColumnName)];
  const desired = Array.isArray(outputColumnNames) && outputColumnNames.length
    ? [...outputColumnNames.map(String), ...derived.map((d) => d.newColumnName)]
    : null;
  if (!desired) return full;
  const used = new Set();
  const out = [];
  for (const name of desired){
    const idx = full.findIndex((h, i) => !used.has(i) && String(h) === String(name));
    if (idx >= 0){ used.add(idx); out.push(full[idx]); }
  }
  return out.length ? out : full;
}

function graphExportIndexesForHeader(header, derivedColumns, outputColumnNames=null){
  const full = graphExportHeader(header, derivedColumns, null);
  const outHeader = graphExportHeader(header, derivedColumns, outputColumnNames);
  const used = new Set();
  return outHeader.map((name) => {
    const idx = full.findIndex((h, i) => !used.has(i) && String(h) === String(name));
    if (idx >= 0) used.add(idx);
    return idx;
  }).filter((idx) => idx >= 0);
}

function appendRowsToCsvLines(lines, header, rows, derivedColumns, outputColumnNames=null){
  const derived = normalizeGraphDerivedColumnsForWorker(derivedColumns);
  const indexes = graphExportIndexesForHeader(header, derivedColumns, outputColumnNames);
  const useProjection = Array.isArray(outputColumnNames) && outputColumnNames.length && indexes.length;
  if (!derived.length){
    for (const row of rows || []){
      const fullRow = row || [];
      const outRow = useProjection ? indexes.map((idx) => fullRow?.[idx] ?? "") : fullRow;
      lines.push(outRow.map(csvEscape).join(","));
    }
    return;
  }
  for (const row of rows || []){
    const rowMap = {};
    header.forEach((h, i) => { rowMap[h] = row?.[i]; });
    const extra = derived.map((d) => evaluateGraphDerivedColumnForWorker(d, rowMap));
    const fullRow = [...(row || []), ...extra];
    const outRow = useProjection ? indexes.map((idx) => fullRow?.[idx] ?? "") : fullRow;
    lines.push(outRow.map(csvEscape).join(","));
  }
}

function normalizeExportLimit(value){
  const n = Number(value || 0);
  return Number.isFinite(n) && n > 0 ? Math.floor(n) : Number.POSITIVE_INFINITY;
}

async function exportGraphQueryCsv(msg={}){
  const mode = String(msg.mode || "data");
  const derivedColumns = normalizeGraphDerivedColumnsForWorker(msg.derivedColumns || []);
  const outputColumnNames = Array.isArray(msg.outputColumnNames) ? msg.outputColumnNames.map(String).filter(Boolean) : null;
  const maxRows = normalizeExportLimit(msg.maxRows);
  const chunkRows = Math.max(100, Math.min(10000, Number(msg.chunkRows || 3000)));
  const lines = [];
  let exportedRows = 0;
  const t0 = now();

  if (mode === "join"){
    if (!state.graphJoinResult) throw new Error("Graph JOIN result is not active");
    const header = state.graphJoinResult.header || [];
    lines.push(graphExportHeader(header, derivedColumns, outputColumnNames).map(csvEscape).join(","));
    const rows = state.graphJoinResult.rows || [];
    const total = Math.min(rows.length, maxRows);
    for (let start=0; start<total; start+=chunkRows){
      if (state.cancelled) throw new Error("Cancelled");
      appendRowsToCsvLines(lines, header, rows.slice(start, Math.min(total, start + chunkRows)), derivedColumns, outputColumnNames);
      exportedRows = Math.min(total, start + chunkRows);
      post("PROGRESS", {value:Math.min(99, Math.floor((exportedRows / Math.max(1,total)) * 100)), text:`Exporting Graph JOIN CSV... ${fmt(exportedRows)}/${fmt(total)} rows`});
    }
    return {csv:lines.join("\n"), rows:exportedRows, totalRows:rows.length, mode, ms:now()-t0};
  }

  const selected = normalizeCols(Array.isArray(msg.columns) && msg.columns.length ? msg.columns : (state.dataQueryMeta?.projection || []));
  const header = selected.map(i => state.manifest.columns[i].name);
  lines.push(graphExportHeader(header, derivedColumns, outputColumnNames).map(csvEscape).join(","));

  if (Array.isArray(state.dataQueryMatches)){
    const total = Math.min(state.dataQueryMatches.length, maxRows);
    for (let start=0; start<total; start+=chunkRows){
      if (state.cancelled) throw new Error("Cancelled");
      const ids = state.dataQueryMatches.slice(start, Math.min(total, start + chunkRows));
      const table = await readRowsByGlobal(ids, selected);
      appendRowsToCsvLines(lines, table.header, table.rows, derivedColumns, outputColumnNames);
      exportedRows = Math.min(total, start + chunkRows);
      post("PROGRESS", {value:Math.min(99, Math.floor((exportedRows / Math.max(1,total)) * 100)), text:`Exporting Graph Query CSV... ${fmt(exportedRows)}/${fmt(total)} rows`});
    }
    return {csv:lines.join("\n"), rows:exportedRows, totalRows:state.dataQueryMatches.length, mode, ms:now()-t0};
  }

  const totalRows = Math.min(Number(state.manifest?.totalRows || 0), maxRows);
  for (let start=0; start<totalRows; start+=chunkRows){
    if (state.cancelled) throw new Error("Cancelled");
    const page = Math.floor(start / chunkRows) + 1;
    const table = await readPage(page, Math.min(chunkRows, totalRows - start), selected);
    appendRowsToCsvLines(lines, table.header, table.rows, derivedColumns, outputColumnNames);
    exportedRows = Math.min(totalRows, start + chunkRows);
    post("PROGRESS", {value:Math.min(99, Math.floor((exportedRows / Math.max(1,totalRows)) * 100)), text:`Exporting Graph Query CSV... ${fmt(exportedRows)}/${fmt(totalRows)} rows`});
  }
  return {csv:lines.join("\n"), rows:exportedRows, totalRows:Number(state.manifest?.totalRows || 0), mode, ms:now()-t0};
}



// Graph Query Result as a temporary, non-persisted dataset for Search / Pivot / Time.
// The result itself is not stored; each analysis reads the latest Graph Result lazily.
function graphApplyDerivedRows(header, rows, derivedColumns=[], outputColumnNames=null){
  const derived = normalizeGraphDerivedColumnsForWorker(derivedColumns);
  const fullHeader = graphExportHeader(header, derived, null);
  const outHeader = graphExportHeader(header, derived, outputColumnNames);
  const indexes = graphExportIndexesForHeader(header, derived, outputColumnNames);
  const useProjection = Array.isArray(outputColumnNames) && outputColumnNames.length && indexes.length;
  if (!derived.length){
    return {header: useProjection ? outHeader : fullHeader, rows: (rows || []).map((row)=> useProjection ? indexes.map((idx)=> row?.[idx] ?? "") : row)};
  }
  const outRows=[];
  for (const row of rows || []){
    const rowMap={};
    header.forEach((h,i)=>{ rowMap[h]=row?.[i]; });
    const extra=derived.map((d)=>evaluateGraphDerivedColumnForWorker(d,rowMap));
    const full=[...(row || []), ...extra];
    outRows.push(useProjection ? indexes.map((idx)=>full?.[idx] ?? "") : full);
  }
  return {header: useProjection ? outHeader : fullHeader, rows:outRows};
}

function graphResultTotalRows(mode){
  if (mode === "join") return Number(state.graphJoinResult?.rows?.length || 0);
  if (Array.isArray(state.dataQueryMatches)) return Number(state.dataQueryMatches.length || 0);
  return Number(state.manifest?.totalRows || 0);
}

async function readGraphResultWindow({mode="data", page=1, pageSize=1000, columns=[], derivedColumns=[], outputColumnNames=null}={}){
  const safePage=Math.max(1, Number(page || 1));
  const safePageSize=Math.max(1, Math.min(50000, Number(pageSize || 1000)));
  const start=Math.max(0,(safePage-1)*safePageSize);
  const total=graphResultTotalRows(mode);
  let header=[], rows=[];
  if (mode === "join"){
    if (!state.graphJoinResult) throw new Error("Graph JOIN result is not active");
    header=state.graphJoinResult.header || [];
    rows=(state.graphJoinResult.rows || []).slice(start, start + safePageSize);
  } else {
    if (!state.manifest) throw new Error("Active dataset is not open");
    const selected=normalizeCols(Array.isArray(columns) && columns.length ? columns : (state.dataQueryMeta?.projection || []));
    if (Array.isArray(state.dataQueryMatches)){
      const ids=state.dataQueryMatches.slice(start, start + safePageSize);
      const table=await readRowsByGlobal(ids, selected);
      header=table.header; rows=table.rows;
    } else {
      const table=await readPage(safePage, safePageSize, selected);
      header=table.header; rows=table.rows;
    }
  }
  const applied=graphApplyDerivedRows(header, rows, derivedColumns, outputColumnNames);
  return {...applied, startRow:start, totalMatches:total, page:safePage, pageSize:safePageSize};
}

async function runGraphResultSearch(msg={}){
  const mode=String(msg.mode || "data");
  const colIndex=Number(msg.columnIndex || 0);
  const op=msg.op || "contains";
  const value=msg.value ?? "";
  const cap=normalizePlanLimit(msg.maxMatches || 100000);
  const chunkRows=Math.max(500, Math.min(20000, Number(msg.chunkRows || 5000)));
  const total=graphResultTotalRows(mode);
  const matched=[];
  let header=[];
  const t0=now();
  for (let start=0; start<total; start+=chunkRows){
    if (state.cancelled) throw new Error("Cancelled");
    const page=Math.floor(start/chunkRows)+1;
    const table=await readGraphResultWindow({...msg, mode, page, pageSize:Math.min(chunkRows, total-start)});
    if (!header.length) header=table.header;
    const type="string";
    for (let i=0;i<table.rows.length;i++){
      const row=table.rows[i] || [];
      if (compareValue(row[colIndex], op, value, type)){
        matched.push({rowNumber:start+i+1,row});
        if (matched.length >= cap) break;
      }
    }
    post("PROGRESS", {value:Math.min(99, Math.floor(((start+table.rows.length)/Math.max(1,total))*100)), text:`Graph Result search... ${fmt(start+table.rows.length)}/${fmt(total)} / matches ${fmt(matched.length)}`});
    if (matched.length >= cap) break;
    if (start % (chunkRows*4) === 0) await workerYield();
  }
  state.graphResultSearch={header:["Result Row", ...header], rows:matched.map(x=>[x.rowNumber, ...x.row]), totalSourceRows:total, capped:matched.length >= cap, ms:now()-t0};
  return {matches:matched.length,totalSourceRows:total,capped:matched.length >= cap,header:state.graphResultSearch.header,rows:state.graphResultSearch.rows.slice(0,Math.min(500,Number(msg.pageSize||500))),ms:state.graphResultSearch.ms};
}

function readGraphResultSearchPage(page=1,pageSize=500){
  if (!state.graphResultSearch) throw new Error("Graph Result search is not active");
  const safePage=Math.max(1,Number(page||1));
  const safeSize=Math.max(1,Number(pageSize||500));
  const start=(safePage-1)*safeSize;
  return {header:state.graphResultSearch.header, rows:state.graphResultSearch.rows.slice(start,start+safeSize), page:safePage, pageSize:safeSize, totalMatches:state.graphResultSearch.rows.length, startRow:start, ms:state.graphResultSearch.ms};
}

async function buildGraphResultPivot(msg={}){
  const mode=String(msg.mode || "data");
  const rowFields=(msg.rowFields||[]).map(Number).filter(Number.isFinite);
  const columnFields=(msg.columnFields||[]).map(Number).filter(Number.isFinite);
  const valIdx=Number(msg.valueField);
  const countMode=!Number.isFinite(valIdx) || valIdx < 0;
  const aggMode=countMode ? "Count" : (msg.aggregation || "Count");
  const rowLimit=Math.max(1,Number(msg.maxRows||10000));
  const colLimit=Math.max(1,Number(msg.maxCols||1000));
  const chunkRows=Math.max(500, Math.min(20000, Number(msg.chunkRows || 5000)));
  const total=graphResultTotalRows(mode);
  let header=[];
  const rowKeys=[], colKeys=[], rowSet=new Set(), colSet=new Set(), cells=new Map(), rowTotals=new Map(), colTotals=new Map();
  const grand=makeAgg();
  let limitHit=false, scanned=0;
  const t0=now();
  for (let start=0; start<total; start+=chunkRows){
    if (state.cancelled) throw new Error("Cancelled");
    const page=Math.floor(start/chunkRows)+1;
    const table=await readGraphResultWindow({...msg, mode, page, pageSize:Math.min(chunkRows,total-start)});
    if (!header.length) header=table.header;
    for (const row of table.rows){
      scanned++;
      const rParts=rowFields.length ? rowFields.map(i=>row?.[i]) : ["(All)"];
      const cParts=columnFields.length ? columnFields.map(i=>row?.[i]) : ["Value"];
      const rk=keyOf(rParts), ck=keyOf(cParts);
      if (!rowSet.has(rk)){
        if (rowKeys.length >= rowLimit){ limitHit=true; continue; }
        rowSet.add(rk); rowKeys.push(rk);
      }
      if (!colSet.has(ck)){
        if (colKeys.length >= colLimit){ limitHit=true; continue; }
        colSet.add(ck); colKeys.push(ck);
      }
      if (!cells.has(rk)) cells.set(rk,new Map());
      const rowMap=cells.get(rk);
      if (!rowMap.has(ck)) rowMap.set(ck,makeAgg());
      if (!rowTotals.has(rk)) rowTotals.set(rk,makeAgg());
      if (!colTotals.has(ck)) colTotals.set(ck,makeAgg());
      const v=countMode ? null : row?.[valIdx];
      addAgg(rowMap.get(ck),v,countMode); addAgg(rowTotals.get(rk),v,countMode); addAgg(colTotals.get(ck),v,countMode); addAgg(grand,v,countMode);
    }
    post("PROGRESS", {value:Math.min(99, Math.floor(((start+table.rows.length)/Math.max(1,total))*100)), text:`Graph Result pivot... ${fmt(start+table.rows.length)}/${fmt(total)} rows / groups ${fmt(rowKeys.length)} x ${fmt(colKeys.length)}`});
    if (start % (chunkRows*4) === 0) await workerYield();
  }
  const rowHeaderNames=rowFields.length ? rowFields.map(i=>header[i] || `Field ${i+1}`) : ["Rows"];
  const colLabels=colKeys.map(k=>pivotColumnLabel(k, columnFields));
  const outHeader=[...rowHeaderNames, ...colLabels, "Grand Total"];
  const outRows=[];
  for (const rk of rowKeys){
    const labels=pivotRowLabelParts(rk);
    while(labels.length < rowHeaderNames.length) labels.push("");
    const row=[...labels];
    const rowMap=cells.get(rk) || new Map();
    for (const ck of colKeys) row.push(aggValue(rowMap.get(ck),aggMode));
    row.push(aggValue(rowTotals.get(rk),aggMode));
    outRows.push(row);
  }
  const grandRow=["Grand Total"];
  while(grandRow.length < rowHeaderNames.length) grandRow.push("");
  for (const ck of colKeys) grandRow.push(aggValue(colTotals.get(ck),aggMode));
  grandRow.push(aggValue(grand,aggMode));
  outRows.push(grandRow);
  state.graphResultPivot={header:outHeader, rows:outRows, scanned, limitHit, ms:now()-t0};
  return state.graphResultPivot;
}

async function buildGraphResultTime(msg={}){
  const mode=String(msg.mode || "data");
  const timeIdx=Number(msg.timeField);
  const groupIdx=Number(msg.groupField);
  const valIdx=Number(msg.valueField);
  const hasGroup=Number.isFinite(groupIdx) && groupIdx >= 0;
  const countMode=!Number.isFinite(valIdx) || valIdx < 0;
  const aggMode=countMode ? "Count" : (msg.aggregation || "Count");
  const bucket=msg.bucket || "month";
  const bucketLimit=Math.max(1,Number(msg.maxBuckets||10000));
  const chunkRows=Math.max(500, Math.min(20000, Number(msg.chunkRows || 5000)));
  const total=graphResultTotalRows(mode);
  const states=new Map();
  let header=[], scanned=0, invalidTime=0, limitHit=false;
  const t0=now();
  for (let start=0; start<total; start+=chunkRows){
    if (state.cancelled) throw new Error("Cancelled");
    const page=Math.floor(start/chunkRows)+1;
    const table=await readGraphResultWindow({...msg, mode, page, pageSize:Math.min(chunkRows,total-start)});
    if (!header.length) header=table.header;
    for (const row of table.rows){
      scanned++;
      const b=parseTimeBucket(row?.[timeIdx], bucket);
      if (!b){ invalidTime++; continue; }
      const g=hasGroup ? keyCellValue(row?.[groupIdx]) : "";
      const key=JSON.stringify([b,g]);
      if (!states.has(key)){
        if (states.size >= bucketLimit){ limitHit=true; continue; }
        states.set(key,makeAgg());
      }
      addAgg(states.get(key), countMode ? null : row?.[valIdx], countMode);
    }
    post("PROGRESS", {value:Math.min(99, Math.floor(((start+table.rows.length)/Math.max(1,total))*100)), text:`Graph Result time... ${fmt(start+table.rows.length)}/${fmt(total)} rows / buckets ${fmt(states.size)}`});
    if (start % (chunkRows*4) === 0) await workerYield();
  }
  const outHeader=hasGroup ? ["Time", "Group", aggMode] : ["Time", aggMode];
  const outRows=[...states.entries()].sort((a,b)=>a[0].localeCompare(b[0])).map(([key,agg])=>{
    let b="", g=""; try{ [b,g]=JSON.parse(key); }catch{ [b,g]=String(key).split("\u001f"); }
    return hasGroup ? [b,g,aggValue(agg,aggMode)] : [b,aggValue(agg,aggMode)];
  });
  state.graphResultTime={header:outHeader, rows:outRows, scanned, invalidTime, limitHit, ms:now()-t0};
  return state.graphResultTime;
}

self.onmessage=async(e)=>{
  const msg=e.data||{};
  try{
    if (msg.type==="EXECUTE_CHUNK_BATCH"){
      state.cancelled=false;
      await hydrateChunkExecutionContext(msg.context);
      const result=await executeChunkExecutionPlan(msg.plan,{...(msg.options || {}),progress:false,parallel:false});
      post("CHUNK_BATCH_DONE",{requestId:msg.requestId,batchIndex:msg.batchIndex,result});
      return;
    }

    if (msg.type==="REMOTE_EXECUTION_CONFIG"){
      post("REMOTE_EXECUTION_STATUS", configureRemoteExecution(msg.config || msg));
      return;
    }

    if (msg.type==="REMOTE_EXECUTION_STATUS"){
      post("REMOTE_EXECUTION_STATUS", remoteExecutionStatus());
      return;
    }

    if (msg.type==="REMOTE_EXECUTION_PING"){
      post("REMOTE_EXECUTION_STATUS", await probeRemoteExecution(msg.config || {}));
      return;
    }

    if (msg.type==="EXTERNAL_STORAGE_CONFIG"){
      post("EXTERNAL_STORAGE_STATUS", configureExternalStorage(msg.config || msg));
      return;
    }

    if (msg.type==="EXTERNAL_STORAGE_TEST"){
      post("EXTERNAL_STORAGE_STATUS", await testExternalStorage(msg.config || {}));
      return;
    }

    if (msg.type==="EXTERNAL_STORAGE_LIST"){
      const datasets=await listExternalDatasets();
      post("EXTERNAL_STORAGE_LIST_DONE", {datasets, status:externalStorageStatus()});
      return;
    }

    if (msg.type==="EXTERNAL_STORAGE_SYNC"){
      state.cancelled=false;
      const result=await syncDatasetToExternal(msg.datasetId || state.dataset?.id || state.manifest?.id);
      const datasets=await listExternalDatasets().catch(()=>[]);
      post("EXTERNAL_STORAGE_SYNC_DONE", {...result,datasets});
      return;
    }

    if (msg.type==="EXTERNAL_STORAGE_OPEN"){
      state.cancelled=false;
      const opened=await openExternalDataset(msg.id || msg.datasetId);
      post("EXTERNAL_STORAGE_OPENED", opened);
      return;
    }

    if (msg.type==="OBSERVATION_ENGINE_CONFIG"){
      post("OBSERVATION_ENGINE_STATUS", configureObservationEngine(msg.config || msg));
      return;
    }

    if (msg.type==="OBSERVATION_ENGINE_STATUS"){
      post("OBSERVATION_ENGINE_STATUS", observationStatus());
      return;
    }

    if (msg.type==="HYBRID_SURFACE_CONFIG"){
      post("HYBRID_SURFACE_STATUS", configureHybridSurfaceBus(msg.config || msg));
      return;
    }

    if (msg.type==="HYBRID_SURFACE_STATUS"){
      post("HYBRID_SURFACE_STATUS", hybridSurfaceStatus());
      return;
    }

    if (msg.type==="HYBRID_SURFACE_CLEAR"){
      post("HYBRID_SURFACE_STATUS", surfaceClear());
      return;
    }

    if (msg.type==="ROW_SURFACE_STATUS"){
      post("ROW_SURFACE_STATUS", hybridSurfaceStatus({rowSurfaceOnly:true}));
      return;
    }

    if (msg.type==="ROW_SURFACE_CLEAR"){
      hybridSurfaceRuntime.rowSlabs.clear();
      hybridSurfaceRuntime.rowSlabBytes=0;
      post("ROW_SURFACE_STATUS", hybridSurfaceStatus({rowSurfaceCleared:true}));
      return;
    }

    if (msg.type==="ROW_SURFACE_PREFETCH"){
      const selected=normalizeCols(msg.columns || []);
      const start=Math.max(0,Number(msg.startRow ?? ((Number(msg.page || 1)-1) * Number(msg.pageSize || 500))));
      const result=await prefetchRowPageSurface(start,Number(msg.pageSize || 500),selected,{manual:true});
      post("ROW_SURFACE_PREFETCH_DONE",{...result,status:hybridSurfaceStatus()});
      return;
    }

    if (msg.type==="EXECUTION_PLANE_CONFIG"){
      post("EXECUTION_PLANE_STATUS", configureExecutionPlane(msg.config || msg));
      return;
    }

    if (msg.type==="EXECUTION_PLANE_STATUS"){
      post("EXECUTION_PLANE_STATUS", executionPlaneStatus());
      return;
    }

    if (msg.type==="ADAPTIVE_KERNEL_CONFIG"){
      post("ADAPTIVE_KERNEL_STATUS", configureAdaptiveKernel(msg.config || msg));
      return;
    }

    if (msg.type==="ADAPTIVE_KERNEL_STATUS"){
      post("ADAPTIVE_KERNEL_STATUS", adaptiveStatus({hyperTensorPlan:state.hyperTensor?.lastPlan ? operatorGraphSummary(state.hyperTensor.lastPlan) : null}));
      return;
    }

    if (msg.type==="ADAPTIVE_CACHE_CLEAR"){
      post("ADAPTIVE_KERNEL_STATUS", clearAdaptiveCaches());
      return;
    }

    if (msg.type==="HYPERTENSOR_PLAN_PREVIEW"){
      const previewPlan=buildQueryPlan(msg.plan || {name:"preview",predicates:[],projection:normalizeProjection(msg.projection || []),limit:msg.limit || 100});
      const graph=buildOperatorGraph(previewPlan);
      const oplan=buildObservationPlan(previewPlan);
      const cost=estimatePlanCost(previewPlan, oplan);
      const strategy=chooseAdaptiveStrategy(previewPlan, oplan, cost, msg.options || {});
      post("HYPERTENSOR_PLAN_PREVIEW_DONE", {operatorGraph:operatorGraphSummary(graph), observationPlan:observationPlanSummary(oplan), costModel:cost, adaptiveStrategy:strategy, executionPlane:chooseExecutionPlane(previewPlan,msg.options || {},strategy,cost), hybridSurface:hybridSurfaceStatus(), surfaceReadPlan:buildSurfaceReadPlan(oplan,strategy)});
      return;
    }

    if (msg.type==="ADAPTIVE_PERF_BENCH"){
      state.cancelled=false;
      post("PROGRESS", {value:0, text:"Running Adaptive HyperTensor PERF_BENCH..."});
      const result=await runAdaptivePerfBench(msg);
      post("ADAPTIVE_PERF_BENCH_DONE", result);
      post("PROGRESS", {value:100, text:"Adaptive PERF_BENCH complete"});
      return;
    }

    if (msg.type==="PERF_BENCH"){
      state.cancelled=false;
      post("PROGRESS", {value:0, text:"Running Observation PERF_BENCH..."});
      const result=await runPerfBench(msg);
      post("PERF_BENCH_DONE", result);
      post("PROGRESS", {value:100, text:"PERF_BENCH complete"});
      return;
    }

    if (msg.type==="CANCEL"){state.cancelled=true; return;}

    if (msg.type==="ANALYZE"){
      state.cancelled=false;
      postProgress(0,"Analyzing schema...");
      const rules=makeRules(msg);
      const schema=await analyzeSchema({file:msg.file,encoding:msg.encoding,delimiter:msg.delimiter,sampleRows:Number(msg.sampleRows||20000),rules});
      post("SCHEMA_DONE",{schema});
      postProgress(100,"Analyze complete");
      return;
    }

    if (msg.type==="VALIDATE_MERGE"){
      state.cancelled=false;
      postProgress(0,"Validating CSV merge layout...");
      const rules=makeRules(msg);
      const result=await analyzeFilesForMerge({files:msg.files,encoding:msg.encoding,delimiter:msg.delimiter,sampleRows:Number(msg.sampleRows||20000),rules});
      post("MERGE_SCHEMA_DONE",result);
      postProgress(100,"Merge validation complete");
      return;
    }

    if (msg.type==="PREVIEW_CLEAN"){
      state.cancelled=false;
      const rules=makeRules(msg);
      const previewLimit=Number(msg.pageSize||200);
      postProgress(1, `Preparing preview: ${msg.file.name}`);
      let schema=state.schema;
      const cacheKey=schemaCacheKey(msg.file, msg.encoding, msg.delimiter, rules);
      if (msg.forceAnalyze || !schema || state.schemaFileKey !== cacheKey) {
        const sampleForPreview = Math.max(200, Math.min(Number(msg.sampleRows||1000), Math.max(1000, previewLimit)));
        schema=await analyzeSchema({file:msg.file,encoding:msg.encoding,delimiter:msg.delimiter,sampleRows:sampleForPreview,rules});
      }
      postProgress(65, `Reading preview rows: 0/${fmt(previewLimit)}`);
      const iter=fileLines(msg.file,msg.encoding,0,`Reading preview ${msg.file.name}`,65,25);
      await iter.next();
      const rows=[]; let source=0, changed=0, malformed=0;
      for await (const line of iter){
        if (rows.length >= previewLimit) break;
        source++;
        let cells=parseCSVLine(line,msg.delimiter);
        if (cells.length !== schema.columns.length) malformed++;
        while(cells.length<schema.columns.length) cells.push("");
        if (cells.length>schema.columns.length) cells=cells.slice(0,schema.columns.length);
        const row=[];
        for (const col of schema.columns){
          const c=cleanCell(cells[col.index],rules); if(c.changed) changed++;
          if (col.type==="number"){
            const n=numberCandidate(c.value,rules);
            row.push(c.value==null ? "" : (n.ok ? n.value : ""));
          } else row.push(c.value ?? "");
        }
        rows.push(row);
        if (rows.length % 25 === 0) postProgress(90, `Cleaning preview rows... ${fmt(rows.length)}/${fmt(previewLimit)}`);
      }
      postProgress(100, `Preview complete: ${fmt(rows.length)} rows`);
      post("CLEAN_PREVIEW",{header:schema.columns.map(c=>c.name),rows,report:{previewRows:rows.length,sourceRowsRead:source,changedCells:changed,malformedRows:malformed,fileSize:msg.file.size}});
      return;
    }

    if (msg.type==="BUILD_COLUMNAR"){
      state.cancelled=false;
      postProgress(0,"Building columnar cache...");
      const result=await buildColumnarCache(msg);
      post("COLUMNAR_DONE",result);
      postProgress(100,"Columnar cache complete");
      return;
    }

    if (msg.type==="OPFS_LIST"){ post("OPFS_LIST_DONE",{datasets:await listDatasets()}); return; }
    if (msg.type==="OPFS_ESTIMATE"){ post("OPFS_ESTIMATE_DONE", navigator.storage?.estimate ? await navigator.storage.estimate() : {usage:null,quota:null}); return; }
    if (msg.type==="OPFS_LOAD"){
      state.cancelled=false;
      const result=await openDataset(msg.id);
      post("OPFS_LOADED",result);
      return;
    }
    if (msg.type==="OPFS_OPEN_VIRTUAL"){
      state.cancelled=false;
      post("PROGRESS",{value:1,text:"Opening Storage-backed Virtual Dataset..."});
      const result=await openVirtualDataset(msg.ids, msg.name);
      post("OPFS_VIRTUAL_LOADED",result);
      post("PROGRESS",{value:100,text:"Virtual Dataset ready"});
      return;
    }
    if (msg.type==="OPFS_OPEN_MEMORY"){
      state.cancelled=false;
      post("PROGRESS",{value:1,text:"Loading selected Storage Tables into In-memory Dataset..."});
      const result=await openMemoryDataset(msg.ids, msg.name, {maxMemoryMB:msg.maxMemoryMB, maxRows:msg.maxRows});
      post("OPFS_MEMORY_LOADED",result);
      post("PROGRESS",{value:100,text:"In-memory Dataset ready"});
      return;
    }
    if (msg.type==="OPFS_DELETE"){
      await deleteDataset(msg.id);
      post("OPFS_DELETED",{datasets:await listDatasets()});
      return;
    }

    if (msg.type==="MERGE_OPFS_DATASETS"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Merging saved OPFS datasets..."});
      const result=await mergeSavedDatasets(msg.ids, msg.datasetName, {storageWorkspace:msg.storageWorkspace, storageCollection:msg.storageCollection, tableName:msg.tableName});
      post("OPFS_MERGED",result);
      post("PROGRESS",{value:100,text:"Saved dataset merge complete"});
      return;
    }

    if (msg.type==="PURGE_SELECTED"){
      await deleteDataset(msg.id);
      if (state.manifest && state.manifest.id === msg.id) forgetSession();
      post("PURGE_DONE",{scope:"selected",datasets:await listDatasets()});
      return;
    }

    if (msg.type==="PURGE_ALL"){
      const count = await purgeAllDatasets();
      post("PURGE_DONE",{scope:"all",count,datasets:await listDatasets()});
      return;
    }

    if (msg.type==="FORGET_SESSION"){
      forgetSession();
      post("SESSION_FORGOTTEN",{datasets:await listDatasets()});
      return;
    }

    if (msg.type==="READ_PAGE"){
      state.cancelled=false;
      const t0=now();
      const result=await readPage(Number(msg.page||1),Number(msg.pageSize||500),msg.columns||[]);
      post("PAGE_RESULT",{...result,page:Number(msg.page||1),ms:now()-t0,origin:msg.origin || ""});
      return;
    }

    if (msg.type==="RUN_DATA_QUERY"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Building global filter/sort row index..."});
      const result=await runDataQuery(msg);
      post("DATA_QUERY_DONE",{...result,origin:msg.origin || ""});
      post("PROGRESS",{value:100,text:result.active ? `Global data query complete: ${fmt(result.matches || 0)} rows` : "Global data query cleared"});
      return;
    }

    if (msg.type==="READ_DATA_QUERY_PAGE"){
      state.cancelled=false;
      const t0=now();
      const result=await readDataQueryPage(Number(msg.page||1),Number(msg.pageSize||500),msg.columns||[]);
      post("DATA_QUERY_PAGE_RESULT",{...result,page:Number(msg.page||1),ms:now()-t0,origin:msg.origin || ""});
      return;
    }



    if (msg.type==="RUN_GRAPH_JOIN_QUERY"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Running Graph JOIN query..."});
      const result=await runGraphJoinQuery({plan:msg.plan,pageSize:Number(msg.pageSize||500)});
      post("GRAPH_JOIN_DONE",result);
      post("PROGRESS",{value:100,text:"Graph JOIN query complete"});
      return;
    }

    if (msg.type==="READ_GRAPH_JOIN_PAGE"){
      state.cancelled=false;
      const t0=now();
      const result=await readGraphJoinPage(Number(msg.page||1),Number(msg.pageSize||500),msg.origin || "");
      post("GRAPH_JOIN_PAGE_RESULT",{...result,ms:now()-t0,origin:msg.origin || ""});
      return;
    }


    if (msg.type==="RUN_GRAPH_RESULT_SEARCH"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Searching Graph Query Result..."});
      const result=await runGraphResultSearch(msg);
      post("GRAPH_RESULT_SEARCH_DONE",{...result,target:msg.target || "graph"});
      post("PROGRESS",{value:100,text:`Graph Result search complete: ${fmt(result.matches)} matches`});
      return;
    }

    if (msg.type==="READ_GRAPH_RESULT_SEARCH_PAGE"){
      const result=readGraphResultSearchPage(Number(msg.page||1),Number(msg.pageSize||500));
      post("GRAPH_RESULT_SEARCH_PAGE_RESULT",{...result,target:msg.target || "graph"});
      return;
    }

    if (msg.type==="BUILD_GRAPH_RESULT_PIVOT"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Building Pivot from Graph Query Result..."});
      const result=await buildGraphResultPivot(msg);
      post("GRAPH_RESULT_PIVOT_DONE",{...result,target:msg.target || "graph"});
      post("PROGRESS",{value:100,text:`Graph Result pivot complete: ${fmt(result.rows?.length || 0)} rows`});
      return;
    }

    if (msg.type==="BUILD_GRAPH_RESULT_TIME"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Building Time view from Graph Query Result..."});
      const result=await buildGraphResultTime(msg);
      post("GRAPH_RESULT_TIME_DONE",{...result,target:msg.target || "graph"});
      post("PROGRESS",{value:100,text:`Graph Result time complete: ${fmt(result.rows?.length || 0)} rows`});
      return;
    }

    if (msg.type==="EXPORT_GRAPH_QUERY_CSV"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Exporting Graph Query CSV..."});
      const result=await exportGraphQueryCsv(msg);
      post("GRAPH_QUERY_CSV",result);
      post("PROGRESS",{value:100,text:`Graph Query CSV export complete: ${fmt(result.rows)} rows`});
      return;
    }

    if (msg.type==="CLEAR_DATA_QUERY"){
      state.dataQueryMatches=null;
      state.dataQueryMeta=null;
      post("DATA_QUERY_CLEARED",{});
      return;
    }

    if (msg.type==="RUN_SEARCH"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Searching columnar cache..."});
      const result=await runSearch(msg);
      post("SEARCH_DONE",result);
      post("PROGRESS",{value:100,text:"Search complete"});
      return;
    }

    if (msg.type==="READ_SEARCH_PAGE"){
      state.cancelled=false;
      const page=Number(msg.page||1), pageSize=Number(msg.pageSize||500);
      const ids=state.searchMatches.slice((page-1)*pageSize,(page-1)*pageSize+pageSize);
      const t0=now();
      const result=await readRowsByGlobal(ids,msg.columns||[]);
      post("SEARCH_PAGE_RESULT",{...result,page,pageSize,totalMatches:state.searchMatches.length,ms:now()-t0});
      return;
    }

    if (msg.type==="BUILD_PIVOT"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Building pivot tile index..."});
      const result=await buildPivot(msg);
      post("PIVOT_TILE_READY",result);
      post("PIVOT_VIEWPORT_DONE",readPivotViewport({rowStart:0,colStart:0,viewportRows:90,viewportCols:40,overscan:1}));
      post("PROGRESS",{value:100,text:"Pivot tile index complete"});
      return;
    }

    if (msg.type==="READ_PIVOT_VIEWPORT"){
      post("PIVOT_VIEWPORT_DONE",readPivotViewport(msg));
      return;
    }

    if (msg.type==="BUILD_TIME"){
      state.cancelled=false;
      post("PROGRESS",{value:0,text:"Building time-oriented view..."});
      const result=await buildTimeSeries(msg);
      post("TIME_DONE",result);
      post("PROGRESS",{value:100,text:"Time view complete"});
      return;
    }

    if (msg.type==="EXPORT_TIME"){
      if (!state.timeTable) throw new Error("Time view table is empty");
      const lines=[state.timeTable.header.map(csvEscape).join(",")];
      for (const r of state.timeTable.rows) lines.push(r.map(csvEscape).join(","));
      post("TIME_CSV",{csv:lines.join("\n")});
      return;
    }

    if (msg.type==="EXPORT_GRAPH_RESULT_TIME"){
      if (!state.graphResultTime) throw new Error("Graph Result Time table is empty");
      const lines=[state.graphResultTime.header.map(csvEscape).join(",")];
      for (const r of state.graphResultTime.rows || []) lines.push((r || []).map(csvEscape).join(","));
      post("TIME_CSV",{csv:lines.join("\n"), source:"graph"});
      return;
    }

    if (msg.type==="EXPORT_PIVOT"){
      const csv=exportPivotCsvFromTileIndex();
      post("PIVOT_CSV",{csv});
      return;
    }

    if (msg.type==="EXPORT_GRAPH_RESULT_PIVOT"){
      if (!state.graphResultPivot) throw new Error("Graph Result Pivot table is empty");
      const lines=[state.graphResultPivot.header.map(csvEscape).join(",")];
      for (const r of state.graphResultPivot.rows || []) lines.push((r || []).map(csvEscape).join(","));
      post("PIVOT_CSV",{csv:lines.join("\n"), source:"graph"});
      return;
    }

  }catch(err){
    post("ERROR",{
      message:err?.message || String(err),
      stack:err?.stack || "",
      requestType:msg?.type || "",
      origin:msg?.origin || "",
      plan:msg?.plan || null
    });
    postProgress(0,`Error: ${err?.message || String(err)}`);
  }
};
  

  
