  const readPivot = () => {
    post("READ_PIVOT_VIEWPORT", {
      rowStart: safeInt(state.pivot.rowStart, 0, 0, 1000000000),
      colStart: safeInt(state.pivot.colStart, 0, 0, 1000000000),
      viewportRows: safeInt(state.pivot.viewportRows, 90, 1, 240),
      viewportCols: safeInt(state.pivot.viewportCols, 40, 1, 120),
      overscan: 1,
    });
  };

  const runTime = () => {
    if (!requireDataset(state, dispatch)) return;
    post("BUILD_TIME", {
      timeField: Number(state.time.timeField),
      bucket: state.time.bucket,
      groupField: Number(state.time.groupField),
      valueField: Number(state.time.valueField),
      aggregation: state.time.aggregation,
      maxBuckets: state.time.maxBuckets,
    }, { busy: true, label: "Build Time" });
  };

  return (
    <>
      <Section
        title="Search"
        subtitle="検索はmatch indexを作り、ページ表示だけを後から取得します。"
        icon={<Search fontSize="small" />}
        actions={[
          <Button key="run" variant="contained" onClick={runSearch} disabled={!manifest}>Run Search</Button>,
          <Button key="prev" onClick={() => dispatch({ type: "search/update", patch: { page: Math.max(1, state.search.page - 1), table: null } })} disabled={!state.search.matches}>Prev</Button>,
          <TextField key="page" label="Page" value={state.search.page} onChange={(e) => dispatch({ type: "search/update", patch: { page: clampPage(e.target.value), table: null } })} sx={{ width: 90 }} />,
          <Button key="next" onClick={() => dispatch({ type: "search/update", patch: { page: state.search.page + 1, table: null } })} disabled={!state.search.matches}>Next</Button>,
          <Button key="csv" onClick={() => downloadText("search_page.csv", tableToCsv(state.search.table))} disabled={!state.search.table}>CSV</Button>,
        ]}
      >
        {manifest ? (
          <Stack spacing={1}>
            <FieldRow>
              <FormControl fullWidth size="small" margin="dense">
                <InputLabel>Column</InputLabel>
                <Select label="Column" value={state.search.columnIndex} onChange={(e) => dispatch({ type: "search/update", patch: { columnIndex: e.target.value } })}>
                  {cols.map((c) => <MenuItem key={c.index} value={String(c.index)}>{c.index}: {c.name} {c.type ? `(${c.type})` : ""}</MenuItem>)}
                </Select>
              </FormControl>
              <TextField select label="Operator" value={state.search.op} onChange={(e) => dispatch({ type: "search/update", patch: { op: e.target.value } })}>
                {QUERY_OPERATORS.map(([v, l]) => <MenuItem key={v} value={v}>{l}</MenuItem>)}
              </TextField>
              <TextField label="Value" value={state.search.value} onChange={(e) => dispatch({ type: "search/update", patch: { value: e.target.value } })} />
              <TextField label="Max matches" value={state.search.maxMatches} onChange={(e) => dispatch({ type: "search/update", patch: { maxMatches: e.target.value } })} />
            </FieldRow>
            <Stack direction="row" spacing={0.7}><StateChip label="matches" value={fmt(state.search.matches)} /><StateChip label="status" value={state.search.status} /></Stack>
            <DataTable table={state.search.table} empty={state.search.status} maxHeight={320} />
          </Stack>
        ) : <Alert severity="info">Datasetを先に開いてください。</Alert>}
      </Section>

      <Section
        title="Pivot"
        subtitle="集計はWorkerのTile Indexとして保持し、UIはViewportだけを読みます。"
        icon={<Analytics fontSize="small" />}
        actions={[
          <Button key="build" variant="contained" onClick={runPivot} disabled={!manifest}>Build Pivot</Button>,
          <Button key="read" onClick={readPivot} disabled={!state.pivot.meta}>Read Viewport</Button>,
          <Button key="export" onClick={() => post("EXPORT_PIVOT", {}, { busy: true, label: "Export Pivot" })} disabled={!state.pivot.meta}>Export CSV</Button>,
        ]}
      >
        {manifest ? (
          <Stack spacing={1}>
            <FieldRow>
              <MultiColumnSelect label="Row fields" manifest={manifest} value={state.pivot.rowFields} onChange={(value) => dispatch({ type: "pivot/update", patch: { rowFields: value } })} />
              <MultiColumnSelect label="Column fields" manifest={manifest} value={state.pivot.columnFields} onChange={(value) => dispatch({ type: "pivot/update", patch: { columnFields: value } })} />
              <FormControl fullWidth size="small" margin="dense">
                <InputLabel>Value field</InputLabel>
                <Select label="Value field" value={state.pivot.valueField} onChange={(e) => dispatch({ type: "pivot/update", patch: { valueField: e.target.value } })}>
                  {colsWithNone.map((c) => <MenuItem key={c.index} value={String(c.index)}>{c.index}: {c.name}</MenuItem>)}
                </Select>
              </FormControl>
              <TextField select label="Aggregation" value={state.pivot.aggregation} onChange={(e) => dispatch({ type: "pivot/update", patch: { aggregation: e.target.value } })}>
                {AGGREGATIONS.map((a) => <MenuItem key={a} value={a}>{a}</MenuItem>)}
              </TextField>
              <TextField label="Max rows" value={state.pivot.maxRows} onChange={(e) => dispatch({ type: "pivot/update", patch: { maxRows: e.target.value } })} />
              <TextField label="Max cols" value={state.pivot.maxCols} onChange={(e) => dispatch({ type: "pivot/update", patch: { maxCols: e.target.value } })} />
              <TextField label="Row start" value={state.pivot.rowStart} onChange={(e) => dispatch({ type: "pivot/update", patch: { rowStart: e.target.value } })} />
              <TextField label="Col start" value={state.pivot.colStart} onChange={(e) => dispatch({ type: "pivot/update", patch: { colStart: e.target.value } })} />
            </FieldRow>
            <Stack direction="row" spacing={0.7}><StateChip label="status" value={state.pivot.status} /></Stack>
            <DataTable table={state.pivot.table} empty={state.pivot.status} maxHeight={320} />
          </Stack>
        ) : <Alert severity="info">Datasetを先に開いてください。</Alert>}
      </Section>

      <Section
        title="Time View"
        subtitle="時系列集計はWorkerでReduceし、UIは結果Tableだけを表示します。"
        icon={<Timeline fontSize="small" />}
        actions={[
          <Button key="build" variant="contained" onClick={runTime} disabled={!manifest}>Build Time</Button>,
          <Button key="export" onClick={() => post("EXPORT_TIME", {}, { busy: true, label: "Export Time" })} disabled={!state.time.table}>Export CSV</Button>,
        ]}
      >
        {manifest ? (
          <Stack spacing={1}>
            <FieldRow>
              <FormControl fullWidth size="small" margin="dense">
                <InputLabel>Time field</InputLabel>
                <Select label="Time field" value={state.time.timeField} onChange={(e) => dispatch({ type: "time/update", patch: { timeField: e.target.value } })}>
                  {cols.map((c) => <MenuItem key={c.index} value={String(c.index)}>{c.index}: {c.name}</MenuItem>)}
                </Select>
              </FormControl>
              <TextField select label="Bucket" value={state.time.bucket} onChange={(e) => dispatch({ type: "time/update", patch: { bucket: e.target.value } })}>
                {TIME_BUCKETS.map((b) => <MenuItem key={b} value={b}>{b}</MenuItem>)}
              </TextField>
              <FormControl fullWidth size="small" margin="dense">
                <InputLabel>Group field</InputLabel>
                <Select label="Group field" value={state.time.groupField} onChange={(e) => dispatch({ type: "time/update", patch: { groupField: e.target.value } })}>
                  {colsWithNone.map((c) => <MenuItem key={c.index} value={String(c.index)}>{c.index}: {c.name}</MenuItem>)}
                </Select>
              </FormControl>
              <FormControl fullWidth size="small" margin="dense">
                <InputLabel>Value field</InputLabel>
                <Select label="Value field" value={state.time.valueField} onChange={(e) => dispatch({ type: "time/update", patch: { valueField: e.target.value } })}>
                  {colsWithNone.map((c) => <MenuItem key={c.index} value={String(c.index)}>{c.index}: {c.name}</MenuItem>)}
                </Select>
              </FormControl>
              <TextField select label="Aggregation" value={state.time.aggregation} onChange={(e) => dispatch({ type: "time/update", patch: { aggregation: e.target.value } })}>
                {AGGREGATIONS.map((a) => <MenuItem key={a} value={a}>{a}</MenuItem>)}
              </TextField>
              <TextField label="Max buckets" value={state.time.maxBuckets} onChange={(e) => dispatch({ type: "time/update", patch: { maxBuckets: e.target.value } })} />
            </FieldRow>
            <Stack direction="row" spacing={0.7}><StateChip label="status" value={state.time.status} /></Stack>
            <DataTable table={state.time.table} empty={state.time.status} maxHeight={320} />
          </Stack>
        ) : <Alert severity="info">Datasetを先に開いてください。</Alert>}
      </Section>
    </>
  );
}

function GraphPanel({ state, dispatch, post }) {
  const runGraph = () => {
    let plan;
    try {
      plan = JSON.parse(state.graph.planText);
    } catch (err) {
      dispatch({ type: "runtime/error", message: `Graph Plan JSONが不正です: ${err.message}`, payload: {} });
      return;
    }
    post("RUN_GRAPH_JOIN_QUERY", { plan, pageSize: state.settings.graphPageSize }, { busy: true, label: "Graph JOIN" });
  };

  return (
    <Section
      title="Graph / Join Execution"
      subtitle="視覚編集ではなく、JOIN plan JSONを実行する安全なCommand面に集約しています。"
      icon={<Analytics fontSize="small" />}
      actions={[
        <TextField key="ps" label="Page size" value={state.settings.graphPageSize} onChange={(e) => dispatch({ type: "settings/update", patch: { graphPageSize: e.target.value } })} sx={{ width: 110 }} />,
        <Button key="run" variant="contained" startIcon={<Send />} onClick={runGraph}>Run Graph JOIN</Button>,
        <Button key="prev" onClick={() => dispatch({ type: "graph/update", patch: { page: Math.max(1, state.graph.page - 1), table: null } })} disabled={!state.graph.meta}>Prev</Button>,
        <TextField key="page" label="Page" value={state.graph.page} onChange={(e) => dispatch({ type: "graph/update", patch: { page: clampPage(e.target.value), table: null } })} sx={{ width: 90 }} />,
        <Button key="next" onClick={() => dispatch({ type: "graph/update", patch: { page: state.graph.page + 1, table: null } })} disabled={!state.graph.meta}>Next</Button>,
        <Button key="export" onClick={() => post("EXPORT_GRAPH_QUERY_CSV", {}, { busy: true, label: "Export Graph" })} disabled={!state.graph.meta}>Export CSV</Button>,
      ]}
    >
      <Stack spacing={1}>
        <Alert severity="info">
          Graph JOINは保存済みDataset IDをplanに指定して実行します。実行例は既存Workerのplan仕様に合わせてJSONで投入してください。
        </Alert>
        <TextField
          label="Graph JOIN Plan JSON"
          value={state.graph.planText}
          onChange={(e) => dispatch({ type: "graph/update", patch: { planText: e.target.value } })}
          multiline
          minRows={10}
          fullWidth
          inputProps={{ style: { fontFamily: "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace", fontSize: 12 } }}
        />
        <Stack direction="row" spacing={0.7}><StateChip label="status" value={state.graph.status} /></Stack>
        <DataTable table={state.graph.table} empty={state.graph.status} />
      </Stack>
    </Section>
  );
}

function RuntimePanel({ state, dispatch, post }) {
  const metrics = state.runtime.metrics || {};
  return (
    <>
      <Section
        title="Runtime / Measurement"
        subtitle="通信・処理・fallbackを観測する面です。改善を測定可能に保ちます。"
        icon={<Analytics fontSize="small" />}
        actions={[
          <Button key="remote" onClick={() => post("REMOTE_EXECUTION_STATUS")}>Remote</Button>,
          <Button key="plane" onClick={() => post("EXECUTION_PLANE_STATUS")}>Execution</Button>,
          <Button key="obs" onClick={() => post("OBSERVATION_ENGINE_STATUS")}>Observation</Button>,
          <Button key="hybrid" onClick={() => post("HYBRID_SURFACE_STATUS")}>Hybrid Surface</Button>,
          <Button key="row" onClick={() => post("ROW_SURFACE_STATUS")}>Row Surface</Button>,
          <Button key="adaptive" onClick={() => post("ADAPTIVE_KERNEL_STATUS")}>Adaptive</Button>,
          <Button key="bench" onClick={() => post("PERF_BENCH", {}, { busy: true, label: "Perf Bench" })}>Perf</Button>,
          <Button key="abench" onClick={() => post("ADAPTIVE_PERF_BENCH", {}, { busy: true, label: "Adaptive Perf" })}>Adaptive Perf</Button>,
        ]}
      >
        <Stack spacing={1}>
          <Stack direction="row" spacing={0.7} flexWrap="wrap">
            {Object.entries(metrics).map(([k, v]) => <StateChip key={k} label={k} value={fmt(v)} />)}
            <StateChip label="last" value={state.runtime.lastMessageType || "-"} />
          </Stack>
          <Box sx={{ display: "grid", gridTemplateColumns: { xs: "1fr", md: "repeat(2, 1fr)" }, gap: 1 }}>
            <JsonBlock value={state.system.remote} />
            <JsonBlock value={state.system.executionPlane} />
            <JsonBlock value={state.system.observation} />
            <JsonBlock value={state.system.hybridSurface} />
            <JsonBlock value={state.system.rowSurface} />
            <JsonBlock value={state.system.adaptive} />
          </Box>
        </Stack>
      </Section>

      <Section
        title="Logs / Errors"
        subtitle="未知message・例外・Worker errorはここに集約します。"
        icon={<Article fontSize="small" />}
        actions={[
          <Button key="toggle" onClick={() => dispatch({ type: "ui/update", patch: { showLogs: !state.ui.showLogs } })}>{state.ui.showLogs ? "Hide" : "Show"}</Button>,
        ]}
      >
        <Collapse in={state.ui.showLogs}>
          <Stack spacing={0.7}>
            {(state.runtime.logs || []).slice(0, 120).map((log) => (
              <Alert key={log.id} severity={log.level === "error" ? "error" : log.level === "warn" ? "warning" : "info"}>
                <Typography variant="caption">{log.at} / {log.message}</Typography>
                {log.detail ? <JsonBlock value={log.detail} maxHeight={120} /> : null}
              </Alert>
            ))}
            {!state.runtime.logs.length ? <Alert severity="info">ログはまだありません。</Alert> : null}
          </Stack>
        </Collapse>
      </Section>
    </>
  );
}

function App() {
  const [state, dispatch] = useReducer(appReducer, undefined, createInitialState);
  const post = useWorkerGateway(dispatch);
  const theme = useMemo(() => createAppTheme(state.settings.themeMode), [state.settings.themeMode]);

  const manifest = state.dataset.manifest;
  const visibleKey = useMemo(() => state.dataset.visibleColumns.join(","), [state.dataset.visibleColumns]);
  const pageSize = safeInt(state.settings.pageSize, 500, 1, 50000);
  const graphPageSize = safeInt(state.settings.graphPageSize, 500, 1, 50000);

  useEffect(() => {
    if (!manifest) return;
    post("READ_PAGE", {
      page: state.dataset.page,
      pageSize,
      columns: projectionColumns(state),
      origin: "data",
    });
  }, [manifest?.id, manifest?.createdAt, state.dataset.page, pageSize, visibleKey]);

  useEffect(() => {
    if (!manifest || !state.query.active) return;
    post("READ_DATA_QUERY_PAGE", {
      page: state.query.page,
      pageSize,
      columns: projectionColumns(state),
      origin: "query",
    });
  }, [manifest?.id, state.query.active, state.query.page, pageSize, visibleKey]);

  useEffect(() => {
    if (!manifest || !state.search.matches) return;
    post("READ_SEARCH_PAGE", {
      page: state.search.page,
      pageSize,
      columns: projectionColumns(state),
    });
  }, [manifest?.id, state.search.matches, state.search.page, pageSize, visibleKey]);

  useEffect(() => {
    if (!state.graph.meta || !state.graph.page) return;
    post("READ_GRAPH_JOIN_PAGE", {
      page: state.graph.page,
      pageSize: graphPageSize,
      origin: "graph",
    });
  }, [state.graph.meta, state.graph.page, graphPageSize]);

  const panel = (() => {
    if (state.ui.tab === "import") return <ImportPanel state={state} dispatch={dispatch} post={post} />;
    if (state.ui.tab === "storage") return <StoragePanel state={state} dispatch={dispatch} post={post} />;
    if (state.ui.tab === "data") return <DataPanel state={state} dispatch={dispatch} post={post} />;
    if (state.ui.tab === "query") return <QueryPanel state={state} dispatch={dispatch} post={post} />;
    if (state.ui.tab === "analytics") return <AnalyticsPanel state={state} dispatch={dispatch} post={post} />;
    if (state.ui.tab === "graph") return <GraphPanel state={state} dispatch={dispatch} post={post} />;
    return <RuntimePanel state={state} dispatch={dispatch} post={post} />;
  })();

  return (
    <ThemeProvider theme={theme}>
      <CssBaseline />
      <Container maxWidth={false} sx={{ py: 1 }}>
        <RuntimeBar state={state} dispatch={dispatch} />

        <Paper elevation={0} sx={{ my: 1, px: 1 }}>
          <Stack direction={{ xs: "column", md: "row" }} alignItems={{ xs: "stretch", md: "center" }} justifyContent="space-between" spacing={1}>
            <Box sx={{ py: 0.8 }}>
              <Typography variant="h4">Quantum CSV Grid</Typography>
              <Typography variant="caption" color="text.secondary">
                Full Surface Replacement / Command Gateway / State Reducer / Projection UI
              </Typography>
            </Box>
            <Tabs
              value={state.ui.tab}
              onChange={(e, value) => dispatch({ type: "ui/update", patch: { tab: value } })}
              variant="scrollable"
              allowScrollButtonsMobile
            >
              <Tab value="import" icon={<UploadFile fontSize="small" />} iconPosition="start" label="Import" />
              <Tab value="storage" icon={<Storage fontSize="small" />} iconPosition="start" label="Storage" />
              <Tab value="data" icon={<TableChart fontSize="small" />} iconPosition="start" label="Data" />
              <Tab value="query" icon={<Search fontSize="small" />} iconPosition="start" label="Query" />
              <Tab value="analytics" icon={<Analytics fontSize="small" />} iconPosition="start" label="Analytics" />
              <Tab value="graph" icon={<Timeline fontSize="small" />} iconPosition="start" label="Graph" />
              <Tab value="runtime" icon={<Article fontSize="small" />} iconPosition="start" label="Runtime" />
            </Tabs>
          </Stack>
        </Paper>

        {state.runtime.errors.length ? (
          <Alert severity="error" sx={{ mb: 1 }}>
            {state.runtime.errors[0].message || state.runtime.status}
          </Alert>
        ) : null}

        {panel}
      </Container>
    </ThemeProvider>
  );
}

createRoot(document.getElementById("root")).render(<App />);

</script>

  <!-- React 19 / MUI 7.3.5 / Icons via CDN ESM -->
  <script type="module">
    import React from "https://esm.sh/react@19.2.0";
    import { createRoot } from "https://esm.sh/react-dom@19.2.0/client";
    import * as MaterialUI from "https://esm.sh/@mui/material@7.3.5?deps=react@19.2.0,react-dom@19.2.0";
    import UploadFile from "https://esm.sh/@mui/icons-material@7.3.5/UploadFile?deps=react@19.2.0,react-dom@19.2.0";
    import CloudUpload from "https://esm.sh/@mui/icons-material@7.3.5/CloudUpload?deps=react@19.2.0,react-dom@19.2.0";
    import FolderOpen from "https://esm.sh/@mui/icons-material@7.3.5/FolderOpen?deps=react@19.2.0,react-dom@19.2.0";
    import Analytics from "https://esm.sh/@mui/icons-material@7.3.5/Analytics?deps=react@19.2.0,react-dom@19.2.0";
    import Storage from "https://esm.sh/@mui/icons-material@7.3.5/Storage?deps=react@19.2.0,react-dom@19.2.0";
    import Search from "https://esm.sh/@mui/icons-material@7.3.5/Search?deps=react@19.2.0,react-dom@19.2.0";
    import TableChart from "https://esm.sh/@mui/icons-material@7.3.5/TableChart?deps=react@19.2.0,react-dom@19.2.0";
    import Timeline from "https://esm.sh/@mui/icons-material@7.3.5/Timeline?deps=react@19.2.0,react-dom@19.2.0";
    import Delete from "https://esm.sh/@mui/icons-material@7.3.5/Delete?deps=react@19.2.0,react-dom@19.2.0";
    import CleaningServices from "https://esm.sh/@mui/icons-material@7.3.5/CleaningServices?deps=react@19.2.0,react-dom@19.2.0";
    import Download from "https://esm.sh/@mui/icons-material@7.3.5/Download?deps=react@19.2.0,react-dom@19.2.0";
    import Send from "https://esm.sh/@mui/icons-material@7.3.5/Send?deps=react@19.2.0,react-dom@19.2.0";
    import Schema from "https://esm.sh/@mui/icons-material@7.3.5/Schema?deps=react@19.2.0,react-dom@19.2.0";
    import Article from "https://esm.sh/@mui/icons-material@7.3.5/Article?deps=react@19.2.0,react-dom@19.2.0";
    import * as ReactFlowLib from "https://esm.sh/@xyflow/react@12.8.4?deps=react@19.2.0,react-dom@19.2.0";
    import * as HtmlToImage from "https://esm.sh/html-to-image@1.11.11";

    const MaterialIcons = {
      UploadFile,
      CloudUpload,
      FolderOpen,
      Analytics,
      Storage,
      Search,
      TableChart,
      Timeline,
      Delete,
      CleaningServices,
      Download,
      Send,
      Schema,
      Article,
    };

    const appCode = document.getElementById("app-code").textContent;

    const missingIcons = Object.entries(MaterialIcons)
      .filter(([, component]) => !component)
      .map(([name]) => name);
    if (missingIcons.length) {
      throw new Error(`Missing MUI icon imports: ${missingIcons.join(", ")}`);
    }

    const { code } = window.Babel.transform(appCode, {
      presets: [["react", { runtime: "classic" }]],
      sourceType: "script",
    });

    const runApp = new Function(
      "React",
      "createRoot",
      "MaterialUI",
      "MaterialIcons",
      "ReactFlowLib",
      "HtmlToImage",
      code
    );

    runApp(React, createRoot, MaterialUI, MaterialIcons, ReactFlowLib, HtmlToImage);
  </script>
