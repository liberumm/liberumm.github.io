async function openMemoryDataset(ids, name, options={}){
  clearChunkCache();
  const list=(Array.isArray(ids) ? ids : []).filter(Boolean);
  if (list.length < 1) throw new Error("Select at least one saved table to load into memory");
  const maxRows=Number(options.maxRows || 0);
  const maxBytes=Number(options.maxMemoryMB || 512) * 1024 * 1024;
  const opened=[];
  for (const id of list){
    opened.push(await loadValidatedDataset(id,{rebuildStats:true}));
  }
  const base=opened[0].manifest;
  const baseSig=schemaFullSignatureFromColumns(base.columns);
  for (const item of opened.slice(1)){
    const sig=schemaFullSignatureFromColumns(item.manifest.columns);
    if (sig !== baseSig) throw new Error(`In-memory Dataset blocked: ${item.manifest.name || item.id} has a different column name/type layout`);
  }

  const columns=base.columns || [];
  const memoryChunks=[];
  const memorySources=opened.map((item, sourceIndex)=>({
    sourceIndex,
    id:item.id,
    manifest:item.manifest,
    rows:Number(item.manifest.totalRows || 0),
    chunks:Number(item.manifest.chunks || item.chunks.length || 0)
  }));
  let rowOffset=0;
  let estimatedBytes=0;
  const t0=now();

  for (let sourceIndex=0; sourceIndex<opened.length; sourceIndex++){
    const item=opened[sourceIndex];
    for (let c=0; c<item.chunks.length; c++){
      if (state.cancelled) throw new Error("Cancelled");
      if (maxRows > 0 && rowOffset >= maxRows) break;
      const chunkDir=await item.dir.getDirectoryHandle(`chunk_${String(c).padStart(6,"0")}`);
      const meta=await readJson(chunkDir,"meta.json");
      const originalRowCount=Number(meta.rowCount || 0);
      const takeRows=maxRows > 0 ? Math.min(originalRowCount, maxRows - rowOffset) : originalRowCount;
      if (takeRows <= 0) break;
      const colMap=new Map();

      for (const col of columns){
        if (col.type === "number"){
          const buf=await readBuffer(chunkDir,colFileName(col.index,col.type));
          let arr=new Float64Array(buf);
          if (takeRows < arr.length) arr=arr.slice(0,takeRows);
          estimatedBytes += arr.byteLength;
          colMap.set(col.index,{type:"number", data:arr});
        } else {
          const buf=await readBuffer(chunkDir,colFileName(col.index,col.type));
          let idsArr=new Int32Array(buf);
          if (takeRows < idsArr.length) idsArr=idsArr.slice(0,takeRows);
          let dict=await readJson(chunkDir,dictFileName(col.index));
          if (takeRows < originalRowCount){
            const compact=compactStringColumnForMemory(idsArr, dict);
            idsArr=compact.ids;
            dict=compact.dict;
          }
          estimatedBytes += idsArr.byteLength + JSON.stringify(dict).length * 2;
          colMap.set(col.index,{type:"string", ids:idsArr, dict});
        }
        if (maxBytes > 0 && estimatedBytes > maxBytes){
          throw new Error(`In-memory load stopped: estimated memory ${fmt(Math.round(estimatedBytes/1024/1024))} MB exceeded limit ${fmt(Math.round(maxBytes/1024/1024))} MB`);
        }
      }

      memoryChunks.push({sourceIndex,sourceChunkIndex:c,rowStart:rowOffset,rowEnd:rowOffset + takeRows,rowCount:takeRows,columns:colMap});
      rowOffset += takeRows;
      post("PROGRESS",{value:Math.min(99, Math.floor(((sourceIndex + (c+1)/Math.max(1,item.chunks.length)) / opened.length) * 100)), text:`Loading to In-memory... table ${sourceIndex+1}/${opened.length} / chunk ${c+1}/${item.chunks.length} / rows ${fmt(rowOffset)} / est ${fmt(Math.round(estimatedBytes/1024/1024))} MB`});
    }
  }

  const tableName=cleanMetaValue(name || `memory_${list.length}_tables`, `memory_${list.length}_tables`);
  const manifest={
    ...base,
    id:`memory:${list.join("+")}`,
    name:tableName,
    storageWorkspace:"In-memory",
    storageCollection:"Session",
    tableName,
    storagePath:`In-memory / Session / ${tableName}`,
    originalFileName:opened.map(x=>x.manifest.name || x.id).join(" + "),
    sourceDatasets:opened.map(x=>({
      id:x.id,workspace:manifestWorkspace(x.manifest),collection:manifestCollection(x.manifest),tableName:manifestTableName(x.manifest),name:x.manifest.name,rows:x.manifest.totalRows,chunks:x.manifest.chunks,createdAt:x.manifest.createdAt
    })),
    createdAt:new Date().toISOString(),
    mode:"memory-dataset",
    totalRows:rowOffset,
    sourceRows:opened.reduce((a,x)=>a+Number(x.manifest.sourceRows || x.manifest.totalRows || 0),0),
    chunks:memoryChunks.length,
    fileSize:opened.reduce((a,x)=>a+Number(x.manifest.fileSize || 0),0),
    memoryReport:{estimatedBytes,estimatedMB:Math.round(estimatedBytes/1024/1024),maxMemoryMB:Number(options.maxMemoryMB || 512),maxRows,loadedTables:opened.length,loadMs:now()-t0},
    cleanReport:{
      sourceRows:opened.reduce((a,x)=>a+Number(x.manifest.cleanReport?.sourceRows || x.manifest.sourceRows || 0),0),
      totalRows:rowOffset,
      skippedRows:opened.reduce((a,x)=>a+Number(x.manifest.cleanReport?.skippedRows || 0),0),
      malformedRows:opened.reduce((a,x)=>a+Number(x.manifest.cleanReport?.malformedRows || 0),0),
      changedCells:opened.reduce((a,x)=>a+Number(x.manifest.cleanReport?.changedCells || 0),0),
      nullCells:opened.reduce((a,x)=>a+Number(x.manifest.cleanReport?.nullCells || 0),0),
      invalidNumbers:opened.reduce((a,x)=>a+Number(x.manifest.cleanReport?.invalidNumbers || 0),0)
    }
  };
  const chunkMetas=memoryChunks.map((ch,i)=>{
    const source=opened[ch.sourceIndex];
    const srcMeta=source?.chunks?.[ch.sourceChunkIndex] || null;
    const fullChunk = Number(srcMeta?.rowCount || 0) === Number(ch.rowCount || 0);
    return {chunkIndex:i,rowCount:ch.rowCount,sourceIndex:ch.sourceIndex,sourceChunkIndex:ch.sourceChunkIndex,rowStart:ch.rowStart,rowEnd:ch.rowEnd,...(fullChunk && srcMeta ? {stats:srcMeta.stats,columnStats:srcMeta.columnStats,indexVersion:srcMeta.indexVersion} : {})};
  });
  state.memory={sources:memorySources,chunks:memoryChunks,estimatedBytes,maxBytes};
  state.virtual=null; state.externalDataset=null; state.dir=null; state.manifest=manifest; state.dataset={id:manifest.id,manifest,chunks:chunkMetas};
  state.searchMatches=[]; state.dataQueryMatches=null; state.dataQueryMeta=null; state.pivotTable=null; state.pivotTileIndex=null; state.timeTable=null;
  return {manifest,chunks:chunkMetas};
}

function activeIsVirtual(){ return !!state.virtual && state.manifest?.mode === "virtual-dataset"; }
function activeIsMemory(){ return !!state.memory && state.manifest?.mode === "memory-dataset"; }
