function ColumnSelector({ manifest, selected, onChange, limit = 80 }) {
  const cols = columnsFromManifest(manifest);
  const set = new Set((selected || []).map(Number));
  const toggle = (idx, checked) => {
    const next = checked ? [...set, idx] : [...set].filter((x) => x !== idx);
    onChange(next.slice(0, limit));
  };
  return (
    <Box sx={{ maxHeight: 240, overflow: "auto", border: "1px solid", borderColor: "divider", borderRadius: 1, p: 0.8 }}>
      <Stack direction="row" spacing={0.8} sx={{ mb: 0.7 }}>
        <Button onClick={() => onChange(cols.slice(0, Math.min(24, cols.length)).map((c, i) => Number(c.index ?? i)))}>先頭24列</Button>
        <Button onClick={() => onChange(cols.map((c, i) => Number(c.index ?? i)).slice(0, limit))}>最大{limit}列</Button>
        <Button onClick={() => onChange([])}>解除</Button>
      </Stack>
      <Box sx={{ display: "grid", gridTemplateColumns: { xs: "1fr", md: "repeat(3, minmax(160px, 1fr))" }, gap: 0.2 }}>
        {cols.map((c, i) => {
          const idx = Number(c.index ?? i);
          return (
            <FormControlLabel
              key={idx}
              control={<Checkbox checked={set.has(idx)} onChange={(e) => toggle(idx, e.target.checked)} />}
              label={`${idx}: ${c.name} ${c.type ? `(${c.type})` : ""}`}
            />
          );
        })}
      </Box>
    </Box>
  );
}

function MultiColumnSelect({ label, manifest, value, onChange, includeNone = false }) {
  const opts = columnOptions(manifest, includeNone);
  return (
    <FormControl fullWidth size="small" margin="dense">
      <InputLabel>{label}</InputLabel>
      <Select
        multiple={!includeNone}
        label={label}
        value={value}
        onChange={(e) => onChange(e.target.value)}
        renderValue={(selected) => Array.isArray(selected)
          ? selected.map((x) => opts.find((o) => String(o.index) === String(x))?.name || x).join(", ")
          : opts.find((o) => String(o.index) === String(selected))?.name || selected}
      >
        {opts.map((c) => <MenuItem key={c.index} value={String(c.index)}>{c.index}: {c.name} {c.type ? `(${c.type})` : ""}</MenuItem>)}
      </Select>
    </FormControl>
  );
}

