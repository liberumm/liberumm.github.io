    observationEngineVersion:OBSERVATION_ENGINE_VERSION,
    enabled:state.observationEngine?.enabled !== false,
    mode:state.observationEngine?.mode || "local-first",
    lastBench:state.observationEngine?.lastBench || null,
    ...extra
  };
}

function configureObservationEngine(config={}){
  const enabled = config.enabled !== false;
  state.observationEngine = {
    ...(state.observationEngine || {}),
    enabled,
    version:OBSERVATION_ENGINE_VERSION,
    mode:String(config.mode || state.observationEngine?.mode || "local-first"),
    lastBench:state.observationEngine?.lastBench || null
