function appReducer(state, action) {
  switch (action.type) {
    case "worker/ready":
      return {
        ...state,
        runtime: appendLog({ ...state.runtime, ready: true, status: "Worker ready" }, "info", "Worker initialized"),
      };

    case "runtime/busy":
      return {
        ...state,
        runtime: {
          ...state.runtime,
          busy: !!action.busy,
          busyLabel: action.label || "",
        },
      };

    case "runtime/sent":
      return { ...state, runtime: updateMetric(state.runtime, "sent") };

    case "runtime/received":
      return {
        ...state,
        runtime: {
          ...updateMetric(state.runtime, "received"),
          lastMessageType: action.messageType || "",
        },
      };

    case "runtime/fallback":
      return {
        ...state,
        runtime: appendLog(updateMetric(state.runtime, "fallback"), "warn", `Unhandled Worker message: ${action.messageType}`, action.payload),
      };

    case "runtime/handlerError":
      return {
        ...state,
        runtime: appendLog(updateMetric(state.runtime, "failures"), "error", action.message || "Message handler failed", action.detail),
      };

    case "runtime/progress":
      return {
        ...state,
        runtime: {
          ...state.runtime,
          progress: Number(action.value || 0),
          progressText: action.text || "",
          busy: Number(action.value || 0) > 0 && Number(action.value || 0) < 100 ? state.runtime.busy : state.runtime.busy,
        },
      };

    case "runtime/error":
      return {
        ...state,
        runtime: appendLog(
          {
            ...updateMetric(state.runtime, "failures"),
            busy: false,
            busyLabel: "",
            status: action.message || "Error",
            errors: [{ at: nowText(), ...action.payload }, ...(state.runtime.errors || [])].slice(0, 80),
          },
          "error",
          action.message || "Worker error",
          action.payload
        ),
      };

    case "runtime/log":
      return { ...state, runtime: appendLog(state.runtime, action.level || "info", action.message, action.detail) };

    case "ui/update":
      return { ...state, ui: { ...state.ui, ...action.patch } };

    case "settings/update":
      return { ...state, settings: mergeSettings(state.settings, action.patch || {}) };

    case "settings/rules":
      return { ...state, settings: mergeSettings(state.settings, { rules: { ...state.settings.rules, ...(action.patch || {}) } }) };

    case "import/files":
      return {
        ...state,
        importSurface: {
          ...state.importSurface,
          files: action.files || [],
          selectedFileIndex: 0,
          schema: null,
          cleanPreview: null,
          cleanReport: null,
          mergeReport: null,
        },
        settings: mergeSettings(state.settings, {
          datasetName: action.files?.[0]?.name ? action.files[0].name.replace(/\.[^.]+$/, "") : state.settings.datasetName,
          tableName: action.files?.[0]?.name ? action.files[0].name.replace(/\.[^.]+$/, "") : state.settings.tableName,
        }),
      };

    case "import/selectFile":
      return {
        ...state,
        importSurface: { ...state.importSurface, selectedFileIndex: Number(action.index || 0), schema: null, cleanPreview: null, cleanReport: null },
      };

    case "schema/done":
      return {
        ...state,
        ui: { ...state.ui, tab: "import" },
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Schema解析が完了しました。" }, "info", "Schema analyzed", action.schema),
        importSurface: { ...state.importSurface, schema: action.schema || null },
      };

    case "merge/done":
      return {
        ...state,
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Merge validationが完了しました。" }, "info", "Merge validation complete", action.payload),
        importSurface: { ...state.importSurface, mergeReport: action.payload || null, schema: action.payload?.schema || state.importSurface.schema },
      };

    case "preview/done":
      return {
        ...state,
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Clean previewを更新しました。" }, "info", "Clean preview ready"),
        importSurface: {
          ...state.importSurface,
          cleanPreview: normalizeTable(action.payload?.table || action.payload),
          cleanReport: action.payload?.report || action.payload?.cleanReport || null,
          schema: action.payload?.schema || state.importSurface.schema,
        },
      };

    case "dataset/opened":
      return activateDatasetState(state, action.payload, action.activeKind || "dataset");

    case "table/page":
      return {
        ...state,
        runtime: updateMetric(state.runtime, "pageReads"),
        dataset: {
          ...state.dataset,
          table: normalizeTable(action.payload),
          dataStatus: `Page ${fmt(action.payload?.page || state.dataset.page)} / ${fmt((action.payload?.rows || []).length)} rows`,
          dataTime: action.payload?.ms ? `${Number(action.payload.ms).toFixed(1)} ms` : "",
        },
      };

    case "dataset/update":
      return { ...state, dataset: { ...state.dataset, ...action.patch } };

    case "dataset/visibleColumns":
      return { ...state, dataset: { ...state.dataset, visibleColumns: action.columns || [], page: 1, table: null } };

    case "storage/list":
      return { ...state, storage: { ...state.storage, datasets: action.datasets || [] } };

    case "storage/estimate":
      return { ...state, storage: { ...state.storage, estimate: action.estimate || null } };

    case "storage/select":
      return {
        ...state,
        storage: {
          ...state.storage,
          selectedIds: action.checked
            ? [...new Set([...state.storage.selectedIds, action.id])]
            : state.storage.selectedIds.filter((id) => id !== action.id),
        },
      };

    case "storage/clearSelection":
      return { ...state, storage: { ...state.storage, selectedIds: [] } };

    case "storage/purged":
      return {
        ...state,
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Storageを更新しました。" }, "info", "Storage changed", action.payload),
        storage: { ...state.storage, datasets: action.payload?.datasets || state.storage.datasets, selectedIds: [] },
      };

    case "query/update":
      return { ...state, query: { ...state.query, ...action.patch } };

    case "query/addFilter": {
      const filter = {
        id: `${Date.now()}_${Math.random().toString(16).slice(2)}`,
        columnIndex: Number(state.query.draftColumn || 0),
        op: state.query.draftOp || "contains",
        value: state.query.draftValue || "",
      };
      return {
        ...state,
        query: {
          ...state.query,
          filters: [...state.query.filters, filter],
          draftValue: "",
          page: 1,
          table: null,
        },
      };
    }

    case "query/removeFilter":
      return { ...state, query: { ...state.query, filters: state.query.filters.filter((f) => f.id !== action.id), page: 1, table: null } };

    case "query/clear":
      return {
        ...state,
        query: {
          ...state.query,
          filters: [],
          sortColumn: "-1",
          sortDirection: "asc",
          active: false,
          matches: 0,
          capped: false,
          page: 1,
          table: null,
          status: "Queryをクリアしました。",
          meta: null,
        },
      };

    case "query/done":
      return {
        ...state,
        ui: { ...state.ui, tab: "query" },
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Queryが完了しました。" }, "info", "Data query complete", action.payload),
        query: {
          ...state.query,
          active: !!action.payload?.active,
          matches: Number(action.payload?.matches || 0),
          capped: !!action.payload?.capped,
          page: 1,
          table: null,
          status: action.payload?.active
            ? `Query: ${fmt(action.payload.matches)} rows${action.payload.capped ? " / capped" : ""}`
            : "Query条件なし。通常Dataへ戻りました。",
          meta: action.payload || null,
        },
      };

    case "query/page":
      return {
        ...state,
        runtime: updateMetric(state.runtime, "queryReads"),
        query: {
          ...state.query,
          table: normalizeTable(action.payload),
          status: `Query page ${fmt(action.payload?.page || state.query.page)} / ${(action.payload?.rows || []).length} rows`,
        },
      };

    case "search/update":
      return { ...state, search: { ...state.search, ...action.patch } };

    case "search/done":
      return {
        ...state,
        ui: { ...state.ui, tab: "analytics" },
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Searchが完了しました。" }, "info", "Search complete", action.payload),
        search: {
          ...state.search,
          matches: Number(action.payload?.matches || 0),
          page: 1,
          table: null,
          status: `Search: ${fmt(action.payload?.matches || 0)} matches${action.payload?.capped ? " / capped" : ""}`,
          meta: action.payload || null,
        },
      };

    case "search/page":
      return {
        ...state,
        search: {
          ...state.search,
          table: normalizeTable(action.payload),
          status: `Search page ${fmt(action.payload?.page || state.search.page)} / ${(action.payload?.rows || []).length} rows`,
        },
      };

    case "pivot/update":
      return { ...state, pivot: { ...state.pivot, ...action.patch } };

    case "pivot/meta":
      return {
        ...state,
        ui: { ...state.ui, tab: "analytics" },
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Pivot indexが完成しました。" }, "info", "Pivot built", action.payload),
        pivot: {
          ...state.pivot,
          meta: action.payload || null,
          status: `Pivot ready: rows ${fmt(action.payload?.totalRows ?? action.payload?.rows ?? "")} / cols ${fmt(action.payload?.totalCols ?? action.payload?.cols ?? "")}`,
        },
      };

    case "pivot/viewport":
      return {
        ...state,
        pivot: {
          ...state.pivot,
          table: pivotViewportToTable(action.payload),
          meta: action.payload || state.pivot.meta,
          status: `Pivot viewport R${fmt(action.payload?.rowStart || 0)}-${fmt(action.payload?.rowEnd || 0)} / C${fmt(action.payload?.colStart || 0)}-${fmt(action.payload?.colEnd || 0)}`,
        },
      };

    case "time/update":
      return { ...state, time: { ...state.time, ...action.patch } };

    case "time/done":
      return {
        ...state,
        ui: { ...state.ui, tab: "analytics" },
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Time viewが完成しました。" }, "info", "Time view built", action.payload),
        time: {
          ...state.time,
          table: normalizeTable(action.payload),
          status: `Time view: ${(action.payload?.rows || []).length} rows`,
          meta: action.payload || null,
        },
      };

    case "graph/update":
      return { ...state, graph: { ...state.graph, ...action.patch } };

    case "graph/done":
      return {
        ...state,
        ui: { ...state.ui, tab: "graph" },
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "Graph JOINが完了しました。" }, "info", "Graph query complete", action.payload),
        graph: {
          ...state.graph,
          page: 1,
          table: normalizeTable(action.payload),
          status: `Graph JOIN: ${fmt(action.payload?.matches || action.payload?.totalMatches || 0)} rows`,
          meta: action.payload || null,
        },
      };

    case "graph/page":
      return {
        ...state,
        graph: {
          ...state.graph,
          table: normalizeTable(action.payload),
          status: `Graph page ${fmt(action.payload?.page || state.graph.page)}`,
        },
      };

    case "csv/download":
      if (action.filename && action.csv != null) downloadText(action.filename, action.csv);
      return {
        ...state,
        runtime: appendLog({ ...state.runtime, busy: false, busyLabel: "", status: "CSVを書き出しました。" }, "info", `CSV exported: ${action.filename}`),
      };

    case "system/update":
      return { ...state, system: { ...state.system, [action.key]: action.value } };

    default:
      return state;
  }
}

function createWorkerMessageRouter(dispatch) {
  const datasetOpened = (activeKind) => (msg) => dispatch({ type: "dataset/opened", payload: msg, activeKind });

  const handlers = {
    PROGRESS: (msg) => dispatch({ type: "runtime/progress", value: msg.value, text: msg.text }),
    ERROR: (msg) => dispatch({ type: "runtime/error", message: msg.message || "Worker error", payload: msg }),

    SCHEMA_DONE: (msg) => dispatch({ type: "schema/done", schema: msg.schema }),
    MERGE_SCHEMA_DONE: (msg) => dispatch({ type: "merge/done", payload: msg }),
    CLEAN_PREVIEW: (msg) => dispatch({ type: "preview/done", payload: msg }),

    COLUMNAR_DONE: datasetOpened("columnar"),
    OPFS_LOADED: datasetOpened("opfs"),
    OPFS_VIRTUAL_LOADED: datasetOpened("virtual"),
    OPFS_MEMORY_LOADED: datasetOpened("memory"),
    OPFS_MERGED: datasetOpened("merged"),
    EXTERNAL_STORAGE_OPENED: datasetOpened("external"),

    OPFS_LIST_DONE: (msg) => dispatch({ type: "storage/list", datasets: msg.datasets || [] }),
    OPFS_ESTIMATE_DONE: (msg) => dispatch({ type: "storage/estimate", estimate: msg }),
    OPFS_DELETED: (msg) => dispatch({ type: "storage/purged", payload: msg }),
    PURGE_DONE: (msg) => dispatch({ type: "storage/purged", payload: msg }),
    SESSION_FORGOTTEN: (msg) => dispatch({ type: "storage/purged", payload: msg }),

    PAGE_RESULT: (msg) => dispatch({ type: "table/page", payload: msg }),
    DATA_QUERY_DONE: (msg) => dispatch({ type: "query/done", payload: msg }),
    DATA_QUERY_PAGE_RESULT: (msg) => dispatch({ type: "query/page", payload: msg }),
    DATA_QUERY_CLEARED: () => dispatch({ type: "query/clear" }),

    SEARCH_DONE: (msg) => dispatch({ type: "search/done", payload: msg }),
    SEARCH_PAGE_RESULT: (msg) => dispatch({ type: "search/page", payload: msg }),

    PIVOT_TILE_READY: (msg) => dispatch({ type: "pivot/meta", payload: msg }),
    PIVOT_VIEWPORT_DONE: (msg) => dispatch({ type: "pivot/viewport", payload: msg }),
    PIVOT_CSV: (msg) => dispatch({ type: "csv/download", filename: msg.source === "graph" ? "graph_pivot.csv" : "pivot.csv", csv: msg.csv }),

    TIME_DONE: (msg) => dispatch({ type: "time/done", payload: msg }),
    GRAPH_RESULT_TIME_DONE: (msg) => dispatch({ type: "time/done", payload: msg }),
    TIME_CSV: (msg) => dispatch({ type: "csv/download", filename: msg.source === "graph" ? "graph_time.csv" : "time.csv", csv: msg.csv }),

    GRAPH_JOIN_DONE: (msg) => dispatch({ type: "graph/done", payload: msg }),
    GRAPH_JOIN_PAGE_RESULT: (msg) => dispatch({ type: "graph/page", payload: msg }),
    GRAPH_QUERY_CSV: (msg) => dispatch({ type: "csv/download", filename: "graph_query.csv", csv: msg.csv }),

    GRAPH_RESULT_SEARCH_DONE: (msg) => dispatch({ type: "search/done", payload: msg }),
    GRAPH_RESULT_SEARCH_PAGE_RESULT: (msg) => dispatch({ type: "search/page", payload: msg }),
    GRAPH_RESULT_PIVOT_DONE: (msg) => dispatch({ type: "pivot/meta", payload: msg }),

    EXTERNAL_STORAGE_STATUS: (msg) => dispatch({ type: "system/update", key: "external", value: msg }),
    EXTERNAL_STORAGE_LIST_DONE: (msg) => {
      dispatch({ type: "system/update", key: "external", value: msg.status || msg });
      dispatch({ type: "runtime/log", level: "info", message: `External datasets: ${(msg.datasets || []).length}` });
    },
    EXTERNAL_STORAGE_SYNC_DONE: (msg) => dispatch({ type: "runtime/log", level: "info", message: "External sync complete", detail: msg }),

    REMOTE_EXECUTION_STATUS: (msg) => dispatch({ type: "system/update", key: "remote", value: msg }),
    EXECUTION_PLANE_STATUS: (msg) => dispatch({ type: "system/update", key: "executionPlane", value: msg }),
    OBSERVATION_ENGINE_STATUS: (msg) => dispatch({ type: "system/update", key: "observation", value: msg }),
    HYBRID_SURFACE_STATUS: (msg) => dispatch({ type: "system/update", key: "hybridSurface", value: msg }),
    ROW_SURFACE_STATUS: (msg) => dispatch({ type: "system/update", key: "rowSurface", value: msg }),
    ROW_SURFACE_PREFETCH_DONE: (msg) => dispatch({ type: "system/update", key: "rowSurface", value: msg.status || msg }),
    ADAPTIVE_KERNEL_STATUS: (msg) => dispatch({ type: "system/update", key: "adaptive", value: msg }),
    HYPERTENSOR_PLAN_PREVIEW_DONE: (msg) => dispatch({ type: "system/update", key: "hyperTensorPlan", value: msg }),
    PERF_BENCH_DONE: (msg) => dispatch({ type: "system/update", key: "perf", value: msg }),
    ADAPTIVE_PERF_BENCH_DONE: (msg) => dispatch({ type: "system/update", key: "adaptivePerf", value: msg }),
    CHUNK_BATCH_DONE: (msg) => dispatch({ type: "runtime/log", level: "info", message: "Chunk batch complete", detail: msg }),
  };

  return (msg) => {
    const type = msg?.type || "";
    dispatch({ type: "runtime/received", messageType: type });
    const handler = handlers[type];
    if (!handler) {
      dispatch({ type: "runtime/fallback", messageType: type || "(missing type)", payload: msg });
      return;
    }
    try {
      handler(msg || {});
    } catch (err) {
      dispatch({
        type: "runtime/handlerError",
        message: err?.message || String(err),
        detail: { messageType: type, payload: msg, stack: err?.stack || "" },
      });
    }
  };
}

function useWorkerGateway(dispatch) {
  const workerRef = useRef(null);
  const routerRef = useRef(null);

  useEffect(() => {
    routerRef.current = createWorkerMessageRouter(dispatch);
  }, [dispatch]);

  useEffect(() => {
    const source = document.getElementById("worker-code")?.textContent || "";
    if (!source.trim()) {
      dispatch({ type: "runtime/error", message: "worker-code script is missing", payload: {} });
      return undefined;
    }
    const blob = new Blob([source], { type: "text/javascript" });
    const url = URL.createObjectURL(blob);
    const worker = new Worker(url);
    workerRef.current = worker;

    worker.onmessage = (event) => routerRef.current?.(event.data || {});
    worker.onerror = (event) => {
      dispatch({ type: "runtime/error", message: event.message || "Worker runtime error", payload: { filename: event.filename, lineno: event.lineno, colno: event.colno } });
    };

    dispatch({ type: "worker/ready" });
    worker.postMessage({ type: "OPFS_LIST" });
    worker.postMessage({ type: "OPFS_ESTIMATE" });
    worker.postMessage({ type: "REMOTE_EXECUTION_STATUS" });
    worker.postMessage({ type: "EXECUTION_PLANE_STATUS" });
    worker.postMessage({ type: "OBSERVATION_ENGINE_STATUS" });
    worker.postMessage({ type: "HYBRID_SURFACE_STATUS" });
    worker.postMessage({ type: "ADAPTIVE_KERNEL_STATUS" });

    return () => {
      worker.terminate();
      URL.revokeObjectURL(url);
      workerRef.current = null;
    };
  }, [dispatch]);

  return useCallback((type, payload = {}, options = {}) => {
    const worker = workerRef.current;
    if (!worker) {
      dispatch({ type: "runtime/error", message: "Worker is not ready", payload: { command: type } });
      return false;
    }
    const message = { ...payload, type };
    if (options.busy) dispatch({ type: "runtime/busy", busy: true, label: options.label || type });
    dispatch({ type: "runtime/sent" });
    worker.postMessage(message);
    return true;
  }, [dispatch]);
}

function requireDataset(state, dispatch) {
  if (!state.dataset.manifest) {
    dispatch({ type: "runtime/error", message: "Datasetを先に開いてください。", payload: {} });
    return false;
  }
  return true;
}

function activeFile(state) {
  return state.importSurface.files[state.importSurface.selectedFileIndex] || state.importSurface.files[0] || null;
}

function commandBase(state) {
  return {
    encoding: state.settings.encoding,
    delimiter: state.settings.delimiter,
    chunkSize: state.settings.chunkSize,
    sampleRows: state.settings.sampleRows,
    pageSize: state.settings.previewRows,
    datasetName: state.settings.datasetName,
    storageWorkspace: state.settings.storageWorkspace,
    storageCollection: state.settings.storageCollection,
    tableName: state.settings.tableName,
    ...state.settings.rules,
  };
}

function columnOptions(manifest, includeNone = false) {
  const cols = columnsFromManifest(manifest);
  const base = includeNone ? [{ index: -1, name: "(none)", type: "" }] : [];
  return [...base, ...cols.map((c, i) => ({ index: Number(c.index ?? i), name: c.name || `Column ${i + 1}`, type: c.type || "" }))];
}

