async function externalFetch(url, init={}, timeoutMs){
  if (!state.externalStorage?.enabled) throw new Error("External Storage is not connected");
  const controller=new AbortController();
  const timer=setTimeout(()=>controller.abort(new Error("External Storage request timeout")), Number(timeoutMs || state.externalStorage.timeoutMs || 120000));
  try{
    const res=await fetch(url,{...init, signal:controller.signal});
    if (!res.ok){
      let message=`External Storage HTTP ${res.status}`;
      try{ const text=await res.text(); if (text) message += `: ${text.slice(0,300)}`; }catch{}
      throw new Error(message);
    }
    return res;
  }finally{
    clearTimeout(timer);
  }
}

function utf8Bytes(text){ return new TextEncoder().encode(String(text)); }
function bytesToHex(bytes){ return Array.from(new Uint8Array(bytes)).map(b=>b.toString(16).padStart(2,"0")).join(""); }
async function sha256Bytes(data){ return await crypto.subtle.digest("SHA-256", data instanceof ArrayBuffer ? data : (ArrayBuffer.isView(data) ? data.buffer.slice(data.byteOffset,data.byteOffset+data.byteLength) : utf8Bytes(data))); }
async function sha256Hex(data){ return bytesToHex(await sha256Bytes(data)); }
async function hmacBytes(key, data){
  const cryptoKey=await crypto.subtle.importKey("raw", key instanceof ArrayBuffer ? key : utf8Bytes(key), {name:"HMAC",hash:"SHA-256"}, false, ["sign"]);
  return await crypto.subtle.sign("HMAC", cryptoKey, data instanceof ArrayBuffer ? data : utf8Bytes(data));
}
function s3Timestamp(date=new Date()){
  const iso=date.toISOString().replace(/[:-]|\.\d{3}/g, "");
  return {amz:iso, short:iso.slice(0,8)};
}
function s3EncodePath(path){ return String(path || "").split("/").filter(Boolean).map(x=>encodeURIComponent(x).replace(/[!'()*]/g,c=>`%${c.charCodeAt(0).toString(16).toUpperCase()}`)).join("/"); }
function s3ObjectUrl(path){
  const cfg=state.externalStorage || {};
  const endpoint=String(cfg.endpoint || "").replace(/\/+$/g, "");
  if (!endpoint) throw new Error("S3 endpoint is empty");
  if (!cfg.bucket) throw new Error("S3 bucket is empty");
  return `${endpoint}/${encodeURIComponent(cfg.bucket)}/${s3EncodePath(path)}`;
}
async function s3SigningKey(secret, date, region, service="s3"){
  let k=await hmacBytes(`AWS4${secret}`, date);
  k=await hmacBytes(k, region);
  k=await hmacBytes(k, service);
  return await hmacBytes(k, "aws4_request");
}
async function s3SignedFetch(method, path, {body=null, contentType="", query=""}={}){
  const cfg=state.externalStorage || {};
  if (!cfg.enabled) throw new Error("External Storage is not connected");
  if (!cfg.accessKeyId || !cfg.secretAccessKey) throw new Error("S3 Access Key / Secret Key is required");
  const urlBase=s3ObjectUrl(path);
  const url=new URL(query ? `${urlBase}?${query}` : urlBase);
  const ts=s3Timestamp();
  const payload=body == null ? new Uint8Array() : (typeof body === "string" ? utf8Bytes(body) : body);
  const payloadHash=await sha256Hex(payload);
  const headers={
    "host":url.host,
    "x-amz-content-sha256":payloadHash,
    "x-amz-date":ts.amz
  };
  if (contentType) headers["content-type"]=contentType;
  if (cfg.sessionToken) headers["x-amz-security-token"]=cfg.sessionToken;
  const signedHeaderNames=Object.keys(headers).map(k=>k.toLowerCase()).sort();
  const canonicalHeaders=signedHeaderNames.map(k=>`${k}:${String(headers[k]).trim().replace(/\s+/g," ")}\n`).join("");
  const canonicalQuery=[...url.searchParams.entries()].sort(([a,av],[b,bv])=> a===b ? av.localeCompare(bv) : a.localeCompare(b)).map(([k,v])=>`${encodeURIComponent(k)}=${encodeURIComponent(v)}`).join("&");
  const canonicalRequest=[method.toUpperCase(), url.pathname, canonicalQuery, canonicalHeaders, signedHeaderNames.join(";"), payloadHash].join("\n");
  const region=cfg.region || "auto";
  const scope=`${ts.short}/${region}/s3/aws4_request`;
  const stringToSign=["AWS4-HMAC-SHA256", ts.amz, scope, await sha256Hex(canonicalRequest)].join("\n");
  const signingKey=await s3SigningKey(cfg.secretAccessKey, ts.short, region, "s3");
  const signature=bytesToHex(await hmacBytes(signingKey, stringToSign));
  const auth=`AWS4-HMAC-SHA256 Credential=${cfg.accessKeyId}/${scope}, SignedHeaders=${signedHeaderNames.join(";")}, Signature=${signature}`;
  const fetchHeaders={...headers, authorization:auth};
  delete fetchHeaders.host;
  const controller=new AbortController();
  const timer=setTimeout(()=>controller.abort(new Error("S3 request timeout")), Number(cfg.timeoutMs || 120000));
  try{
    const res=await fetch(url.toString(),{method:method.toUpperCase(),headers:fetchHeaders,body:method.toUpperCase()==="GET" ? undefined : payload,signal:controller.signal});
    if (!res.ok){
      let message=`S3 HTTP ${res.status}`;
      try{ const text=await res.text(); if (text) message += `: ${text.slice(0,500)}`; }catch{}
      throw new Error(message);
    }
    return res;
  }finally{ clearTimeout(timer); }
}

async function externalReadText(path){
  if (state.externalStorage?.provider === "s3-compatible") return await (await s3SignedFetch("GET", path)).text();
  const res=await externalFetch(externalUrlForFile(path),{method:"GET",headers:externalStorageHeaders()}, state.externalStorage?.timeoutMs);
  return await res.text();
}
async function externalReadJson(path){ return JSON.parse(await externalReadText(path)); }
async function externalReadBuffer(path){
  if (state.externalStorage?.provider === "s3-compatible") return await (await s3SignedFetch("GET", path)).arrayBuffer();
  const res=await externalFetch(externalUrlForFile(path),{method:"GET",headers:externalStorageHeaders()}, state.externalStorage?.timeoutMs);
  return await res.arrayBuffer();
}
async function externalWriteText(path, text){
  if (state.externalStorage?.provider === "s3-compatible") { await s3SignedFetch("PUT", path, {body:String(text ?? ""), contentType:"application/json; charset=utf-8"}); return; }
  await externalFetch(externalUrlForFile(path),{method:"PUT",headers:externalStorageHeaders("application/json; charset=utf-8"),body:String(text ?? "")}, state.externalStorage?.timeoutMs);
}
async function externalWriteJson(path, obj){ await externalWriteText(path, JSON.stringify(obj)); }
async function externalWriteBuffer(path, buffer){
  if (state.externalStorage?.provider === "s3-compatible") { await s3SignedFetch("PUT", path, {body:buffer, contentType:"application/octet-stream"}); return; }
  await externalFetch(externalUrlForFile(path),{method:"PUT",headers:externalStorageHeaders("application/octet-stream"),body:buffer}, state.externalStorage?.timeoutMs);
}

function parseExternalListPayload(payload){
  const raw=Array.isArray(payload) ? payload : (payload?.paths || payload?.items || payload?.objects || payload?.keys || []);
  return raw.map((item)=> typeof item === "string" ? item : (item?.path || item?.key || item?.name || item?.url || "")).map(String).filter(Boolean);
}
function decodeXmlEntities(s){ return String(s || "").replace(/&lt;/g,"<").replace(/&gt;/g,">").replace(/&amp;/g,"&").replace(/&quot;/g,'"').replace(/&#39;/g,"'"); }
function parseS3ListXml(xml){
  const out=[];
  const re=/<Key>([\s\S]*?)<\/Key>/g;
  let m;
  while((m=re.exec(String(xml || "")))) out.push(decodeXmlEntities(m[1]));
  return out;
}
async function externalListPaths(prefix){
  if (state.externalStorage?.provider === "s3-compatible"){
    const paths=[];
    let token="";
    for (let guard=0; guard<100; guard++){
      const params=new URLSearchParams({"list-type":"2",prefix:String(prefix || ""),"max-keys":"1000"});
      if (token) params.set("continuation-token", token);
      const res=await s3SignedFetch("GET", "", {query:params.toString()});
      const xml=await res.text();
      paths.push(...parseS3ListXml(xml));
      const next=xml.match(/<NextContinuationToken>([\s\S]*?)<\/NextContinuationToken>/)?.[1];
      if (!next) break;
      token=decodeXmlEntities(next);
    }
    return paths;
  }
  const res=await externalFetch(externalUrlForList(prefix),{method:"GET",headers:externalStorageHeaders()}, state.externalStorage?.timeoutMs);
  const text=await res.text();
  if (!text) return [];
  let payload;
  try{ payload=JSON.parse(text); }catch{ return text.split(/\r?\n/).map(x=>x.trim()).filter(Boolean); }
  return parseExternalListPayload(payload);
}

function externalDatasetIdFromManifestPath(path){
  const prefix=`${normalizeExternalStoragePrefix(state.externalStorage?.prefix)}/datasets/`;
  const s=String(path || "");
  if (!s.startsWith(prefix) || !s.endsWith("/manifest.json")) return "";
  return s.slice(prefix.length, -"/manifest.json".length).split("/")[0] || "";
}

async function testExternalStorage(config={}){
  configureExternalStorage({...state.externalStorage,...config,enabled:true});
  const t0=now();
  const prefix=`${normalizeExternalStoragePrefix(state.externalStorage.prefix)}/datasets/`;
  try{
    const paths=await externalListPaths(prefix);
    state.externalStorage.lastProbe={ok:true,checkedAt:new Date().toISOString(),ms:Math.round(now()-t0),count:paths.length};
    return externalStorageStatus({ok:true,count:paths.length});
  }catch(e){
    state.externalStorage.lastProbe={ok:false,checkedAt:new Date().toISOString(),ms:Math.round(now()-t0),message:issueText(e)};
    return externalStorageStatus({ok:false,message:`Connected config saved, but list failed: ${issueText(e)}`});
  }
}

async function listExternalDatasets(){
  const prefix=`${normalizeExternalStoragePrefix(state.externalStorage?.prefix)}/datasets/`;
  const paths=await externalListPaths(prefix);
  const ids=[...new Set(paths.map(externalDatasetIdFromManifestPath).filter(Boolean))].sort();
  const rows=[];
  for (const id of ids){
    try{
      const base=externalDatasetBasePath(id);
      const m=await externalReadJson(`${base}/manifest.json`);
      rows.push({id,workspace:manifestWorkspace(m),collection:manifestCollection(m),tableName:manifestTableName(m),path:manifestPath(m),name:m.name||id,originalFileName:m.originalFileName||"",createdAt:m.createdAt||"",rows:m.totalRows||0,sourceRows:m.sourceRows||0,columns:(m.columns||[]).length,chunks:m.chunks||0,fileSize:m.fileSize||0,mode:m.mode||"",external:true});
    }catch(e){
      rows.push({id,name:id,workspace:"External",collection:"Unreadable",tableName:id,path:`External / Unreadable / ${id}`,rows:0,columns:0,chunks:0,mode:`error: ${issueText(e)}`,external:true});
    }
  }
  rows.sort((a,b)=>String(b.createdAt).localeCompare(String(a.createdAt)));
  return rows;
}

async function syncDatasetToExternal(datasetId){
  if (!state.externalStorage?.enabled) throw new Error("External Storage is not connected");
  const id=datasetId || state.dataset?.id || state.manifest?.id;
  if (!id || String(id).startsWith("virtual:") || String(id).startsWith("memory:") || state.manifest?.openedFromExternalStorage) throw new Error("Sync requires one physical OPFS dataset");
  const loaded=await loadValidatedDataset(id,{rebuildStats:true});
  const {dir,manifest,chunks}=loaded;
  const base=externalDatasetBasePath(id);
  const columns=manifest.columns || [];
  const t0=now();
  let filesWritten=0, bytesWritten=0;
  postProgress(1, `External sync start: ${manifest.name || id}`);
  await externalWriteJson(`${base}/manifest.json`, {...manifest, externalStorageSyncedAt:new Date().toISOString()}); filesWritten++;
  await externalWriteJson(`${base}/chunks.json`, chunks); filesWritten++;
  for (let c=0; c<chunks.length; c++){
    if (state.cancelled) throw new Error("Cancelled");
    const chunkName=`chunk_${String(c).padStart(6,"0")}`;
    const chunkDir=await dir.getDirectoryHandle(chunkName);
    try{ await externalWriteText(`${base}/${chunkName}/meta.json`, await readText(chunkDir,"meta.json")); filesWritten++; }catch{}
    for (const col of columns){
      const colName=colFileName(col.index,col.type);
      const buf=await readBuffer(chunkDir,colName);
      await externalWriteBuffer(`${base}/${chunkName}/${colName}`, buf);
      filesWritten++; bytesWritten += Number(buf.byteLength || 0);
      if (col.type === "string"){
        const dictName=dictFileName(col.index);
        const dictText=await readText(chunkDir,dictName);
        await externalWriteText(`${base}/${chunkName}/${dictName}`, dictText);
        filesWritten++; bytesWritten += dictText.length * 2;
      }
    }
    postProgress(Math.min(99, Math.floor(((c+1)/Math.max(1,chunks.length))*100)), `External sync... chunks ${fmt(c+1)}/${fmt(chunks.length)} / files ${fmt(filesWritten)}`);
  }
  return {id,manifest,filesWritten,bytesWritten,ms:now()-t0,base};
}

async function openExternalDataset(id){
  if (!state.externalStorage?.enabled) throw new Error("External Storage is not connected");
  const datasetId=safeId(id);
  if (!datasetId) throw new Error("External dataset id is empty");
  clearChunkCache();
  const base=externalDatasetBasePath(datasetId);
  const manifest=await externalReadJson(`${base}/manifest.json`);
  const chunks=await externalReadJson(`${base}/chunks.json`);
  if (!manifest || !Array.isArray(manifest.columns)) throw new Error("External manifest is invalid");
  if (!Array.isArray(chunks)) throw new Error("External chunks.json is invalid");
  const openedManifest={...manifest,id:manifest.id || datasetId,openedFromExternalStorage:true,externalStoragePath:base};
  state.virtual=null; state.memory=null; state.dir=null;
  state.externalDataset={id:datasetId,base,manifest:openedManifest,chunks};
  state.manifest=openedManifest;
  state.dataset={id:datasetId,manifest:openedManifest,chunks};
  state.searchMatches=[]; state.dataQueryMatches=null; state.dataQueryMeta=null; state.pivotTable=null; state.pivotTileIndex=null; state.timeTable=null;
  return {manifest:openedManifest,chunks};
}

function activeIsExternalStorage(){ return !!state.externalDataset && !!state.manifest?.openedFromExternalStorage; }


const CHUNK_WORKER_POOL_VERSION = 1;

function chunkExecutionContextSnapshot(){
  if (activeIsMemory()) return {mode:"memory", reason:"In-memory chunks cannot be shared across nested workers yet"};
  if (activeIsExternalStorage()) return {mode:"external", reason:"External Storage credentials stay in the main worker memory only"};
  if (activeIsVirtual()){
    return {
      mode:"virtual",
      sourceIds:(state.virtual?.sources || []).map(s => s.id).filter(Boolean),
      name:state.manifest?.name || "virtual_worker_pool"
    };
  }
  const id=state.dataset?.id || state.manifest?.id;
  return id ? {mode:"storage", datasetId:id} : {mode:"none", reason:"No active storage-backed dataset"};
}

async function hydrateChunkExecutionContext(context){
  if (!context || context.mode === "none") throw new Error(context?.reason || "Chunk worker context is empty");
  if (context.mode === "memory") throw new Error(context.reason || "Memory dataset is not supported by worker pool");
  if (context.mode === "storage"){
    const loaded=await loadDatasetForWorkerReadOnly(context.datasetId);
    state.virtual=null;
    state.memory=null;
    state.dir=loaded.dir;
    state.manifest=loaded.manifest;
    state.dataset={id:loaded.id,manifest:loaded.manifest,chunks:loaded.chunks};
    return;
  }
  if (context.mode === "virtual"){
    await openVirtualDatasetForWorkerReadOnly(context.sourceIds || [], context.name || "virtual_worker_pool");
    return;
  }
  throw new Error(`Unsupported chunk worker context: ${context.mode}`);
}

function defaultChunkWorkerCount(chunkCount){
  const cores=Number(navigator?.hardwareConcurrency || 4);
  return Math.max(1, Math.min(Number(chunkCount || 1), Math.max(1, cores - 1), 6));
}

function canUseChunkWorkerPool(plan, options, chunks){
  if (options?.parallel === false) return false;
  if (options?.onMatch || options?.onChunkStart || options?.onChunkEnd) return false;
  if (!(options?.collectRows || options?.collectSort || options?.collectPartials || plan?.aggregate)) return false;
  if (!Array.isArray(chunks) || chunks.length < 2) return false;
  if (activeIsMemory()) return false;
  if (activeIsExternalStorage()) return false;
  if (typeof Worker === "undefined") return false;
  if (!self.location || !self.location.href) return false;
  const context=chunkExecutionContextSnapshot();
  if (context.mode !== "storage" && context.mode !== "virtual") return false;
  return !!plan;
}

function shardChunksContiguously(chunks, workerCount){
  const n=Math.max(1, Math.min(Number(workerCount || 1), chunks.length));
  const out=[];
  const size=Math.ceil(chunks.length / n);
  for (let i=0;i<n;i++){
    const batch=chunks.slice(i*size, (i+1)*size);
    if (batch.length) out.push(batch);
  }
  return out;
}

function serializableExecutionOptions(options={}){
  return {
    collectRows:!!options.collectRows,
    collectSort:!!options.collectSort,
    collectPartials:!!options.collectPartials,
    limit:Number.POSITIVE_INFINITY,
    progress:false,
    parallel:false
  };
}

function runChunkExecutorWorker({requestId, batchIndex, context, plan, options}){
  return new Promise((resolve,reject)=>{
    let worker;
    try{ worker=new Worker(self.location.href); }
    catch(err){ reject(err); return; }
    let settled=false;
    const cleanup=()=>{ try{ worker.terminate(); }catch{} };
    worker.onmessage=(e)=>{
      const msg=e.data || {};
      if (msg.type === "CHUNK_BATCH_DONE" && msg.requestId === requestId){
        if (settled) return;
        settled=true;
        cleanup();
        resolve({...msg.result,batchIndex});
      } else if (msg.type === "ERROR"){
        if (settled) return;
        settled=true;
        cleanup();
        reject(new Error(msg.message || "Chunk executor failed"));
      }
    };
    worker.onerror=(err)=>{
      if (settled) return;
      settled=true;
      cleanup();
      reject(new Error(err?.message || "Chunk executor worker error"));
    };
    worker.postMessage({type:"EXECUTE_CHUNK_BATCH", requestId, batchIndex, context, plan, options});
  });
}

function reduceChunkWorkerResults(plan, options, chunks, batches, results, t0){
  const ordered=[...results].sort((a,b)=>Number(a.batchIndex||0)-Number(b.batchIndex||0));
  let refs=[], sortable=[], partials=[];
  let scanned=0, matched=0, skippedChunks=0;
  for (const r of ordered){
    scanned += Number(r.scanned || 0);
    matched += Number(r.matched || 0);
    skippedChunks += Number(r.skippedChunks || 0);
    if (Array.isArray(r.refs)) refs.push(...r.refs);
    if (Array.isArray(r.sortable)) sortable.push(...r.sortable);
    if (Array.isArray(r.partials)) partials.push(...r.partials);
  }

  const limit=normalizePlanLimit(options.limit ?? plan?.limit);
  let capped=false;
  if (options.collectRows && Number.isFinite(limit) && refs.length > limit){
    refs=refs.slice(0, limit);
    capped=true;
  }
  if (options.collectSort && Number.isFinite(limit) && sortable.length > limit){
    // Keep the full sortable list for correct final ordering. The caller sorts and slices.
    capped=true;
  }

  return {
    taskId:options.taskId || executionTaskId(plan?.name || "query"),
    engineVersion:CHUNK_EXECUTION_ENGINE_VERSION,
    workerPoolVersion:CHUNK_WORKER_POOL_VERSION,
    executionMode:"worker-pool",
    workerCount:batches.length,
    chunks,
    refs,
    sortable,
    partials,
    scanned,
    matched,
    skippedChunks,
    capped,
    ms:now()-t0,
    queryPlan:{...queryPlanSummary(plan), executionEngine:"chunk-pool-v1", workerPool:{version:CHUNK_WORKER_POOL_VERSION, workers:batches.length}, distributedReduce:!!plan?.aggregate}
  };
}

async function executeChunkExecutionPlanLocalMaybeParallel(plan, options={}){
  const chunks=selectChunksForPlan(plan);
  if (!canUseChunkWorkerPool(plan, options, chunks)){
    const exec=await executeChunkExecutionPlan(plan, options);
    exec.executionMode=exec.executionMode || "single-worker";
    return exec;
  }

  const t0=now();
  const context=chunkExecutionContextSnapshot();
  const workerCount=defaultChunkWorkerCount(chunks.length);
  const batches=shardChunksContiguously(chunks, workerCount);
  const taskId=options.taskId || executionTaskId(`${plan?.name || "query"}_pool`);
  const progressLabel=options.progressLabel || plan?.name || "Executing chunks";
  post("PROGRESS",{value:1,text:`${progressLabel} with Worker Pool... workers ${batches.length} / chunks ${fmt(chunks.length)}`});

  try{
    let completed=0;
    const results=await Promise.all(batches.map((batch,batchIndex)=>{
      const batchPlan={...plan,chunks:batch,limit:Number.POSITIVE_INFINITY};
      const batchOptions=serializableExecutionOptions(options);
      return runChunkExecutorWorker({requestId:`${taskId}_${batchIndex}`, batchIndex, context, plan:batchPlan, options:batchOptions})
        .then(result=>{
          completed++;
          post("PROGRESS",{value:Math.min(99,Math.floor((completed / batches.length) * 100)),text:`${progressLabel} with Worker Pool... batches ${completed}/${batches.length}`});
          return result;
        });
    }));
    return reduceChunkWorkerResults(plan,{...options,taskId},chunks,batches,results,t0);
  }catch(err){
    post("PROGRESS",{value:0,text:`Worker Pool fallback: ${err?.message || err}`});
    const exec=await executeChunkExecutionPlan(plan,{...options,parallel:false});
    exec.executionMode="single-worker-fallback";
    exec.workerPoolError=err?.message || String(err);
    return exec;
  }
}


async function executeChunkExecutionPlanMaybeParallel(plan, options={}){
  const chunks=selectChunksForPlan(plan);
  const cfg=state.remoteExecution || {};
  const remoteEligible=canUseRemoteExecution(plan, options, chunks);

  if (canUseAdaptiveKernel(plan, options) && !(remoteEligible && cfg.mode === "remote-only")){
    return await executeHyperTensorAdaptivePlan(plan, {...options, chunks});
  }

  if (canUseObservationEngine(plan, options) && !(remoteEligible && cfg.mode === "remote-only")){
    return await executeObservationPlan(plan, {...options, chunks});
  }

  if (remoteEligible && (cfg.mode === "remote-first" || cfg.mode === "remote-only")){
    try{
      return await executeChunkExecutionPlanRemote(plan, options, chunks);
    }catch(err){
      if (cfg.mode === "remote-only") throw err;
      post("PROGRESS",{value:0,text:`Remote Execution fallback: ${err?.message || err}`});
    }
  }

  const local=await executeChunkExecutionPlanLocalMaybeParallel(plan, options);
  if (remoteEligible && cfg.mode === "local-first"){
    local.remoteExecutionAvailable=true;
    local.queryPlan={...(local.queryPlan || queryPlanSummary(plan)), remoteExecution:{version:REMOTE_EXECUTION_ADAPTER_VERSION, available:true, mode:cfg.mode}};
  }
  return local;
}

function compactStringColumnForMemory(idsArr, dict){
  const used=new Map();
  const newDict=[];
  const remapped=new Int32Array(idsArr.length);
  for (let i=0;i<idsArr.length;i++){
    const oldId=idsArr[i];
    if (oldId < 0){ remapped[i] = -1; continue; }
    let newId=used.get(oldId);
    if (newId == null){
      newId=newDict.length;
      used.set(oldId,newId);
      newDict.push(dict[oldId] ?? "");
    }
    remapped[i]=newId;
  }
  return {ids:remapped, dict:newDict};
}

async function analyzeSchema({file, encoding, delimiter, sampleRows, rules}){
  state.file=file; state.encoding=encoding; state.delimiter=delimiter;
  postProgress(1, `Preparing CSV schema: ${file.name}`);
  const iter=fileLines(file, encoding, 0, `Reading sample ${file.name}`, 2, 58);
  const first=await iter.next();
  if (first.done) throw new Error("CSV is empty");
  const rawHeaders=parseCSVLine(first.value, delimiter);
  const headers=uniqueNames(rawHeaders.map((h,i)=>cleanHeaderName(h,i,rules)));
  const stats=headers.map(()=>({nonNull:0,num:0,nulls:0,examples:[]}));
  let sampled=0, malformed=0, changed=0;

  for await (const line of iter){
    if (sampled >= sampleRows) break;
    if (!line && sampled >= sampleRows) break;
    let cells=parseCSVLine(line, delimiter);
    if (cells.length !== headers.length) malformed++;
    if (rules.skipBadRows && cells.length !== headers.length) continue;
    while(cells.length < headers.length) cells.push("");
    if (cells.length > headers.length) cells=cells.slice(0, headers.length);

    for (let i=0;i<headers.length;i++){
      const c=cleanCell(cells[i], rules);
      if (c.changed) changed++;
      if (c.value == null){ stats[i].nulls++; continue; }
      stats[i].nonNull++;
      const n=numberCandidate(c.value, rules);
      if (n.ok) stats[i].num++;
      if (stats[i].examples.length < 3) stats[i].examples.push(c.value);
    }
    sampled++;
    if (sampled % 1000 === 0) postProgress(Math.min(88, 60 + Math.floor(sampled/Math.max(1,sampleRows)*28)), `Analyzing sample rows... ${fmt(sampled)}/${fmt(sampleRows)}`);
  }

  const columns=headers.map((name,i)=>{
    const s=stats[i];
    const ratio=s.nonNull ? s.num / s.nonNull : 0;
    return {index:i,name,type: ratio >= rules.numericThreshold ? "number" : "string", sampleNonNull:s.nonNull, sampleNulls:s.nulls, numericRatio:ratio, examples:s.examples};
  });

  state.schema={headers, columns, rules, sampleRows:sampled, malformedSampleRows:malformed, changedSampleCells:changed};
  state.schemaFileKey=schemaCacheKey(file, encoding, delimiter, rules);
  postProgress(92, `Schema sample complete: ${fmt(sampled)} rows / ${fmt(headers.length)} columns`);
  return state.schema;
}

function initChunk(columns){
  return {
    rows:0,
    numeric: columns.map(c => c.type === "number" ? [] : null),
    stringIds: columns.map(c => c.type === "string" ? [] : null),
    dictMaps: columns.map(c => c.type === "string" ? new Map() : null),
    dictValues: columns.map(c => c.type === "string" ? [] : null),
    stats: columns.map(c => ({
      type:c.type,nulls:0,invalidNumbers:0,changedCells:0,min:null,max:null,distinct:0
    }))
  };
}

function addRowToChunk(chunk, cells, columns, rules){
  for (const col of columns){
    const raw = cells[col.index] ?? "";
    const cleaned = cleanCell(raw, rules);
    if (cleaned.changed) chunk.stats[col.index].changedCells++;

    if (col.type === "number"){
      if (cleaned.value == null){
        chunk.numeric[col.index].push(NaN);
        chunk.stats[col.index].nulls++;
      } else {
        const n=numberCandidate(cleaned.value, rules);
        if (n.ok){
          chunk.numeric[col.index].push(n.value);
          const st=chunk.stats[col.index];
          st.min = st.min == null ? n.value : Math.min(st.min,n.value);
          st.max = st.max == null ? n.value : Math.max(st.max,n.value);
        } else {
          chunk.numeric[col.index].push(NaN);
          chunk.stats[col.index].nulls++;
          chunk.stats[col.index].invalidNumbers++;
        }
      }
    } else {
      if (cleaned.value == null){
        chunk.stringIds[col.index].push(-1);
        chunk.stats[col.index].nulls++;
      } else {
        const map=chunk.dictMaps[col.index];
        let id=map.get(cleaned.value);
        if (id === undefined){
          id=chunk.dictValues[col.index].length;
          map.set(cleaned.value,id);
          chunk.dictValues[col.index].push(cleaned.value);
        }
        chunk.stringIds[col.index].push(id);
      }
    }
  }
  chunk.rows++;
}

async function flushChunk(datasetDir, chunkIndex, chunk, columns){
  const chunkDir=await datasetDir.getDirectoryHandle(`chunk_${String(chunkIndex).padStart(6,"0")}`, {create:true});
  const columnStats={};
  for (const col of columns){
    if (col.type === "number"){
      const arr=new Float64Array(chunk.numeric[col.index]);
      await writeBuffer(chunkDir, colFileName(col.index,col.type), arr.buffer);
      columnStats[String(col.index)] = makeColumnStatForMeta(chunk.stats[col.index], chunk.rows);
    } else {
      const arr=new Int32Array(chunk.stringIds[col.index]);
      await writeBuffer(chunkDir, colFileName(col.index,col.type), arr.buffer);
      await writeJson(chunkDir, dictFileName(col.index), chunk.dictValues[col.index]);
      chunk.stats[col.index].distinct = chunk.dictValues[col.index].length;
      columnStats[String(col.index)] = makeColumnStatForMeta(chunk.stats[col.index], chunk.rows, chunk.dictValues[col.index]);
    }
  }
  const meta={chunkIndex,rowCount:chunk.rows,stats:chunk.stats,columnStats,indexVersion:1};
  await writeJson(chunkDir,"meta.json",meta);
  return meta;
}

function schemaHeaderSignature(schema){
  return (schema?.columns || []).map(c => c.name).join("\u001f");
}
function schemaFullSignatureFromColumns(columns){
  return (columns || []).map(c => `${c.name}\u001e${c.type}`).join("\u001f");
}
function schemaMismatchMessage(a,b){
  const ac=a?.columns||[], bc=b?.columns||[];
  if (ac.length !== bc.length) return `Column count mismatch: ${ac.length} vs ${bc.length}`;
  const diffs=[];
  for (let i=0;i<ac.length;i++){
    if (ac[i].name !== bc[i].name) diffs.push(`#${i+1}: ${ac[i].name} != ${bc[i].name}`);
    if (diffs.length >= 5) break;
  }
  return diffs.length ? diffs.join(" / ") : "Column names are different";
}
function schemaTypeWarnings(base, other, fileName){
  const warnings=[];
  const ac=base?.columns||[], bc=other?.columns||[];
  for (let i=0;i<Math.min(ac.length,bc.length);i++){
    if (ac[i].type !== bc[i].type) warnings.push(`${fileName} #${i+1} ${ac[i].name}: ${bc[i].type} -> ${ac[i].type}`);
    if (warnings.length >= 10) break;
  }
  return warnings;
}
async function analyzeFilesForMerge({files, encoding, delimiter, sampleRows, rules}){
  const list=(Array.isArray(files) && files.length ? files : []).filter(Boolean);
  if (!list.length) throw new Error("CSV file is not selected");
  const fileSchemas=[];
  let base=null;
  const typeWarnings=[];
  for (let i=0;i<list.length;i++){
    if (state.cancelled) throw new Error("Cancelled");
    postProgress(Math.floor(i/Math.max(1,list.length)*100), `Analyzing CSV ${i+1}/${list.length}: ${list[i].name}`);
    const schema=await analyzeSchema({file:list[i], encoding, delimiter, sampleRows:Number(sampleRows||20000), rules});
    fileSchemas.push({
      name:list[i].name,
      size:list[i].size,
      columns:schema.columns.length,
      sampleRows:schema.sampleRows,
      malformedSampleRows:schema.malformedSampleRows,
      changedSampleCells:schema.changedSampleCells,
      signature:schemaHeaderSignature(schema)
    });
    if (!base) base=schema;
    else {
      if (schemaHeaderSignature(base) !== schemaHeaderSignature(schema)) {
        throw new Error(`Merge blocked: ${list[i].name} has a different column layout. ${schemaMismatchMessage(base,schema)}`);
      }
      typeWarnings.push(...schemaTypeWarnings(base,schema,list[i].name));
    }
  }
  state.schema=base;
  return {schema:base,fileSchemas,typeWarnings};
}

async function buildSingleColumnarCache(msg){
  clearChunkCache();
  const rules=makeRules(msg);
  const cacheKey=schemaCacheKey(msg.file, msg.encoding, msg.delimiter, rules);
  let schema=state.schema;
  if (!schema || !schema.columns || state.schemaFileKey !== cacheKey || msg.forceAnalyze){
    schema=await analyzeSchema({file:msg.file, encoding:msg.encoding, delimiter:msg.delimiter, sampleRows:Number(msg.sampleRows||20000), rules});
  }

  state.file=msg.file; state.encoding=msg.encoding; state.delimiter=msg.delimiter;
  const root=await rootDir();
  const id=makeDatasetId(msg.datasetName || msg.file.name);
  const dir=await root.getDirectoryHandle(id,{create:true});
  const t0=now();

  try{
    const columns=schema.columns;
    const chunkSize=Math.max(1000,Number(msg.chunkSize||100000));
    const iter=fileLines(msg.file, msg.encoding, 0, `Reading ${msg.file.name} for cache`, 8, 72);
    await iter.next(); // header

    let chunk=initChunk(columns);
    let chunkIndex=0, totalRows=0, sourceRows=0, skippedRows=0, malformedRows=0;
    const chunkMetas=[];

    for await (const line of iter){
      if (state.cancelled) throw new Error("Cancelled");
      sourceRows++;
      let cells=parseCSVLine(line, msg.delimiter);
      if (cells.length !== columns.length) malformedRows++;
      if (rules.skipBadRows && cells.length !== columns.length){ skippedRows++; continue; }
      while(cells.length < columns.length) cells.push("");
      if (cells.length > columns.length) cells=cells.slice(0, columns.length);

      addRowToChunk(chunk,cells,columns,rules);
      totalRows++;

      if (chunk.rows >= chunkSize){
        const meta=await flushChunk(dir,chunkIndex,chunk,columns);
        chunkMetas.push(meta);
        chunkIndex++;
        chunk=initChunk(columns);
        postProgress(progressCurrentValue, `Writing chunk ${fmt(chunkIndex)}... rows ${fmt(totalRows)}`);
      }
      if (sourceRows % 50000 === 0){
        postProgress(progressCurrentValue, `Building columnar... source rows ${fmt(sourceRows)} / output rows ${fmt(totalRows)} / chunks ${fmt(chunkIndex)}`);
      }
    }
    if (chunk.rows > 0){
      const meta=await flushChunk(dir,chunkIndex,chunk,columns);
      chunkMetas.push(meta);
      chunkIndex++;
    }

    postProgress(88, `Finalizing columnar cache... ${fmt(totalRows)} rows / ${fmt(chunkIndex)} chunks`);

    const cleanReport={
      sourceRows,totalRows,skippedRows,malformedRows,
      changedCells:chunkMetas.flatMap(c=>c.stats).reduce((a,s)=>a+(s.changedCells||0),0),
      nullCells:chunkMetas.flatMap(c=>c.stats).reduce((a,s)=>a+(s.nulls||0),0),
      invalidNumbers:chunkMetas.flatMap(c=>c.stats).reduce((a,s)=>a+(s.invalidNumbers||0),0)
    };

    const tableName=cleanMetaValue(msg.tableName || msg.datasetName || msg.file.name, msg.file.name);
    const manifest={
      id,
      name:msg.datasetName || tableName,
      storageWorkspace:cleanMetaValue(msg.storageWorkspace, "Default"),
      storageCollection:cleanMetaValue(msg.storageCollection, "General"),
      tableName,
      storagePath:`${cleanMetaValue(msg.storageWorkspace, "Default")} / ${cleanMetaValue(msg.storageCollection, "General")} / ${tableName}`,
      originalFileName:msg.file.name,
      sourceFiles:[{name:msg.file.name,size:msg.file.size,sourceRows,totalRows,skippedRows,malformedRows}],
      createdAt:new Date().toISOString(), mode:"columnar-clean",
      formatVersion:5, features:integrityFeatureFlags({}),
      encoding:msg.encoding, delimiter:msg.delimiter, fileSize:msg.file.size,
      chunkSize,totalRows,sourceRows,chunks:chunkIndex,
      columns, rules, cleanReport
    };
    postProgress(94, "Writing manifest and chunk metadata...");
    await writeJson(dir,"manifest.json",manifest);
    await writeJson(dir,"chunks.json",chunkMetas);

    state.dataset={id,manifest,chunks:chunkMetas};
    state.virtual=null; state.memory=null; state.manifest=manifest; state.dir=dir; state.searchMatches=[]; state.dataQueryMatches=null; state.dataQueryMeta=null; state.pivotTable=null; state.pivotTileIndex=null; state.timeTable=null;
    return {manifest,chunks:chunkMetas,ms:now()-t0};
  }catch(err){
    await cleanupDatasetDir(root,id);
    throw err;
  }
}

async function buildMergedColumnarCache(msg){
  clearChunkCache();
  const rules=makeRules(msg);
  const files=(Array.isArray(msg.files) && msg.files.length ? msg.files : [msg.file]).filter(Boolean);
  if (files.length < 2) return buildSingleColumnarCache({...msg,file:files[0]});

  const analyzed=await analyzeFilesForMerge({files, encoding:msg.encoding, delimiter:msg.delimiter, sampleRows:Number(msg.sampleRows||20000), rules});
  const schema=analyzed.schema;
  const columns=schema.columns;
  state.file=files[0]; state.encoding=msg.encoding; state.delimiter=msg.delimiter;

  const root=await rootDir();
  const id=makeDatasetId(msg.datasetName || `merged_${files.length}_csv`);
  const dir=await root.getDirectoryHandle(id,{create:true});
  const t0=now();

  try{
    const chunkSize=Math.max(1000,Number(msg.chunkSize||100000));
    let chunk=initChunk(columns);
    let chunkIndex=0, totalRows=0, sourceRows=0, skippedRows=0, malformedRows=0;
    const sourceFiles=[];
    const chunkMetas=[];

    for (let f=0; f<files.length; f++){
      const file=files[f];
      const iter=fileLines(file, msg.encoding, 0, `Reading CSV ${f+1}/${files.length} ${file.name}`, Math.floor((f/files.length)*80)+8, Math.max(1, Math.floor(80/files.length)));
      await iter.next(); // header
      let fileSourceRows=0, fileTotalRows=0, fileSkippedRows=0, fileMalformedRows=0;
      postProgress(Math.floor((f/files.length)*80)+8, `Merging CSV ${f+1}/${files.length}: ${file.name}`);

      for await (const line of iter){
        if (state.cancelled) throw new Error("Cancelled");
        fileSourceRows++; sourceRows++;
        let cells=parseCSVLine(line, msg.delimiter);
        if (cells.length !== columns.length){ malformedRows++; fileMalformedRows++; }
        if (rules.skipBadRows && cells.length !== columns.length){ skippedRows++; fileSkippedRows++; continue; }
        while(cells.length < columns.length) cells.push("");
        if (cells.length > columns.length) cells=cells.slice(0, columns.length);

        addRowToChunk(chunk,cells,columns,rules);
        totalRows++; fileTotalRows++;

        if (chunk.rows >= chunkSize){
          const meta=await flushChunk(dir,chunkIndex,chunk,columns);
          chunkMetas.push(meta);
          chunkIndex++;
          chunk=initChunk(columns);
        }
        if (sourceRows % 50000 === 0){
          postProgress(progressCurrentValue, `Merging... source rows ${fmt(sourceRows)} / output rows ${fmt(totalRows)} / chunks ${fmt(chunkIndex)}`);
        }
      }
      sourceFiles.push({name:file.name,size:file.size,sourceRows:fileSourceRows,totalRows:fileTotalRows,skippedRows:fileSkippedRows,malformedRows:fileMalformedRows});
    }

    if (chunk.rows > 0){
      const meta=await flushChunk(dir,chunkIndex,chunk,columns);
      chunkMetas.push(meta);
      chunkIndex++;
    }

    postProgress(88, `Finalizing merged cache... ${fmt(totalRows)} rows / ${fmt(chunkIndex)} chunks`);

    const cleanReport={
      sourceRows,totalRows,skippedRows,malformedRows,
      changedCells:chunkMetas.flatMap(c=>c.stats).reduce((a,s)=>a+(s.changedCells||0),0),
      nullCells:chunkMetas.flatMap(c=>c.stats).reduce((a,s)=>a+(s.nulls||0),0),
      invalidNumbers:chunkMetas.flatMap(c=>c.stats).reduce((a,s)=>a+(s.invalidNumbers||0),0),
      typeWarnings:analyzed.typeWarnings
    };

    const tableName=cleanMetaValue(msg.tableName || msg.datasetName || `merged_${files.length}_csv`, `merged_${files.length}_csv`);
    const manifest={
      id,
      name:msg.datasetName || tableName,
      storageWorkspace:cleanMetaValue(msg.storageWorkspace, "Default"),
      storageCollection:cleanMetaValue(msg.storageCollection, "General"),
      tableName,
      storagePath:`${cleanMetaValue(msg.storageWorkspace, "Default")} / ${cleanMetaValue(msg.storageCollection, "General")} / ${tableName}`,
      originalFileName:files.map(f=>f.name).join(" + "),
      sourceFiles,
      createdAt:new Date().toISOString(), mode:"columnar-clean-merged-csv",
      formatVersion:5, features:integrityFeatureFlags({}),
      encoding:msg.encoding, delimiter:msg.delimiter, fileSize:files.reduce((a,f)=>a+(f.size||0),0),
      chunkSize,totalRows,sourceRows,chunks:chunkIndex,
      columns, rules, cleanReport
    };
    await writeJson(dir,"manifest.json",manifest);
    await writeJson(dir,"chunks.json",chunkMetas);

    state.dataset={id,manifest,chunks:chunkMetas};
    state.virtual=null; state.memory=null; state.manifest=manifest; state.dir=dir; state.searchMatches=[]; state.dataQueryMatches=null; state.dataQueryMeta=null; state.pivotTable=null; state.pivotTileIndex=null; state.timeTable=null;
    return {manifest,chunks:chunkMetas,ms:now()-t0,typeWarnings:analyzed.typeWarnings};
  }catch(err){
    await cleanupDatasetDir(root,id);
    throw err;
  }
}

