function chunkBaseRow(chunkIndex){
  if (activeIsMemory()) return Number(state.memory.chunks[chunkIndex]?.rowStart || 0);
  if (activeIsVirtual()) return Number(state.virtual.globalChunks[chunkIndex]?.rowStart || 0);
  const chunks=state.dataset?.chunks || [];
  let start=0;
  for (let i=0;i<chunkIndex;i++) start += Number(chunks[i]?.rowCount || 0);
  return start;
}

