  if (!p || !state.manifest?.columns?.[Number(p.columnIndex)]) return null;
  const col=state.manifest.columns[Number(p.columnIndex)];
  const op=normalizeQueryOp(p.op, col.type);
  const rawTarget=String(p.value ?? "");
  let regex=null;
  if (op === "regex") { try { regex=new RegExp(rawTarget, "i"); } catch { regex=null; } }
  return {
    ...p,
    columnIndex:Number(p.columnIndex),
    columnName:col.name,
    type:col.type,
    op,
    value:p.value ?? "",
    targetRaw:rawTarget,
    targetLower:rawTarget.toLowerCase(),
    targetNumber:Number(rawTarget),
    regex,
    rowLevel:p.rowLevel !== false,
    pushdown:p.pushdown !== false,
    compiled:true
